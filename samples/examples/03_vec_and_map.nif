// Vec (Obj elements) and Map (Obj -> Obj keys via Hashable/Equalable)
import std.box;
import std.vec;

export fn main() -> unit {
    var nums: Vec = Vec.new();
    nums.push((Obj)BoxI64(10));
    nums.push((Obj)BoxI64(10));
    nums.push((Obj)BoxI64(42));

    var m: Map = Map();

    // BoxI64 equality/hash semantics treat equal boxed values as the same logical key
    var k1: Obj = nums.index_get(0);
    var k2: Obj = nums.index_get(1);
    var v1: Obj = (Obj)"first ten";
    var v2: Obj = (Obj)"second ten";

    m.put(k1, v1);
    m.put(k2, v2);

    var contains_k1: bool = m.contains(k1);
    var contains_k2: bool = m.contains(k2);

    var _sink1: bool = contains_k1;
    var _sink2: bool = contains_k2;
    var _sink3: i64 = (i64)nums.len();
}
