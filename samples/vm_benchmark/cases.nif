    code[14] = instructions.JumpOp(opcodes.jump_opcode(), 7u);
    code[15] = instructions.LoadConstOp(opcodes.load_const_opcode(), 0, 0u);
    code[16] = instructions.CmpLtOp(opcodes.cmp_lt_opcode(), 7, 0, 1);
    code[17] = instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 7, 26u);
    code[18] = instructions.LoadMemIndexedOp(opcodes.load_mem_indexed_opcode(), 8, 6, 0);
    code[19] = instructions.AddOp(opcodes.add_opcode(), 3, 3, 8);
    code[20] = instructions.ModOp(opcodes.mod_opcode(), 10, 0, 4);
    code[21] = instructions.CmpEqOp(opcodes.cmp_eq_opcode(), 7, 10, 5);
    code[22] = instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 7, 24u);
    code[23] = instructions.AddOp(opcodes.add_opcode(), 3, 3, 2);
    code[24] = instructions.AddOp(opcodes.add_opcode(), 0, 0, 2);
    code[25] = instructions.JumpOp(opcodes.jump_opcode(), 16u);
    code[26] = instructions.StoreMemOp(opcodes.store_mem_opcode(), 8, 3);
    code[27] = instructions.RegisterCopyOp(opcodes.move_opcode(), 0, 3);
    code[28] = instructions.CallBuiltinOp(opcodes.call_builtin_opcode(), 0u, 1u);
    code[29] = instructions.HaltOp(opcodes.halt_opcode(), 3);

    var functions: model.FunctionInfo[] = model.FunctionInfo[](1u);
