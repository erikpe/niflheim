fn build_obj_cast_builtin_program() -> model.Program {
    var code: model.Instruction[] = model.Instruction[](16u);
    code[0] = instructions.LoadConstOp(opcodes.load_const_opcode(), 0, 0u);
    code[1] = instructions.LoadConstOp(opcodes.load_const_opcode(), 1, 1u);
    code[2] = instructions.LoadConstOp(opcodes.load_const_opcode(), 2, 2u);
    code[3] = instructions.LoadConstOp(opcodes.load_const_opcode(), 3, 3u);
    code[4] = instructions.CallBuiltinOp(opcodes.call_builtin_opcode(), 1u, 4u);
    code[5] = instructions.RegisterCopyOp(opcodes.move_opcode(), 4, 0);
    code[6] = instructions.LoadConstOp(opcodes.load_const_opcode(), 0, 4u);
    code[7] = instructions.LoadConstOp(opcodes.load_const_opcode(), 1, 5u);
    code[8] = instructions.LoadConstOp(opcodes.load_const_opcode(), 2, 6u);
    code[9] = instructions.LoadConstOp(opcodes.load_const_opcode(), 3, 7u);
    code[10] = instructions.CallBuiltinOp(opcodes.call_builtin_opcode(), 2u, 4u);
    code[11] = instructions.AddOp(opcodes.add_opcode(), 5, 4, 0);
    code[12] = instructions.StoreMemOp(opcodes.store_mem_opcode(), 0, 5);
    code[13] = instructions.RegisterCopyOp(opcodes.move_opcode(), 0, 5);
