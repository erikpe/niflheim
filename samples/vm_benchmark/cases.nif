}

export fn build_cases() -> model.BenchmarkCase[] {
    var benchmark_cases: model.BenchmarkCase[] = model.BenchmarkCase[](6u);
    benchmark_cases[0] = build_minimal_case();
    benchmark_cases[1] = build_arithmetic_case();
    benchmark_cases[2] = build_branch_maze_case();
    benchmark_cases[3] = build_recursive_case();
    benchmark_cases[4] = build_dense_array_case();
    benchmark_cases[5] = build_slice_copy_case();
    return benchmark_cases;
}