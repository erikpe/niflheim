fn build_sha1_quick_brown_fox_case() -> model.BenchmarkCase {
    return model.BenchmarkCase(
        "sha1_quick_brown_fox",
        build_sha1_quick_brown_fox_program(),
        3446627857414826236,
        802480582,
        -1257569273529833621,
        10444962798,
        3933u,
        0u,
        326u,
        1u
    );
}

export fn build_cases() -> model.BenchmarkCase[] {
    var benchmark_cases: model.BenchmarkCase[] = model.BenchmarkCase[](12u);
    benchmark_cases[0] = build_minimal_case();
    benchmark_cases[1] = build_arithmetic_case();
    benchmark_cases[2] = build_branch_maze_case();
    benchmark_cases[3] = build_recursive_case();
    benchmark_cases[4] = build_dense_array_case();
    benchmark_cases[5] = build_slice_copy_case();
    benchmark_cases[6] = build_builtin_dispatch_case();
    benchmark_cases[7] = build_obj_cast_builtin_case();
    benchmark_cases[8] = build_exact_double_case();
    benchmark_cases[9] = build_prime_sum_100_case();
    benchmark_cases[10] = build_fibonacci_recursive_case();
    benchmark_cases[11] = build_sha1_quick_brown_fox_case();
    return benchmark_cases;
}
