fn build_slice_copy_case() -> model.BenchmarkCase {
    return model.BenchmarkCase(
        "slice_copy",
        build_slice_copy_program(),
        159,
        10,
        -5438759747882907306,
        159,
        91u,
        0u,
        12u,
        1u
