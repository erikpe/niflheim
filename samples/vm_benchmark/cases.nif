    constants[1] = BoxI64(11);
    constants[2] = BoxI64(12);
    constants[3] = BoxI64(13);
    constants[4] = BoxI64(2);
    constants[5] = BoxI64(9);
    constants[6] = BoxI64(2);
    constants[7] = BoxI64(14);
    constants[8] = BoxI64(0);
    constants[9] = BoxI64(0);
