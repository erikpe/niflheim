import std.box;
import samples.vm_benchmark.builtins;
import samples.vm_benchmark.instructions;
import samples.vm_benchmark.model;
import samples.vm_benchmark.opcodes;

fn build_minimal_program() -> model.Program {
    var code: model.Instruction[] = model.Instruction[](11u);
    code[0] = instructions.LoadConstOp(opcodes.load_const_opcode(), 0, 0u);
    code[1] = instructions.LoadConstOp(opcodes.load_const_opcode(), 1, 1u);
    code[2] = instructions.AddOp(opcodes.add_opcode(), 2, 0, 1);
    code[3] = instructions.StoreMemOp(opcodes.store_mem_opcode(), 0, 2);
    code[4] = instructions.LoadMemOp(opcodes.load_mem_opcode(), 0, 3);
    code[5] = instructions.LoadConstOp(opcodes.load_const_opcode(), 4, 2u);
    code[6] = instructions.AddOp(opcodes.add_opcode(), 5, 3, 4);
    code[7] = instructions.RegisterCopyOp(opcodes.move_opcode(), 0, 5);
    code[8] = instructions.CallBuiltinOp(opcodes.call_builtin_opcode(), 0u, 1u);
    code[9] = instructions.StoreMemOp(opcodes.store_mem_opcode(), 0, 5);
    code[10] = instructions.HaltOp(opcodes.halt_opcode(), 5);

    var functions: model.FunctionInfo[] = model.FunctionInfo[](1u);
    functions[0] = model.FunctionInfo("main", 0u, 6u, code);

    var constants: Obj[] = Obj[](3u);
    constants[0] = BoxI64(7);
    constants[1] = BoxI64(5);
    constants[2] = BoxI64(2);

    var builtin_table: model.Builtin[] = model.Builtin[](1u);
    builtin_table[0] = builtins.TraceAccumulatorBuiltin("trace_accumulate");

    return model.Program("slice1_minimal", 0u, functions, constants, builtin_table, 2u);
}

fn build_minimal_case() -> model.BenchmarkCase {
    return model.BenchmarkCase(
        "slice1_minimal",
        build_minimal_program(),
        14,
        14,
        434,
        14,
        11u,
        0u,
        0u,
        1u
    );
}

fn build_arithmetic_program() -> model.Program {
    var code: model.Instruction[] = model.Instruction[](26u);
    code[0] = instructions.LoadConstOp(opcodes.load_const_opcode(), 0, 0u);
    code[1] = instructions.LoadConstOp(opcodes.load_const_opcode(), 1, 1u);
    code[2] = instructions.LoadConstOp(opcodes.load_const_opcode(), 2, 2u);
    code[3] = instructions.LoadConstOp(opcodes.load_const_opcode(), 6, 3u);
    code[4] = instructions.LoadConstOp(opcodes.load_const_opcode(), 7, 4u);
    code[5] = instructions.LoadConstOp(opcodes.load_const_opcode(), 8, 5u);
    code[6] = instructions.LoadConstOp(opcodes.load_const_opcode(), 9, 6u);
    code[7] = instructions.LoadConstOp(opcodes.load_const_opcode(), 10, 7u);
    code[8] = instructions.CmpLtOp(opcodes.cmp_lt_opcode(), 3, 0, 1);
    code[9] = instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 3, 21u);
    code[10] = instructions.AddOp(opcodes.add_opcode(), 2, 2, 0);
    code[11] = instructions.MulOp(opcodes.mul_opcode(), 4, 2, 7);
    code[12] = instructions.SubOp(opcodes.sub_opcode(), 2, 4, 0);
    code[13] = instructions.DivOp(opcodes.div_opcode(), 4, 2, 8);
    code[14] = instructions.ModOp(opcodes.mod_opcode(), 5, 2, 9);
    code[15] = instructions.AddOp(opcodes.add_opcode(), 2, 4, 5);
    code[16] = instructions.CmpEqOp(opcodes.cmp_eq_opcode(), 3, 5, 10);
    code[17] = instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 3, 19u);
    code[18] = instructions.AddOp(opcodes.add_opcode(), 2, 2, 0);
    code[19] = instructions.AddOp(opcodes.add_opcode(), 0, 0, 6);
    code[20] = instructions.JumpOp(opcodes.jump_opcode(), 8u);
    code[21] = instructions.StoreMemOp(opcodes.store_mem_opcode(), 0, 2);
    code[22] = instructions.LoadMemOp(opcodes.load_mem_opcode(), 0, 4);
    code[23] = instructions.RegisterCopyOp(opcodes.move_opcode(), 0, 4);
    code[24] = instructions.CallBuiltinOp(opcodes.call_builtin_opcode(), 0u, 3u);
    code[25] = instructions.HaltOp(opcodes.halt_opcode(), 2);

    var functions: model.FunctionInfo[] = model.FunctionInfo[](1u);
    functions[0] = model.FunctionInfo("main", 0u, 11u, code);

    var constants: Obj[] = Obj[](8u);
    constants[0] = BoxI64(1);
    constants[1] = BoxI64(7);
    constants[2] = BoxI64(0);
    constants[3] = BoxI64(1);
    constants[4] = BoxI64(3);
    constants[5] = BoxI64(2);
    constants[6] = BoxI64(5);
    constants[7] = BoxI64(0);

    var builtin_table: model.Builtin[] = model.Builtin[](1u);
    builtin_table[0] = builtins.TraceAccumulatorBuiltin("trace_accumulate");

    return model.Program("arithmetic_mixer", 0u, functions, constants, builtin_table, 2u);
}

fn build_arithmetic_case() -> model.BenchmarkCase {
    return model.BenchmarkCase(
        "arithmetic_mixer",
        build_arithmetic_program(),
        102,
        102,
        3162,
        211,
        88u,
        0u,
        12u,
        1u
    );
}

fn build_branch_maze_program() -> model.Program {
