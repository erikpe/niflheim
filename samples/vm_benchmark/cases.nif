    code[11] = instructions.CmpEqOp(opcodes.cmp_eq_opcode(), 3, 5, 6);
    code[12] = instructions.JumpIfTrueOp(opcodes.jump_if_true_opcode(), 3, 15u);
    code[13] = instructions.RegisterCopyOp(opcodes.move_opcode(), 4, 10);
    code[14] = instructions.JumpOp(opcodes.jump_opcode(), 16u);
    code[15] = instructions.MulOp(opcodes.mul_opcode(), 4, 0, 9);
    code[16] = instructions.AddOp(opcodes.add_opcode(), 2, 2, 4);
    code[17] = instructions.ModOp(opcodes.mod_opcode(), 5, 0, 9);
    code[18] = instructions.CmpEqOp(opcodes.cmp_eq_opcode(), 3, 5, 7);
    code[19] = instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 3, 21u);
    code[20] = instructions.SubOp(opcodes.sub_opcode(), 2, 2, 7);
    code[21] = instructions.AddOp(opcodes.add_opcode(), 0, 0, 7);
    code[22] = instructions.JumpOp(opcodes.jump_opcode(), 8u);
    code[23] = instructions.StoreMemOp(opcodes.store_mem_opcode(), 0, 2);
    code[24] = instructions.RegisterCopyOp(opcodes.move_opcode(), 0, 2);
    code[25] = instructions.CallBuiltinOp(opcodes.call_builtin_opcode(), 0u, 2u);
    code[26] = instructions.HaltOp(opcodes.halt_opcode(), 2);

    var functions: model.FunctionInfo[] = model.FunctionInfo[](1u);
