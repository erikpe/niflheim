fn _emit_instruction(code: model.Instruction[], pc: i64, instruction: model.Instruction) -> i64 {
    code[pc] = instruction;
    return pc + 1;
}

fn build_sha1_quick_brown_fox_program() -> model.Program {
    var code: model.Instruction[] = model.Instruction[](512u);
    var pc: i64 = 0;

    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 0, 0u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 2, 1u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 3, 2u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 4, 3u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 5, 4u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 6, 5u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 7, 6u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 8, 7u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 9, 8u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 10, 9u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 11, 10u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 12, 11u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 13, 12u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 14, 13u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 20, 14u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 21, 15u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 22, 16u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 23, 17u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 24, 18u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 25, 19u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 26, 20u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 27, 21u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 28, 22u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 29, 23u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 30, 24u));
    pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 31, 25u));

    var word_const_index: i64 = 26;
    var word_slot: i64 = 0;
    while word_slot < 16 {
        pc = _emit_instruction(code, pc, instructions.LoadConstOp(opcodes.load_const_opcode(), 34, (u64)word_const_index));
        pc = _emit_instruction(code, pc, instructions.StoreMemOp(opcodes.store_mem_opcode(), word_slot, 34));
        word_const_index = word_const_index + 1;
        word_slot = word_slot + 1;
    }

    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 1, 8));

    var schedule_loop_start: i64 = pc;
    pc = _emit_instruction(code, pc, instructions.CmpLtOp(opcodes.cmp_lt_opcode(), 39, 1, 21));
    var schedule_exit_jump_pc: i64 = pc;
    pc = _emit_instruction(code, pc, instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 39, 0u));

    pc = _emit_instruction(code, pc, instructions.SubOp(opcodes.sub_opcode(), 35, 1, 4));
    pc = _emit_instruction(code, pc, instructions.LoadMemIndexedOp(opcodes.load_mem_indexed_opcode(), 35, 0, 35));
    pc = _emit_instruction(code, pc, instructions.SubOp(opcodes.sub_opcode(), 36, 1, 6));
    pc = _emit_instruction(code, pc, instructions.LoadMemIndexedOp(opcodes.load_mem_indexed_opcode(), 36, 0, 36));
    pc = _emit_instruction(code, pc, instructions.SubOp(opcodes.sub_opcode(), 37, 1, 7));
    pc = _emit_instruction(code, pc, instructions.LoadMemIndexedOp(opcodes.load_mem_indexed_opcode(), 37, 0, 37));
    pc = _emit_instruction(code, pc, instructions.SubOp(opcodes.sub_opcode(), 38, 1, 8));
    pc = _emit_instruction(code, pc, instructions.LoadMemIndexedOp(opcodes.load_mem_indexed_opcode(), 38, 0, 38));
    pc = _emit_instruction(code, pc, instructions.XorOp(opcodes.xor_opcode(), 35, 35, 36));
    pc = _emit_instruction(code, pc, instructions.XorOp(opcodes.xor_opcode(), 35, 35, 37));
    pc = _emit_instruction(code, pc, instructions.XorOp(opcodes.xor_opcode(), 35, 35, 38));
    pc = _emit_instruction(code, pc, instructions.ShlOp(opcodes.shl_opcode(), 36, 35, 2));
    pc = _emit_instruction(code, pc, instructions.AndOp(opcodes.and_opcode(), 36, 36, 22));
    pc = _emit_instruction(code, pc, instructions.ShrOp(opcodes.shr_opcode(), 37, 35, 12));
    pc = _emit_instruction(code, pc, instructions.OrOp(opcodes.or_opcode(), 35, 36, 37));
    pc = _emit_instruction(code, pc, instructions.StoreMemIndexedOp(opcodes.store_mem_indexed_opcode(), 35, 0, 1));
    pc = _emit_instruction(code, pc, instructions.AddOp(opcodes.add_opcode(), 1, 1, 2));
    pc = _emit_instruction(code, pc, instructions.JumpOp(opcodes.jump_opcode(), (u64)schedule_loop_start));
    code[schedule_exit_jump_pc] = instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 39, (u64)pc);

    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 15, 27));
    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 16, 28));
    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 17, 29));
    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 18, 30));
    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 19, 31));
    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 1, 0));

    var round_loop_start: i64 = pc;
    pc = _emit_instruction(code, pc, instructions.CmpLtOp(opcodes.cmp_lt_opcode(), 39, 1, 21));
    var round_exit_jump_pc: i64 = pc;
    pc = _emit_instruction(code, pc, instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 39, 0u));
    pc = _emit_instruction(code, pc, instructions.LoadMemIndexedOp(opcodes.load_mem_indexed_opcode(), 34, 0, 1));

    pc = _emit_instruction(code, pc, instructions.CmpLtOp(opcodes.cmp_lt_opcode(), 39, 1, 9));
    var choose_jump_pc: i64 = pc;
    pc = _emit_instruction(code, pc, instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 39, 0u));
    pc = _emit_instruction(code, pc, instructions.XorOp(opcodes.xor_opcode(), 35, 17, 18));
    pc = _emit_instruction(code, pc, instructions.AndOp(opcodes.and_opcode(), 35, 16, 35));
    pc = _emit_instruction(code, pc, instructions.XorOp(opcodes.xor_opcode(), 32, 18, 35));
    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 33, 23));
    var fn_done_after_choose_jump_pc: i64 = pc;
    pc = _emit_instruction(code, pc, instructions.JumpOp(opcodes.jump_opcode(), 0u));

    var parity_one_start: i64 = pc;
    code[choose_jump_pc] = instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 39, (u64)parity_one_start);
    pc = _emit_instruction(code, pc, instructions.CmpLtOp(opcodes.cmp_lt_opcode(), 39, 1, 14));
    var parity_one_jump_pc: i64 = pc;
    pc = _emit_instruction(code, pc, instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 39, 0u));
    pc = _emit_instruction(code, pc, instructions.XorOp(opcodes.xor_opcode(), 32, 16, 17));
    pc = _emit_instruction(code, pc, instructions.XorOp(opcodes.xor_opcode(), 32, 32, 18));
    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 33, 24));
    var fn_done_after_parity_one_jump_pc: i64 = pc;
    pc = _emit_instruction(code, pc, instructions.JumpOp(opcodes.jump_opcode(), 0u));

    var majority_start: i64 = pc;
    code[parity_one_jump_pc] = instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 39, (u64)majority_start);
    pc = _emit_instruction(code, pc, instructions.CmpLtOp(opcodes.cmp_lt_opcode(), 39, 1, 20));
    var majority_jump_pc: i64 = pc;
    pc = _emit_instruction(code, pc, instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 39, 0u));
    pc = _emit_instruction(code, pc, instructions.AndOp(opcodes.and_opcode(), 35, 16, 17));
    pc = _emit_instruction(code, pc, instructions.OrOp(opcodes.or_opcode(), 36, 16, 17));
    pc = _emit_instruction(code, pc, instructions.AndOp(opcodes.and_opcode(), 36, 18, 36));
    pc = _emit_instruction(code, pc, instructions.OrOp(opcodes.or_opcode(), 32, 35, 36));
    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 33, 25));
    var fn_done_after_majority_jump_pc: i64 = pc;
    pc = _emit_instruction(code, pc, instructions.JumpOp(opcodes.jump_opcode(), 0u));

    var parity_two_start: i64 = pc;
    code[majority_jump_pc] = instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 39, (u64)parity_two_start);
    pc = _emit_instruction(code, pc, instructions.XorOp(opcodes.xor_opcode(), 32, 16, 17));
    pc = _emit_instruction(code, pc, instructions.XorOp(opcodes.xor_opcode(), 32, 32, 18));
    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 33, 26));

    var fn_done_start: i64 = pc;
    code[fn_done_after_choose_jump_pc] = instructions.JumpOp(opcodes.jump_opcode(), (u64)fn_done_start);
    code[fn_done_after_parity_one_jump_pc] = instructions.JumpOp(opcodes.jump_opcode(), (u64)fn_done_start);
    code[fn_done_after_majority_jump_pc] = instructions.JumpOp(opcodes.jump_opcode(), (u64)fn_done_start);

    pc = _emit_instruction(code, pc, instructions.ShlOp(opcodes.shl_opcode(), 35, 15, 5));
    pc = _emit_instruction(code, pc, instructions.AndOp(opcodes.and_opcode(), 35, 35, 22));
    pc = _emit_instruction(code, pc, instructions.ShrOp(opcodes.shr_opcode(), 36, 15, 10));
    pc = _emit_instruction(code, pc, instructions.OrOp(opcodes.or_opcode(), 35, 35, 36));
    pc = _emit_instruction(code, pc, instructions.AddOp(opcodes.add_opcode(), 35, 35, 32));
    pc = _emit_instruction(code, pc, instructions.AddOp(opcodes.add_opcode(), 35, 35, 19));
    pc = _emit_instruction(code, pc, instructions.AddOp(opcodes.add_opcode(), 35, 35, 33));
    pc = _emit_instruction(code, pc, instructions.AddOp(opcodes.add_opcode(), 35, 35, 34));
    pc = _emit_instruction(code, pc, instructions.AndOp(opcodes.and_opcode(), 35, 35, 22));

    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 19, 18));
    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 18, 17));
    pc = _emit_instruction(code, pc, instructions.ShlOp(opcodes.shl_opcode(), 36, 16, 11));
    pc = _emit_instruction(code, pc, instructions.AndOp(opcodes.and_opcode(), 36, 36, 22));
    pc = _emit_instruction(code, pc, instructions.ShrOp(opcodes.shr_opcode(), 37, 16, 3));
    pc = _emit_instruction(code, pc, instructions.OrOp(opcodes.or_opcode(), 17, 36, 37));
    pc = _emit_instruction(code, pc, instructions.AndOp(opcodes.and_opcode(), 17, 17, 22));
    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 16, 15));
    pc = _emit_instruction(code, pc, instructions.RegisterCopyOp(opcodes.move_opcode(), 15, 35));
    pc = _emit_instruction(code, pc, instructions.AddOp(opcodes.add_opcode(), 1, 1, 2));
    pc = _emit_instruction(code, pc, instructions.JumpOp(opcodes.jump_opcode(), (u64)round_loop_start));
    code[round_exit_jump_pc] = instructions.JumpIfFalseOp(opcodes.jump_if_false_opcode(), 39, (u64)pc);

    pc = _emit_instruction(code, pc, instructions.AddOp(opcodes.add_opcode(), 27, 27, 15));
    pc = _emit_instruction(code, pc, instructions.AndOp(opcodes.and_opcode(), 27, 27, 22));
    pc = _emit_instruction(code, pc, instructions.AddOp(opcodes.add_opcode(), 28, 28, 16));
    pc = _emit_instruction(code, pc, instructions.AndOp(opcodes.and_opcode(), 28, 28, 22));
    pc = _emit_instruction(code, pc, instructions.AddOp(opcodes.add_opcode(), 29, 29, 17));
    pc = _emit_instruction(code, pc, instructions.AndOp(opcodes.and_opcode(), 29, 29, 22));
    pc = _emit_instruction(code, pc, instructions.AddOp(opcodes.add_opcode(), 30, 30, 18));
    pc = _emit_instruction(code, pc, instructions.AndOp(opcodes.and_opcode(), 30, 30, 22));
    pc = _emit_instruction(code, pc, instructions.AddOp(opcodes.add_opcode(), 31, 31, 19));
    pc = _emit_instruction(code, pc, instructions.AndOp(opcodes.and_opcode(), 31, 31, 22));

    pc = _emit_instruction(code, pc, instructions.StoreMemOp(opcodes.store_mem_opcode(), 0, 27));
    pc = _emit_instruction(code, pc, instructions.StoreMemOp(opcodes.store_mem_opcode(), 1, 28));
