fn build_recursive_program() -> model.Program {
    var main_code: model.Instruction[] = model.Instruction[](6u);
    main_code[0] = instructions.LoadConstOp(opcodes.load_const_opcode(), 0, 0u);
    main_code[1] = instructions.CallOp(opcodes.call_opcode(), 1u, 1u, 1);
    main_code[2] = instructions.StoreMemOp(opcodes.store_mem_opcode(), 0, 1);
    main_code[3] = instructions.RegisterCopyOp(opcodes.move_opcode(), 0, 1);
    main_code[4] = instructions.CallBuiltinOp(opcodes.call_builtin_opcode(), 0u, 1u);
    main_code[5] = instructions.HaltOp(opcodes.halt_opcode(), 1);

    var fib_full: model.Instruction[] = model.Instruction[](12u);
    fib_full[0] = instructions.LoadConstOp(opcodes.load_const_opcode(), 1, 1u);
    fib_full[1] = instructions.LoadConstOp(opcodes.load_const_opcode(), 2, 2u);
    fib_full[2] = instructions.CmpLtOp(opcodes.cmp_lt_opcode(), 3, 0, 2);
    fib_full[3] = instructions.JumpIfTrueOp(opcodes.jump_if_true_opcode(), 3, 11u);
    fib_full[4] = instructions.RegisterCopyOp(opcodes.move_opcode(), 4, 0);
    fib_full[5] = instructions.SubOp(opcodes.sub_opcode(), 0, 0, 1);
    fib_full[6] = instructions.CallOp(opcodes.call_opcode(), 1u, 1u, 5);
    fib_full[7] = instructions.SubOp(opcodes.sub_opcode(), 0, 4, 2);
    fib_full[8] = instructions.CallOp(opcodes.call_opcode(), 1u, 1u, 6);
    fib_full[9] = instructions.AddOp(opcodes.add_opcode(), 7, 5, 6);
    fib_full[10] = instructions.RetOp(opcodes.ret_opcode(), 7);
    fib_full[11] = instructions.RetOp(opcodes.ret_opcode(), 0);

    var functions: model.FunctionInfo[] = model.FunctionInfo[](2u);
    functions[0] = model.FunctionInfo("main", 0u, 2u, main_code);
    functions[1] = model.FunctionInfo("fib", 1u, 8u, fib_full);

    var constants: Obj[] = Obj[](3u);
    constants[0] = BoxI64(7);
    constants[1] = BoxI64(1);
    constants[2] = BoxI64(2);

    var builtin_table: model.Builtin[] = model.Builtin[](1u);
    builtin_table[0] = builtins.TraceAccumulatorBuiltin("trace_accumulate");

    return model.Program("recursive_calls", 0u, functions, constants, builtin_table, 2u);
}

fn build_recursive_case() -> model.BenchmarkCase {
    return model.BenchmarkCase(
        "recursive_calls",
        build_recursive_program(),
        13,
        13,
        403,
        13,
        331u,
        41u,
        21u,
        1u
    );
}

fn build_dense_array_program() -> model.Program {
