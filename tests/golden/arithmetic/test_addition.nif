import std.io;
import std.str;
import std.test;

fn test_i64(input: Str[]) -> unit {
    var i64_min: i64 = -9223372036854775808;
    var i64_max: i64 = 9223372036854775807;
    var i64_zero: i64 = 0;
    var i64_one: i64 = 1;
    var i64_neg1: i64 = -1;
    var i64_mid: i64 = 123456789;

    var i64_min_arg: i64 = input[0].to_i64();
    var i64_max_arg: i64 = input[1].to_i64();
    var i64_zero_arg: i64 = input[2].to_i64();
    var i64_one_arg: i64 = input[3].to_i64();
    var i64_neg1_arg: i64 = input[4].to_i64();
    var i64_mid_arg: i64 = input[5].to_i64();

    assert_eq_i64(i64_min + i64_min, 0);
    assert_eq_i64(i64_min + i64_max, -1);
    assert_eq_i64(i64_min + i64_zero, -9223372036854775808);
    assert_eq_i64(i64_min + i64_one, -9223372036854775807);
    assert_eq_i64(i64_min + i64_neg1, 9223372036854775807);
    assert_eq_i64(i64_min + i64_mid, -9223372036731319019);

    assert_eq_i64(i64_max + i64_min, -1);
    assert_eq_i64(i64_max + i64_max, -2);
    assert_eq_i64(i64_max + i64_zero, 9223372036854775807);
    assert_eq_i64(i64_max + i64_one, -9223372036854775808);
    assert_eq_i64(i64_max + i64_neg1, 9223372036854775806);
    assert_eq_i64(i64_max + i64_mid, -9223372036731319020);

    assert_eq_i64(i64_zero + i64_min, -9223372036854775808);
    assert_eq_i64(i64_zero + i64_max, 9223372036854775807);
    assert_eq_i64(i64_zero + i64_zero, 0);
    assert_eq_i64(i64_zero + i64_one, 1);
    assert_eq_i64(i64_zero + i64_neg1, -1);
    assert_eq_i64(i64_zero + i64_mid, 123456789);

    assert_eq_i64(i64_one + i64_min, -9223372036854775807);
    assert_eq_i64(i64_one + i64_max, -9223372036854775808);
    assert_eq_i64(i64_one + i64_zero, 1);
    assert_eq_i64(i64_one + i64_one, 2);
    assert_eq_i64(i64_one + i64_neg1, 0);
    assert_eq_i64(i64_one + i64_mid, 123456790);

    assert_eq_i64(i64_neg1 + i64_min, 9223372036854775807);
    assert_eq_i64(i64_neg1 + i64_max, 9223372036854775806);
    assert_eq_i64(i64_neg1 + i64_zero, -1);
    assert_eq_i64(i64_neg1 + i64_one, 0);
    assert_eq_i64(i64_neg1 + i64_neg1, -2);
    assert_eq_i64(i64_neg1 + i64_mid, 123456788);

    assert_eq_i64(i64_mid + i64_min, -9223372036731319019);
    assert_eq_i64(i64_mid + i64_max, -9223372036731319020);
    assert_eq_i64(i64_mid + i64_zero, 123456789);
    assert_eq_i64(i64_mid + i64_one, 123456790);
    assert_eq_i64(i64_mid + i64_neg1, 123456788);
    assert_eq_i64(i64_mid + i64_mid, 246913578);

    assert_eq_i64(i64_min_arg + i64_min_arg, 0);
    assert_eq_i64(i64_min_arg + i64_max_arg, -1);
    assert_eq_i64(i64_min_arg + i64_zero_arg, -9223372036854775808);
    assert_eq_i64(i64_min_arg + i64_one_arg, -9223372036854775807);
    assert_eq_i64(i64_min_arg + i64_neg1_arg, 9223372036854775807);
    assert_eq_i64(i64_min_arg + i64_mid_arg, -9223372036731319019);

    assert_eq_i64(i64_max_arg + i64_min_arg, -1);
    assert_eq_i64(i64_max_arg + i64_max_arg, -2);
    assert_eq_i64(i64_max_arg + i64_zero_arg, 9223372036854775807);
    assert_eq_i64(i64_max_arg + i64_one_arg, -9223372036854775808);
    assert_eq_i64(i64_max_arg + i64_neg1_arg, 9223372036854775806);
    assert_eq_i64(i64_max_arg + i64_mid_arg, -9223372036731319020);

    assert_eq_i64(i64_zero_arg + i64_min_arg, -9223372036854775808);
    assert_eq_i64(i64_zero_arg + i64_max_arg, 9223372036854775807);
    assert_eq_i64(i64_zero_arg + i64_zero_arg, 0);
    assert_eq_i64(i64_zero_arg + i64_one_arg, 1);
    assert_eq_i64(i64_zero_arg + i64_neg1_arg, -1);
    assert_eq_i64(i64_zero_arg + i64_mid_arg, 123456789);

    assert_eq_i64(i64_one_arg + i64_min_arg, -9223372036854775807);
    assert_eq_i64(i64_one_arg + i64_max_arg, -9223372036854775808);
    assert_eq_i64(i64_one_arg + i64_zero_arg, 1);
    assert_eq_i64(i64_one_arg + i64_one_arg, 2);
    assert_eq_i64(i64_one_arg + i64_neg1_arg, 0);
    assert_eq_i64(i64_one_arg + i64_mid_arg, 123456790);

    assert_eq_i64(i64_neg1_arg + i64_min_arg, 9223372036854775807);
    assert_eq_i64(i64_neg1_arg + i64_max_arg, 9223372036854775806);
    assert_eq_i64(i64_neg1_arg + i64_zero_arg, -1);
    assert_eq_i64(i64_neg1_arg + i64_one_arg, 0);
    assert_eq_i64(i64_neg1_arg + i64_neg1_arg, -2);
    assert_eq_i64(i64_neg1_arg + i64_mid_arg, 123456788);

    assert_eq_i64(i64_mid_arg + i64_min_arg, -9223372036731319019);
    assert_eq_i64(i64_mid_arg + i64_max_arg, -9223372036731319020);
    assert_eq_i64(i64_mid_arg + i64_zero_arg, 123456789);
    assert_eq_i64(i64_mid_arg + i64_one_arg, 123456790);
    assert_eq_i64(i64_mid_arg + i64_neg1_arg, 123456788);
    assert_eq_i64(i64_mid_arg + i64_mid_arg, 246913578);
}

fn test_u64(input: Str[]) -> unit {
    var u64_zero: u64 = 0u;
    var u64_one: u64 = 1u;
    var u64_max: u64 = 18446744073709551615u;
    var u64_mid: u64 = 1000000000u;
    var u64_big: u64 = 4000000000000000000u;

    var u64_zero_arg: u64 = input[0].to_u64();
    var u64_one_arg: u64 = input[1].to_u64();
    var u64_max_arg: u64 = input[2].to_u64();
    var u64_mid_arg: u64 = input[3].to_u64();
    var u64_big_arg: u64 = input[4].to_u64();

    assert_eq_u64(u64_zero + u64_zero, 0u);
    assert_eq_u64(u64_zero + u64_one, 1u);
    assert_eq_u64(u64_zero + u64_max, 18446744073709551615u);
    assert_eq_u64(u64_zero + u64_mid, 1000000000u);
    assert_eq_u64(u64_zero + u64_big, 4000000000000000000u);

    assert_eq_u64(u64_one + u64_zero, 1u);
    assert_eq_u64(u64_one + u64_one, 2u);
    assert_eq_u64(u64_one + u64_max, 0u);
    assert_eq_u64(u64_one + u64_mid, 1000000001u);
    assert_eq_u64(u64_one + u64_big, 4000000000000000001u);

    assert_eq_u64(u64_max + u64_zero, 18446744073709551615u);
    assert_eq_u64(u64_max + u64_one, 0u);
    assert_eq_u64(u64_max + u64_max, 18446744073709551614u);
    assert_eq_u64(u64_max + u64_mid, 999999999u);
    assert_eq_u64(u64_max + u64_big, 3999999999999999999u);

    assert_eq_u64(u64_mid + u64_zero, 1000000000u);
    assert_eq_u64(u64_mid + u64_one, 1000000001u);
    assert_eq_u64(u64_mid + u64_max, 999999999u);
    assert_eq_u64(u64_mid + u64_mid, 2000000000u);
    assert_eq_u64(u64_mid + u64_big, 4000000001000000000u);

    assert_eq_u64(u64_big + u64_zero, 4000000000000000000u);
    assert_eq_u64(u64_big + u64_one, 4000000000000000001u);
    assert_eq_u64(u64_big + u64_max, 3999999999999999999u);
    assert_eq_u64(u64_big + u64_mid, 4000000001000000000u);
    assert_eq_u64(u64_big + u64_big, 8000000000000000000u);

    assert_eq_u64(u64_zero_arg + u64_zero_arg, 0u);
    assert_eq_u64(u64_zero_arg + u64_one_arg, 1u);
    assert_eq_u64(u64_zero_arg + u64_max_arg, 18446744073709551615u);
    assert_eq_u64(u64_zero_arg + u64_mid_arg, 1000000000u);
    assert_eq_u64(u64_zero_arg + u64_big_arg, 4000000000000000000u);

    assert_eq_u64(u64_one_arg + u64_zero_arg, 1u);
    assert_eq_u64(u64_one_arg + u64_one_arg, 2u);
    assert_eq_u64(u64_one_arg + u64_max_arg, 0u);
    assert_eq_u64(u64_one_arg + u64_mid_arg, 1000000001u);
    assert_eq_u64(u64_one_arg + u64_big_arg, 4000000000000000001u);

    assert_eq_u64(u64_max_arg + u64_zero_arg, 18446744073709551615u);
    assert_eq_u64(u64_max_arg + u64_one_arg, 0u);
    assert_eq_u64(u64_max_arg + u64_max_arg, 18446744073709551614u);
    assert_eq_u64(u64_max_arg + u64_mid_arg, 999999999u);
    assert_eq_u64(u64_max_arg + u64_big_arg, 3999999999999999999u);

    assert_eq_u64(u64_mid_arg + u64_zero_arg, 1000000000u);
    assert_eq_u64(u64_mid_arg + u64_one_arg, 1000000001u);
    assert_eq_u64(u64_mid_arg + u64_max_arg, 999999999u);
    assert_eq_u64(u64_mid_arg + u64_mid_arg, 2000000000u);
    assert_eq_u64(u64_mid_arg + u64_big_arg, 4000000001000000000u);

    assert_eq_u64(u64_big_arg + u64_zero_arg, 4000000000000000000u);
    assert_eq_u64(u64_big_arg + u64_one_arg, 4000000000000000001u);
    assert_eq_u64(u64_big_arg + u64_max_arg, 3999999999999999999u);
    assert_eq_u64(u64_big_arg + u64_mid_arg, 4000000001000000000u);
    assert_eq_u64(u64_big_arg + u64_big_arg, 8000000000000000000u);
}

fn test_u8(input: Str[]) -> unit {
    var u8_zero: u8 = 0u8;
    var u8_one: u8 = 1u8;
    var u8_max: u8 = 255u8;
    var u8_mid: u8 = 17u8;
    var u8_big: u8 = 200u8;

    var u8_zero_arg: u8 = (u8)input[0].to_u64();
    var u8_one_arg: u8 = (u8)input[1].to_u64();
    var u8_max_arg: u8 = (u8)input[2].to_u64();
    var u8_mid_arg: u8 = (u8)input[3].to_u64();
    var u8_big_arg: u8 = (u8)input[4].to_u64();

    assert_eq_u8(u8_zero + u8_zero, 0u8);
    assert_eq_u8(u8_zero + u8_one, 1u8);
    assert_eq_u8(u8_zero + u8_max, 255u8);
    assert_eq_u8(u8_zero + u8_mid, 17u8);
    assert_eq_u8(u8_zero + u8_big, 200u8);

    assert_eq_u8(u8_one + u8_zero, 1u8);
    assert_eq_u8(u8_one + u8_one, 2u8);
    assert_eq_u8(u8_one + u8_max, 0u8);
    assert_eq_u8(u8_one + u8_mid, 18u8);
    assert_eq_u8(u8_one + u8_big, 201u8);

    assert_eq_u8(u8_max + u8_zero, 255u8);
    assert_eq_u8(u8_max + u8_one, 0u8);
    assert_eq_u8(u8_max + u8_max, 254u8);
    assert_eq_u8(u8_max + u8_mid, 16u8);
    assert_eq_u8(u8_max + u8_big, 199u8);

    assert_eq_u8(u8_mid + u8_zero, 17u8);
    assert_eq_u8(u8_mid + u8_one, 18u8);
    assert_eq_u8(u8_mid + u8_max, 16u8);
    assert_eq_u8(u8_mid + u8_mid, 34u8);
    assert_eq_u8(u8_mid + u8_big, 217u8);

    assert_eq_u8(u8_big + u8_zero, 200u8);
    assert_eq_u8(u8_big + u8_one, 201u8);
    assert_eq_u8(u8_big + u8_max, 199u8);
    assert_eq_u8(u8_big + u8_mid, 217u8);
    assert_eq_u8(u8_big + u8_big, 144u8);

    assert_eq_u64((u64)(u8_big + u8_big), 144u);
    assert_eq_u64((u64)(u8_max + u8_one), 0u);
    assert_eq_u64((u64)(u8_mid + u8_max), 16u);

    assert_eq_u8(u8_zero_arg + u8_zero_arg, 0u8);
    assert_eq_u8(u8_zero_arg + u8_one_arg, 1u8);
    assert_eq_u8(u8_zero_arg + u8_max_arg, 255u8);
    assert_eq_u8(u8_zero_arg + u8_mid_arg, 17u8);
    assert_eq_u8(u8_zero_arg + u8_big_arg, 200u8);

    assert_eq_u8(u8_one_arg + u8_zero_arg, 1u8);
    assert_eq_u8(u8_one_arg + u8_one_arg, 2u8);
    assert_eq_u8(u8_one_arg + u8_max_arg, 0u8);
    assert_eq_u8(u8_one_arg + u8_mid_arg, 18u8);
    assert_eq_u8(u8_one_arg + u8_big_arg, 201u8);

    assert_eq_u8(u8_max_arg + u8_zero_arg, 255u8);
    assert_eq_u8(u8_max_arg + u8_one_arg, 0u8);
    assert_eq_u8(u8_max_arg + u8_max_arg, 254u8);
    assert_eq_u8(u8_max_arg + u8_mid_arg, 16u8);
    assert_eq_u8(u8_max_arg + u8_big_arg, 199u8);

    assert_eq_u8(u8_mid_arg + u8_zero_arg, 17u8);
    assert_eq_u8(u8_mid_arg + u8_one_arg, 18u8);
    assert_eq_u8(u8_mid_arg + u8_max_arg, 16u8);
    assert_eq_u8(u8_mid_arg + u8_mid_arg, 34u8);
    assert_eq_u8(u8_mid_arg + u8_big_arg, 217u8);

    assert_eq_u8(u8_big_arg + u8_zero_arg, 200u8);
    assert_eq_u8(u8_big_arg + u8_one_arg, 201u8);
    assert_eq_u8(u8_big_arg + u8_max_arg, 199u8);
    assert_eq_u8(u8_big_arg + u8_mid_arg, 217u8);
    assert_eq_u8(u8_big_arg + u8_big_arg, 144u8);

    assert_eq_u64((u64)(u8_big_arg + u8_big_arg), 144u);
    assert_eq_u64((u64)(u8_max_arg + u8_one_arg), 0u);
    assert_eq_u64((u64)(u8_mid_arg + u8_max_arg), 16u);
}

fn test_double(input: Str[]) -> unit {
    var d_neg: double = -1.5;
    var d_zero: double = 0.0;
    var d_one: double = 1.0;
    var d_big: double = 1000000.25;
    var d_small: double = 0.75;

    var d_neg_arg: double = input[0].to_double();
    var d_zero_arg: double = input[1].to_double();
    var d_one_arg: double = input[2].to_double();
    var d_big_arg: double = input[3].to_double();
    var d_small_arg: double = input[4].to_double();

    assert_eq_double(d_neg + d_neg, -3.0);
    assert_eq_double(d_neg + d_zero, -1.5);
    assert_eq_double(d_neg + d_one, -0.5);
    assert_eq_double(d_neg + d_big, 999998.75);
    assert_eq_double(d_neg + d_small, -0.75);

    assert_eq_double(d_zero + d_neg, -1.5);
    assert_eq_double(d_zero + d_zero, 0.0);
    assert_eq_double(d_zero + d_one, 1.0);
    assert_eq_double(d_zero + d_big, 1000000.25);
    assert_eq_double(d_zero + d_small, 0.75);

    assert_eq_double(d_one + d_neg, -0.5);
    assert_eq_double(d_one + d_zero, 1.0);
    assert_eq_double(d_one + d_one, 2.0);
    assert_eq_double(d_one + d_big, 1000001.25);
    assert_eq_double(d_one + d_small, 1.75);

    assert_eq_double(d_big + d_neg, 999998.75);
    assert_eq_double(d_big + d_zero, 1000000.25);
    assert_eq_double(d_big + d_one, 1000001.25);
    assert_eq_double(d_big + d_big, 2000000.5);
    assert_eq_double(d_big + d_small, 1000001.0);

    assert_eq_double(d_small + d_neg, -0.75);
    assert_eq_double(d_small + d_zero, 0.75);
    assert_eq_double(d_small + d_one, 1.75);
    assert_eq_double(d_small + d_big, 1000001.0);
    assert_eq_double(d_small + d_small, 1.5);

    assert_eq_double(d_neg_arg + d_neg_arg, -3.0);
    assert_eq_double(d_neg_arg + d_zero_arg, -1.5);
    assert_eq_double(d_neg_arg + d_one_arg, -0.5);
    assert_eq_double(d_neg_arg + d_big_arg, 999998.75);
    assert_eq_double(d_neg_arg + d_small_arg, -0.75);

    assert_eq_double(d_zero_arg + d_neg_arg, -1.5);
    assert_eq_double(d_zero_arg + d_zero_arg, 0.0);
    assert_eq_double(d_zero_arg + d_one_arg, 1.0);
    assert_eq_double(d_zero_arg + d_big_arg, 1000000.25);
    assert_eq_double(d_zero_arg + d_small_arg, 0.75);

    assert_eq_double(d_one_arg + d_neg_arg, -0.5);
    assert_eq_double(d_one_arg + d_zero_arg, 1.0);
    assert_eq_double(d_one_arg + d_one_arg, 2.0);
    assert_eq_double(d_one_arg + d_big_arg, 1000001.25);
    assert_eq_double(d_one_arg + d_small_arg, 1.75);

    assert_eq_double(d_big_arg + d_neg_arg, 999998.75);
    assert_eq_double(d_big_arg + d_zero_arg, 1000000.25);
    assert_eq_double(d_big_arg + d_one_arg, 1000001.25);
    assert_eq_double(d_big_arg + d_big_arg, 2000000.5);
    assert_eq_double(d_big_arg + d_small_arg, 1000001.0);

    assert_eq_double(d_small_arg + d_neg_arg, -0.75);
    assert_eq_double(d_small_arg + d_zero_arg, 0.75);
    assert_eq_double(d_small_arg + d_one_arg, 1.75);
    assert_eq_double(d_small_arg + d_big_arg, 1000001.0);
    assert_eq_double(d_small_arg + d_small_arg, 1.5);
}

fn main() -> i64 {
    var args: Str[] = read_program_args();
    var select: u64 = args[1].to_u64();

    if select == 1u { test_i64(args[2:]); return 0; }
    if select == 2u { test_u64(args[2:]); return 0; }
    if select == 3u { test_u8(args[2:]); return 0; }
    if select == 4u { test_double(args[2:]); return 0; }

    return 99;
}
