import std.io;
import std.str;
import std.test;

fn test_i64_literals() -> unit {
    assert_false(-9223372036854775808 == 9223372036854775807);
    assert_true(-9223372036854775808 != 9223372036854775807);
    assert_true(-9223372036854775808 <= 9223372036854775807);
    assert_false(-9223372036854775808 >= 9223372036854775807);
    assert_true(-9223372036854775808 < 9223372036854775807);
    assert_false(-9223372036854775808 > 9223372036854775807);

    assert_true(-1 == -1);
    assert_false(-1 != -1);
    assert_true(-1 <= -1);
    assert_true(-1 >= -1);
    assert_false(-1 < -1);
    assert_false(-1 > -1);

    assert_false(9223372036854775807 == -9223372036854775808);
    assert_true(9223372036854775807 != -9223372036854775808);
    assert_false(9223372036854775807 <= -9223372036854775808);
    assert_true(9223372036854775807 >= -9223372036854775808);
    assert_false(9223372036854775807 < -9223372036854775808);
    assert_true(9223372036854775807 > -9223372036854775808);
}

fn test_i64_constants() -> unit {
    var min: i64 = -9223372036854775808;
    var max: i64 = 9223372036854775807;
    var neg_one_a: i64 = -1;
    var neg_one_b: i64 = -1;

    assert_false(min == max);
    assert_true(min != max);
    assert_true(min <= max);
    assert_false(min >= max);
    assert_true(min < max);
    assert_false(min > max);

    assert_true(neg_one_a == neg_one_b);
    assert_false(neg_one_a != neg_one_b);
    assert_true(neg_one_a <= neg_one_b);
    assert_true(neg_one_a >= neg_one_b);
    assert_false(neg_one_a < neg_one_b);
    assert_false(neg_one_a > neg_one_b);

    assert_false(max == min);
    assert_true(max != min);
    assert_false(max <= min);
    assert_true(max >= min);
    assert_false(max < min);
    assert_true(max > min);
}

fn test_i64_args(input: Str[]) -> unit {
    var less_left: i64 = input[0].to_i64();
    var less_right: i64 = input[1].to_i64();
    var equal_left: i64 = input[2].to_i64();
    var equal_right: i64 = input[3].to_i64();
    var greater_left: i64 = input[4].to_i64();
    var greater_right: i64 = input[5].to_i64();

    assert_false(less_left == less_right);
    assert_true(less_left != less_right);
    assert_true(less_left <= less_right);
    assert_false(less_left >= less_right);
    assert_true(less_left < less_right);
    assert_false(less_left > less_right);

    assert_true(equal_left == equal_right);
    assert_false(equal_left != equal_right);
    assert_true(equal_left <= equal_right);
    assert_true(equal_left >= equal_right);
    assert_false(equal_left < equal_right);
    assert_false(equal_left > equal_right);

    assert_false(greater_left == greater_right);
    assert_true(greater_left != greater_right);
    assert_false(greater_left <= greater_right);
    assert_true(greater_left >= greater_right);
    assert_false(greater_left < greater_right);
    assert_true(greater_left > greater_right);
}

fn test_u64_literals() -> unit {
    assert_false(0u == 18446744073709551615u);
    assert_true(0u != 18446744073709551615u);
    assert_true(0u <= 18446744073709551615u);
    assert_false(0u >= 18446744073709551615u);
    assert_true(0u < 18446744073709551615u);
    assert_false(0u > 18446744073709551615u);

    assert_true(9223372036854775808u == 9223372036854775808u);
    assert_false(9223372036854775808u != 9223372036854775808u);
    assert_true(9223372036854775808u <= 9223372036854775808u);
    assert_true(9223372036854775808u >= 9223372036854775808u);
    assert_false(9223372036854775808u < 9223372036854775808u);
    assert_false(9223372036854775808u > 9223372036854775808u);

    assert_false(18446744073709551615u == 0u);
    assert_true(18446744073709551615u != 0u);
    assert_false(18446744073709551615u <= 0u);
    assert_true(18446744073709551615u >= 0u);
    assert_false(18446744073709551615u < 0u);
    assert_true(18446744073709551615u > 0u);
}

fn test_u64_constants() -> unit {
    var zero: u64 = 0u;
    var high_a: u64 = 9223372036854775808u;
    var high_b: u64 = 9223372036854775808u;
    var max: u64 = 18446744073709551615u;

    assert_false(zero == max);
    assert_true(zero != max);
    assert_true(zero <= max);
    assert_false(zero >= max);
    assert_true(zero < max);
    assert_false(zero > max);

    assert_true(high_a == high_b);
    assert_false(high_a != high_b);
    assert_true(high_a <= high_b);
    assert_true(high_a >= high_b);
    assert_false(high_a < high_b);
    assert_false(high_a > high_b);

    assert_false(max == zero);
    assert_true(max != zero);
    assert_false(max <= zero);
    assert_true(max >= zero);
    assert_false(max < zero);
    assert_true(max > zero);
}

fn test_u64_args(input: Str[]) -> unit {
    var less_left: u64 = input[0].to_u64();
    var less_right: u64 = input[1].to_u64();
    var equal_left: u64 = input[2].to_u64();
    var equal_right: u64 = input[3].to_u64();
