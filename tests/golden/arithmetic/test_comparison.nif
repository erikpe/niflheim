}

fn test_u8_literals() -> unit {
    assert_false(0u8 == 255u8);
    assert_true(0u8 != 255u8);
    assert_true(0u8 <= 255u8);
    assert_false(0u8 >= 255u8);
    assert_true(0u8 < 255u8);
    assert_false(0u8 > 255u8);

    assert_true(17u8 == 17u8);
    assert_false(17u8 != 17u8);
    assert_true(17u8 <= 17u8);
    assert_true(17u8 >= 17u8);
    assert_false(17u8 < 17u8);
    assert_false(17u8 > 17u8);

    assert_false(255u8 == 0u8);
    assert_true(255u8 != 0u8);
    assert_false(255u8 <= 0u8);
    assert_true(255u8 >= 0u8);
    assert_false(255u8 < 0u8);
    assert_true(255u8 > 0u8);
}

fn test_u8_constants() -> unit {
    var zero: u8 = 0u8;
    var seventeen_a: u8 = 17u8;
    var seventeen_b: u8 = 17u8;
    var max: u8 = 255u8;

    assert_false(zero == max);
    assert_true(zero != max);
    assert_true(zero <= max);
    assert_false(zero >= max);
    assert_true(zero < max);
    assert_false(zero > max);

    assert_true(seventeen_a == seventeen_b);
    assert_false(seventeen_a != seventeen_b);
    assert_true(seventeen_a <= seventeen_b);
    assert_true(seventeen_a >= seventeen_b);
    assert_false(seventeen_a < seventeen_b);
    assert_false(seventeen_a > seventeen_b);

    assert_false(max == zero);
    assert_true(max != zero);
    assert_false(max <= zero);
    assert_true(max >= zero);
    assert_false(max < zero);
    assert_true(max > zero);
}

fn test_u8_args(input: Str[]) -> unit {
    var less_left: u8 = (u8)input[0].to_u64();
    var less_right: u8 = (u8)input[1].to_u64();
    var equal_left: u8 = (u8)input[2].to_u64();
    var equal_right: u8 = (u8)input[3].to_u64();
    var greater_left: u8 = (u8)input[4].to_u64();
    var greater_right: u8 = (u8)input[5].to_u64();

    assert_false(less_left == less_right);
    assert_true(less_left != less_right);
    assert_true(less_left <= less_right);
    assert_false(less_left >= less_right);
    assert_true(less_left < less_right);
    assert_false(less_left > less_right);

    assert_true(equal_left == equal_right);
    assert_false(equal_left != equal_right);
    assert_true(equal_left <= equal_right);
    assert_true(equal_left >= equal_right);
    assert_false(equal_left < equal_right);
    assert_false(equal_left > equal_right);

    assert_false(greater_left == greater_right);
    assert_true(greater_left != greater_right);
    assert_false(greater_left <= greater_right);
    assert_true(greater_left >= greater_right);
    assert_false(greater_left < greater_right);
    assert_true(greater_left > greater_right);
}

fn test_double_literals() -> unit {
    assert_false(-1.5 == 0.0);
    assert_true(-1.5 != 0.0);
    assert_true(-1.5 <= 0.0);
    assert_false(-1.5 >= 0.0);
    assert_true(-1.5 < 0.0);
    assert_false(-1.5 > 0.0);

    assert_true(-0.0 == 0.0);
    assert_false(-0.0 != 0.0);
    assert_true(-0.0 <= 0.0);
    assert_true(-0.0 >= 0.0);
    assert_false(-0.0 < 0.0);
    assert_false(-0.0 > 0.0);

    assert_false(123456.75 == -42.5);
    assert_true(123456.75 != -42.5);
    assert_false(123456.75 <= -42.5);
    assert_true(123456.75 >= -42.5);
    assert_false(123456.75 < -42.5);
    assert_true(123456.75 > -42.5);
}

fn test_double_constants() -> unit {
    var low: double = -1.5;
    var zero_neg: double = -0.0;
    var zero_pos: double = 0.0;
    var high: double = 123456.75;
    var lower: double = -42.5;

    assert_false(low == zero_pos);
    assert_true(low != zero_pos);
    assert_true(low <= zero_pos);
    assert_false(low >= zero_pos);
    assert_true(low < zero_pos);
    assert_false(low > zero_pos);

    assert_true(zero_neg == zero_pos);
    assert_false(zero_neg != zero_pos);
    assert_true(zero_neg <= zero_pos);
    assert_true(zero_neg >= zero_pos);
    assert_false(zero_neg < zero_pos);
    assert_false(zero_neg > zero_pos);

    assert_false(high == lower);
    assert_true(high != lower);
    assert_false(high <= lower);
    assert_true(high >= lower);
    assert_false(high < lower);
    assert_true(high > lower);
}

fn test_double_args(input: Str[]) -> unit {
    var less_left: double = input[0].to_double();
    var less_right: double = input[1].to_double();
    var equal_left: double = input[2].to_double();
    var equal_right: double = input[3].to_double();
    var greater_left: double = input[4].to_double();
    var greater_right: double = input[5].to_double();

    assert_false(less_left == less_right);
    assert_true(less_left != less_right);
    assert_true(less_left <= less_right);
    assert_false(less_left >= less_right);
    assert_true(less_left < less_right);
    assert_false(less_left > less_right);

    assert_true(equal_left == equal_right);
    assert_false(equal_left != equal_right);
    assert_true(equal_left <= equal_right);
    assert_true(equal_left >= equal_right);
    assert_false(equal_left < equal_right);
    assert_false(equal_left > equal_right);

    assert_false(greater_left == greater_right);
    assert_true(greater_left != greater_right);
    assert_false(greater_left <= greater_right);
    assert_true(greater_left >= greater_right);
    assert_false(greater_left < greater_right);
    assert_true(greater_left > greater_right);
}

fn main() -> i64 {
    var args: Str[] = read_program_args();
    var select: u64 = args[1].to_u64();

    if select == 1u { test_i64_literals(); return 0; }
    if select == 2u { test_i64_constants(); return 0; }
    if select == 3u { test_i64_args(args[2:]); return 0; }
    if select == 4u { test_u64_literals(); return 0; }
    if select == 5u { test_u64_constants(); return 0; }
    if select == 6u { test_u64_args(args[2:]); return 0; }
    if select == 7u { test_u8_literals(); return 0; }
    if select == 8u { test_u8_constants(); return 0; }
    if select == 9u { test_u8_args(args[2:]); return 0; }
    if select == 10u { test_double_literals(); return 0; }
    if select == 11u { test_double_constants(); return 0; }
    if select == 12u { test_double_args(args[2:]); return 0; }

    fail("comparison golden: invalid selection");
    return 1;
}
