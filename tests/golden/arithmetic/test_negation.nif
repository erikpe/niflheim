import std.io;
import std.math as math;
import std.str;
import std.test;

fn assert_neg_zero(value: double) -> unit {
    assert_eq_double(value, 0.0);
    var reciprocal: double = 1.0 / value;
    assert_true(math.is_infinite(reciprocal));
    assert_true(reciprocal < 0.0);
}

fn assert_pos_zero(value: double) -> unit {
    assert_eq_double(value, 0.0);
    var reciprocal: double = 1.0 / value;
    assert_true(math.is_infinite(reciprocal));
    assert_true(reciprocal > 0.0);
}

fn test_i64_literals() -> unit {
    assert_eq_i64(-0, 0);
    assert_eq_i64(-1, -1);
    assert_eq_i64(-(-1), 1);
    assert_eq_i64(-200, -200);
    assert_eq_i64(-(-200), 200);
    assert_eq_i64(-9223372036854775807, -9223372036854775807);
    assert_eq_i64(-(-9223372036854775807), 9223372036854775807);
    assert_eq_i64(-(-9223372036854775808), -9223372036854775808);
}

fn test_i64_constants() -> unit {
    var zero: i64 = 0;
    var one: i64 = 1;
    var neg_one: i64 = -1;
    var two_hundred: i64 = 200;
    var neg_two_hundred: i64 = -200;
    var max: i64 = 9223372036854775807;
    var min: i64 = -9223372036854775808;
    var min_plus_one: i64 = -9223372036854775807;

    assert_eq_i64(-zero, 0);
    assert_eq_i64(-one, -1);
    assert_eq_i64(-neg_one, 1);
    assert_eq_i64(-two_hundred, -200);
    assert_eq_i64(-neg_two_hundred, 200);
    assert_eq_i64(-max, -9223372036854775807);
    assert_eq_i64(-min, -9223372036854775808);
    assert_eq_i64(-min_plus_one, 9223372036854775807);
}

fn test_i64_args(input: Str[]) -> unit {
    assert_eq_i64(-input[0].to_i64(), 0);
    assert_eq_i64(-input[1].to_i64(), -1);
    assert_eq_i64(-input[2].to_i64(), 1);
    assert_eq_i64(-input[3].to_i64(), -200);
    assert_eq_i64(-input[4].to_i64(), 200);
    assert_eq_i64(-input[5].to_i64(), -9223372036854775807);
    assert_eq_i64(-input[6].to_i64(), -9223372036854775808);
    assert_eq_i64(-input[7].to_i64(), 9223372036854775807);
}

fn test_double_literals() -> unit {
    assert_eq_double(-1.5, -1.5);
    assert_eq_double(-(-1.5), 1.5);
    assert_eq_double(-2.5, -2.5);
    assert_eq_double(-(-2.5), 2.5);
    assert_eq_double(-123456.75, -123456.75);
    assert_eq_double(-(-123456.75), 123456.75);
    assert_neg_zero(-0.0);
    assert_pos_zero(-(-0.0));
}

fn test_double_constants() -> unit {
    var zero: double = 0.0;
    var neg_zero: double = -0.0;
    var one_half: double = 1.5;
    var neg_one_half: double = -1.5;
    var two_half: double = 2.5;
    var neg_two_half: double = -2.5;
    var large: double = 123456.75;
    var neg_large: double = -123456.75;

    assert_neg_zero(-zero);
    assert_pos_zero(-neg_zero);
    assert_eq_double(-one_half, -1.5);
    assert_eq_double(-neg_one_half, 1.5);
    assert_eq_double(-two_half, -2.5);
    assert_eq_double(-neg_two_half, 2.5);
    assert_eq_double(-large, -123456.75);
    assert_eq_double(-neg_large, 123456.75);
}

fn test_double_args(input: Str[]) -> unit {
    assert_neg_zero(-input[0].to_double());
    assert_pos_zero(-input[1].to_double());
    assert_eq_double(-input[2].to_double(), -1.5);
    assert_eq_double(-input[3].to_double(), 1.5);
    assert_eq_double(-input[4].to_double(), -2.5);
    assert_eq_double(-input[5].to_double(), 2.5);
    assert_eq_double(-input[6].to_double(), -123456.75);
    assert_eq_double(-input[7].to_double(), 123456.75);
}

fn main() -> i64 {
    var args: Str[] = read_program_args();
    var select: u64 = args[1].to_u64();

    if select == 1u { test_i64_literals(); return 0; }
    if select == 2u { test_i64_constants(); return 0; }
    if select == 3u { test_i64_args(args[2:]); return 0; }
    if select == 4u { test_double_literals(); return 0; }
    if select == 5u { test_double_constants(); return 0; }
    if select == 6u { test_double_args(args[2:]); return 0; }

    fail("negation golden: invalid selection");
    return 1;
}
