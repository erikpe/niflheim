import std.io;
import std.str;
import std.test;

fn test_i64(input: Str[]) -> unit {
    var i64_min: i64 = -9223372036854775808;
    var i64_max: i64 = 9223372036854775807;
    var i64_zero: i64 = 0;
    var i64_one: i64 = 1;
    var i64_neg1: i64 = -1;
    var i64_mid: i64 = 123456789;

    var d_i64_0: i64 = 1;
    var d_i64_1: i64 = 2;
    var d_i64_2: i64 = -2;
    var d_i64_3: i64 = 9223372036854775807;
    var d_i64_4: i64 = 123456789;
    var d_i64_5: i64 = -3;

    var i64_min_arg: i64 = input[0].to_i64();
    var i64_max_arg: i64 = input[1].to_i64();
    var i64_zero_arg: i64 = input[2].to_i64();
    var i64_one_arg: i64 = input[3].to_i64();
    var i64_neg1_arg: i64 = input[4].to_i64();
    var i64_mid_arg: i64 = input[5].to_i64();

    var d_i64_0_arg: i64 = input[6].to_i64();
    var d_i64_1_arg: i64 = input[7].to_i64();
    var d_i64_2_arg: i64 = input[8].to_i64();
    var d_i64_3_arg: i64 = input[9].to_i64();
    var d_i64_4_arg: i64 = input[10].to_i64();
    var d_i64_5_arg: i64 = input[11].to_i64();

    assert_eq_i64(i64_min % d_i64_0, 0);
    assert_eq_i64(i64_min % d_i64_1, 0);
    assert_eq_i64(i64_min % d_i64_2, 0);
    assert_eq_i64(i64_min % d_i64_3, 9223372036854775806);
    assert_eq_i64(i64_min % d_i64_4, 76735423);
    assert_eq_i64(i64_min % d_i64_5, -2);

    assert_eq_i64(i64_max % d_i64_0, 0);
    assert_eq_i64(i64_max % d_i64_1, 1);
    assert_eq_i64(i64_max % d_i64_2, -1);
    assert_eq_i64(i64_max % d_i64_3, 0);
    assert_eq_i64(i64_max % d_i64_4, 46721365);
    assert_eq_i64(i64_max % d_i64_5, -2);

    assert_eq_i64(i64_zero % d_i64_0, 0);
    assert_eq_i64(i64_zero % d_i64_1, 0);
    assert_eq_i64(i64_zero % d_i64_2, 0);
    assert_eq_i64(i64_zero % d_i64_3, 0);
    assert_eq_i64(i64_zero % d_i64_4, 0);
    assert_eq_i64(i64_zero % d_i64_5, 0);

    assert_eq_i64(i64_one % d_i64_0, 0);
    assert_eq_i64(i64_one % d_i64_1, 1);
    assert_eq_i64(i64_one % d_i64_2, -1);
    assert_eq_i64(i64_one % d_i64_3, 1);
    assert_eq_i64(i64_one % d_i64_4, 1);
    assert_eq_i64(i64_one % d_i64_5, -2);

    assert_eq_i64(i64_neg1 % d_i64_0, 0);
    assert_eq_i64(i64_neg1 % d_i64_1, 1);
    assert_eq_i64(i64_neg1 % d_i64_2, -1);
    assert_eq_i64(i64_neg1 % d_i64_3, 9223372036854775806);
    assert_eq_i64(i64_neg1 % d_i64_4, 123456788);
    assert_eq_i64(i64_neg1 % d_i64_5, -1);

    assert_eq_i64(i64_mid % d_i64_0, 0);
    assert_eq_i64(i64_mid % d_i64_1, 1);
    assert_eq_i64(i64_mid % d_i64_2, -1);
    assert_eq_i64(i64_mid % d_i64_3, 123456789);
    assert_eq_i64(i64_mid % d_i64_4, 0);
    assert_eq_i64(i64_mid % d_i64_5, 0);

    assert_eq_i64(i64_min_arg % d_i64_0_arg, 0);
    assert_eq_i64(i64_min_arg % d_i64_1_arg, 0);
    assert_eq_i64(i64_min_arg % d_i64_2_arg, 0);
    assert_eq_i64(i64_min_arg % d_i64_3_arg, 9223372036854775806);
    assert_eq_i64(i64_min_arg % d_i64_4_arg, 76735423);
    assert_eq_i64(i64_min_arg % d_i64_5_arg, -2);

    assert_eq_i64(i64_max_arg % d_i64_0_arg, 0);
    assert_eq_i64(i64_max_arg % d_i64_1_arg, 1);
    assert_eq_i64(i64_max_arg % d_i64_2_arg, -1);
    assert_eq_i64(i64_max_arg % d_i64_3_arg, 0);
    assert_eq_i64(i64_max_arg % d_i64_4_arg, 46721365);
    assert_eq_i64(i64_max_arg % d_i64_5_arg, -2);

    assert_eq_i64(i64_zero_arg % d_i64_0_arg, 0);
    assert_eq_i64(i64_zero_arg % d_i64_1_arg, 0);
    assert_eq_i64(i64_zero_arg % d_i64_2_arg, 0);
    assert_eq_i64(i64_zero_arg % d_i64_3_arg, 0);
    assert_eq_i64(i64_zero_arg % d_i64_4_arg, 0);
    assert_eq_i64(i64_zero_arg % d_i64_5_arg, 0);

    assert_eq_i64(i64_one_arg % d_i64_0_arg, 0);
    assert_eq_i64(i64_one_arg % d_i64_1_arg, 1);
    assert_eq_i64(i64_one_arg % d_i64_2_arg, -1);
    assert_eq_i64(i64_one_arg % d_i64_3_arg, 1);
    assert_eq_i64(i64_one_arg % d_i64_4_arg, 1);
    assert_eq_i64(i64_one_arg % d_i64_5_arg, -2);

    assert_eq_i64(i64_neg1_arg % d_i64_0_arg, 0);
    assert_eq_i64(i64_neg1_arg % d_i64_1_arg, 1);
    assert_eq_i64(i64_neg1_arg % d_i64_2_arg, -1);
    assert_eq_i64(i64_neg1_arg % d_i64_3_arg, 9223372036854775806);
    assert_eq_i64(i64_neg1_arg % d_i64_4_arg, 123456788);
    assert_eq_i64(i64_neg1_arg % d_i64_5_arg, -1);

    assert_eq_i64(i64_mid_arg % d_i64_0_arg, 0);
    assert_eq_i64(i64_mid_arg % d_i64_1_arg, 1);
    assert_eq_i64(i64_mid_arg % d_i64_2_arg, -1);
    assert_eq_i64(i64_mid_arg % d_i64_3_arg, 123456789);
    assert_eq_i64(i64_mid_arg % d_i64_4_arg, 0);
    assert_eq_i64(i64_mid_arg % d_i64_5_arg, 0);
}

fn test_i64_special_cases(input: Str[]) -> unit {
    var ex_a: i64 = -7;
    var ex_b: i64 = 100;
    var ex_c: i64 = 7;
    var ex_d: i64 = -100;
    var ex_e: i64 = -7;
    var ex_f: i64 = -100;
    var ex_g: i64 = 7;
    var ex_h: i64 = 100;
    var ex_i: i64 = -100;
    var ex_j: i64 = 7;
    var ex_k: i64 = 100;
    var ex_l: i64 = -7;
    var ex_m: i64 = -100;
    var ex_n: i64 = -7;
    var ex_o: i64 = 100;
    var ex_p: i64 = 7;

    var ex_a_arg: i64 = input[0].to_i64();
    var ex_b_arg: i64 = input[1].to_i64();
    var ex_c_arg: i64 = input[2].to_i64();
    var ex_d_arg: i64 = input[3].to_i64();
    var ex_e_arg: i64 = input[4].to_i64();
    var ex_f_arg: i64 = input[5].to_i64();
    var ex_g_arg: i64 = input[6].to_i64();
    var ex_h_arg: i64 = input[7].to_i64();
    var ex_i_arg: i64 = input[8].to_i64();
    var ex_j_arg: i64 = input[9].to_i64();
    var ex_k_arg: i64 = input[10].to_i64();
    var ex_l_arg: i64 = input[11].to_i64();
    var ex_m_arg: i64 = input[12].to_i64();
    var ex_n_arg: i64 = input[13].to_i64();
    var ex_o_arg: i64 = input[14].to_i64();
    var ex_p_arg: i64 = input[15].to_i64();

    assert_eq_i64(ex_a % ex_b, 93);
    assert_eq_i64(ex_c % ex_d, -93);
    assert_eq_i64(ex_e % ex_f, -7);
    assert_eq_i64(ex_g % ex_h, 7);
    assert_eq_i64(ex_i % ex_j, 5);
    assert_eq_i64(ex_k % ex_l, -5);
    assert_eq_i64(ex_m % ex_n, -2);
    assert_eq_i64(ex_o % ex_p, 2);

    assert_eq_i64(ex_a_arg % ex_b_arg, 93);
    assert_eq_i64(ex_c_arg % ex_d_arg, -93);
    assert_eq_i64(ex_e_arg % ex_f_arg, -7);
    assert_eq_i64(ex_g_arg % ex_h_arg, 7);
    assert_eq_i64(ex_i_arg % ex_j_arg, 5);
    assert_eq_i64(ex_k_arg % ex_l_arg, -5);
    assert_eq_i64(ex_m_arg % ex_n_arg, -2);
    assert_eq_i64(ex_o_arg % ex_p_arg, 2);
}

fn test_u64(input: Str[]) -> unit {
    var u64_zero: u64 = 0u;
    var u64_one: u64 = 1u;
    var u64_max: u64 = 18446744073709551615u;
    var u64_mid: u64 = 1000000000u;
    var u64_big: u64 = 4000000000000000000u;

    var d_u64_0: u64 = 1u;
    var d_u64_1: u64 = 18446744073709551615u;
    var d_u64_2: u64 = 1000000000u;
    var d_u64_3: u64 = 4000000000000000000u;
    var d_u64_4: u64 = 3u;

    var u64_zero_arg: u64 = input[0].to_u64();
    var u64_one_arg: u64 = input[1].to_u64();
    var u64_max_arg: u64 = input[2].to_u64();
    var u64_mid_arg: u64 = input[3].to_u64();
    var u64_big_arg: u64 = input[4].to_u64();

    var d_u64_0_arg: u64 = input[5].to_u64();
    var d_u64_1_arg: u64 = input[6].to_u64();
    var d_u64_2_arg: u64 = input[7].to_u64();
    var d_u64_3_arg: u64 = input[8].to_u64();
    var d_u64_4_arg: u64 = input[9].to_u64();

    assert_eq_u64(u64_zero % d_u64_0, 0u);
    assert_eq_u64(u64_zero % d_u64_1, 0u);
    assert_eq_u64(u64_zero % d_u64_2, 0u);
    assert_eq_u64(u64_zero % d_u64_3, 0u);
    assert_eq_u64(u64_zero % d_u64_4, 0u);

    assert_eq_u64(u64_one % d_u64_0, 0u);
    assert_eq_u64(u64_one % d_u64_1, 1u);
    assert_eq_u64(u64_one % d_u64_2, 1u);
    assert_eq_u64(u64_one % d_u64_3, 1u);
    assert_eq_u64(u64_one % d_u64_4, 1u);

    assert_eq_u64(u64_max % d_u64_0, 0u);
    assert_eq_u64(u64_max % d_u64_1, 0u);
    assert_eq_u64(u64_max % d_u64_2, 709551615u);
    assert_eq_u64(u64_max % d_u64_3, 2446744073709551615u);
    assert_eq_u64(u64_max % d_u64_4, 0u);

    assert_eq_u64(u64_mid % d_u64_0, 0u);
    assert_eq_u64(u64_mid % d_u64_1, 1000000000u);
    assert_eq_u64(u64_mid % d_u64_2, 0u);
    assert_eq_u64(u64_mid % d_u64_3, 1000000000u);
    assert_eq_u64(u64_mid % d_u64_4, 1u);

    assert_eq_u64(u64_big % d_u64_0, 0u);
    assert_eq_u64(u64_big % d_u64_1, 4000000000000000000u);
    assert_eq_u64(u64_big % d_u64_2, 0u);
    assert_eq_u64(u64_big % d_u64_3, 0u);
    assert_eq_u64(u64_big % d_u64_4, 1u);

    assert_eq_u64(u64_zero_arg % d_u64_0_arg, 0u);
    assert_eq_u64(u64_zero_arg % d_u64_1_arg, 0u);
    assert_eq_u64(u64_zero_arg % d_u64_2_arg, 0u);
    assert_eq_u64(u64_zero_arg % d_u64_3_arg, 0u);
    assert_eq_u64(u64_zero_arg % d_u64_4_arg, 0u);

    assert_eq_u64(u64_one_arg % d_u64_0_arg, 0u);
    assert_eq_u64(u64_one_arg % d_u64_1_arg, 1u);
    assert_eq_u64(u64_one_arg % d_u64_2_arg, 1u);
    assert_eq_u64(u64_one_arg % d_u64_3_arg, 1u);
    assert_eq_u64(u64_one_arg % d_u64_4_arg, 1u);

    assert_eq_u64(u64_max_arg % d_u64_0_arg, 0u);
    assert_eq_u64(u64_max_arg % d_u64_1_arg, 0u);
    assert_eq_u64(u64_max_arg % d_u64_2_arg, 709551615u);
    assert_eq_u64(u64_max_arg % d_u64_3_arg, 2446744073709551615u);
    assert_eq_u64(u64_max_arg % d_u64_4_arg, 0u);

    assert_eq_u64(u64_mid_arg % d_u64_0_arg, 0u);
    assert_eq_u64(u64_mid_arg % d_u64_1_arg, 1000000000u);
    assert_eq_u64(u64_mid_arg % d_u64_2_arg, 0u);
    assert_eq_u64(u64_mid_arg % d_u64_3_arg, 1000000000u);
    assert_eq_u64(u64_mid_arg % d_u64_4_arg, 1u);

    assert_eq_u64(u64_big_arg % d_u64_0_arg, 0u);
    assert_eq_u64(u64_big_arg % d_u64_1_arg, 4000000000000000000u);
    assert_eq_u64(u64_big_arg % d_u64_2_arg, 0u);
    assert_eq_u64(u64_big_arg % d_u64_3_arg, 0u);
    assert_eq_u64(u64_big_arg % d_u64_4_arg, 1u);
}

fn test_u8(input: Str[]) -> unit {
    var u8_zero: u8 = 0u8;
    var u8_one: u8 = 1u8;
    var u8_max: u8 = 255u8;
    var u8_mid: u8 = 17u8;
    var u8_big: u8 = 200u8;

    var d_u8_0: u8 = 1u8;
    var d_u8_1: u8 = 255u8;
    var d_u8_2: u8 = 17u8;
    var d_u8_3: u8 = 200u8;
    var d_u8_4: u8 = 3u8;

    var u8_zero_arg: u8 = (u8)input[0].to_u64();
    var u8_one_arg: u8 = (u8)input[1].to_u64();
    var u8_max_arg: u8 = (u8)input[2].to_u64();
    var u8_mid_arg: u8 = (u8)input[3].to_u64();
    var u8_big_arg: u8 = (u8)input[4].to_u64();

    var d_u8_0_arg: u8 = (u8)input[5].to_u64();
    var d_u8_1_arg: u8 = (u8)input[6].to_u64();
    var d_u8_2_arg: u8 = (u8)input[7].to_u64();
    var d_u8_3_arg: u8 = (u8)input[8].to_u64();
    var d_u8_4_arg: u8 = (u8)input[9].to_u64();

    assert_eq_u8(u8_zero % d_u8_0, 0u8);
    assert_eq_u8(u8_zero % d_u8_1, 0u8);
    assert_eq_u8(u8_zero % d_u8_2, 0u8);
    assert_eq_u8(u8_zero % d_u8_3, 0u8);
    assert_eq_u8(u8_zero % d_u8_4, 0u8);

    assert_eq_u8(u8_one % d_u8_0, 0u8);
    assert_eq_u8(u8_one % d_u8_1, 1u8);
    assert_eq_u8(u8_one % d_u8_2, 1u8);
    assert_eq_u8(u8_one % d_u8_3, 1u8);
    assert_eq_u8(u8_one % d_u8_4, 1u8);

    assert_eq_u8(u8_max % d_u8_0, 0u8);
    assert_eq_u8(u8_max % d_u8_1, 0u8);
    assert_eq_u8(u8_max % d_u8_2, 0u8);
    assert_eq_u8(u8_max % d_u8_3, 55u8);
    assert_eq_u8(u8_max % d_u8_4, 0u8);

    assert_eq_u8(u8_mid % d_u8_0, 0u8);
    assert_eq_u8(u8_mid % d_u8_1, 17u8);
    assert_eq_u8(u8_mid % d_u8_2, 0u8);
    assert_eq_u8(u8_mid % d_u8_3, 17u8);
    assert_eq_u8(u8_mid % d_u8_4, 2u8);

    assert_eq_u8(u8_big % d_u8_0, 0u8);
    assert_eq_u8(u8_big % d_u8_1, 200u8);
    assert_eq_u8(u8_big % d_u8_2, 13u8);
    assert_eq_u8(u8_big % d_u8_3, 0u8);
    assert_eq_u8(u8_big % d_u8_4, 2u8);

    assert_eq_u8(u8_zero_arg % d_u8_0_arg, 0u8);
    assert_eq_u8(u8_zero_arg % d_u8_1_arg, 0u8);
    assert_eq_u8(u8_zero_arg % d_u8_2_arg, 0u8);
    assert_eq_u8(u8_zero_arg % d_u8_3_arg, 0u8);
    assert_eq_u8(u8_zero_arg % d_u8_4_arg, 0u8);

    assert_eq_u8(u8_one_arg % d_u8_0_arg, 0u8);
    assert_eq_u8(u8_one_arg % d_u8_1_arg, 1u8);
    assert_eq_u8(u8_one_arg % d_u8_2_arg, 1u8);
    assert_eq_u8(u8_one_arg % d_u8_3_arg, 1u8);
    assert_eq_u8(u8_one_arg % d_u8_4_arg, 1u8);

    assert_eq_u8(u8_max_arg % d_u8_0_arg, 0u8);
    assert_eq_u8(u8_max_arg % d_u8_1_arg, 0u8);
    assert_eq_u8(u8_max_arg % d_u8_2_arg, 0u8);
    assert_eq_u8(u8_max_arg % d_u8_3_arg, 55u8);
    assert_eq_u8(u8_max_arg % d_u8_4_arg, 0u8);

    assert_eq_u8(u8_mid_arg % d_u8_0_arg, 0u8);
    assert_eq_u8(u8_mid_arg % d_u8_1_arg, 17u8);
    assert_eq_u8(u8_mid_arg % d_u8_2_arg, 0u8);
    assert_eq_u8(u8_mid_arg % d_u8_3_arg, 17u8);
    assert_eq_u8(u8_mid_arg % d_u8_4_arg, 2u8);

    assert_eq_u8(u8_big_arg % d_u8_0_arg, 0u8);
    assert_eq_u8(u8_big_arg % d_u8_1_arg, 200u8);
    assert_eq_u8(u8_big_arg % d_u8_2_arg, 13u8);
    assert_eq_u8(u8_big_arg % d_u8_3_arg, 0u8);
    assert_eq_u8(u8_big_arg % d_u8_4_arg, 2u8);
}

fn main() -> i64 {
    var args: Str[] = read_program_args();
    var select: u64 = args[1].to_u64();

    if select == 1u { test_i64(args[2:]); return 0; }
    if select == 2u { test_i64_special_cases(args[2:]); return 0; }
    if select == 3u { test_u64(args[2:]); return 0; }
    if select == 4u { test_u8(args[2:]); return 0; }

    return 99;
}
