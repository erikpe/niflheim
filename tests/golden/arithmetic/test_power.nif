import std.io;
import std.str;
import std.test;

fn test_i64_literals() -> unit {
    assert_eq_i64((-2) ** 0u, 1);
    assert_eq_i64((-2) ** 1u, -2);
    assert_eq_i64((-2) ** 2u, 4);
    assert_eq_i64((-2) ** 3u, -8);
    assert_eq_i64((-2) ** 4u, 16);
    assert_eq_i64((-1) ** 63u, -1);
    assert_eq_i64((-1) ** 64u, 1);
    assert_eq_i64(0 ** 0u, 1);
    assert_eq_i64(0 ** 5u, 0);
    assert_eq_i64(1 ** 63u, 1);
    assert_eq_i64(2 ** 10u, 1024);
    assert_eq_i64(3 ** 40u, -6289078614652622815);
    assert_eq_i64((-9223372036854775808) ** 1u, -9223372036854775808);
    assert_eq_i64((-9223372036854775808) ** 2u, 0);
    assert_eq_i64(9223372036854775807 ** 2u, 1);
}

fn test_i64_constants() -> unit {
    var neg_two: i64 = -2;
    var neg_one: i64 = -1;
    var zero: i64 = 0;
    var one: i64 = 1;
    var two: i64 = 2;
    var three: i64 = 3;
    var min: i64 = -9223372036854775808;
    var max: i64 = 9223372036854775807;

    var e0: u64 = 0u;
    var e1: u64 = 1u;
    var e2: u64 = 2u;
    var e3: u64 = 3u;
    var e4: u64 = 4u;
    var e5: u64 = 5u;
    var e10: u64 = 10u;
    var e40: u64 = 40u;
    var e63: u64 = 63u;
    var e64: u64 = 64u;

    assert_eq_i64(neg_two ** e0, 1);
    assert_eq_i64(neg_two ** e1, -2);
    assert_eq_i64(neg_two ** e2, 4);
    assert_eq_i64(neg_two ** e3, -8);
    assert_eq_i64(neg_two ** e4, 16);
    assert_eq_i64(neg_one ** e63, -1);
    assert_eq_i64(neg_one ** e64, 1);
    assert_eq_i64(zero ** e0, 1);
    assert_eq_i64(zero ** e5, 0);
    assert_eq_i64(one ** e63, 1);
    assert_eq_i64(two ** e10, 1024);
    assert_eq_i64(three ** e40, -6289078614652622815);
    assert_eq_i64(min ** e1, -9223372036854775808);
    assert_eq_i64(min ** e2, 0);
    assert_eq_i64(max ** e2, 1);
}

fn test_i64_args(input: Str[]) -> unit {
    assert_eq_i64(input[0].to_i64() ** input[1].to_u64(), 1);
    assert_eq_i64(input[2].to_i64() ** input[3].to_u64(), -2);
    assert_eq_i64(input[4].to_i64() ** input[5].to_u64(), 4);
    assert_eq_i64(input[6].to_i64() ** input[7].to_u64(), -8);
    assert_eq_i64(input[8].to_i64() ** input[9].to_u64(), 16);
    assert_eq_i64(input[10].to_i64() ** input[11].to_u64(), -1);
    assert_eq_i64(input[12].to_i64() ** input[13].to_u64(), 1);
    assert_eq_i64(input[14].to_i64() ** input[15].to_u64(), 1);
    assert_eq_i64(input[16].to_i64() ** input[17].to_u64(), 0);
    assert_eq_i64(input[18].to_i64() ** input[19].to_u64(), 1);
    assert_eq_i64(input[20].to_i64() ** input[21].to_u64(), 1024);
    assert_eq_i64(input[22].to_i64() ** input[23].to_u64(), -6289078614652622815);
    assert_eq_i64(input[24].to_i64() ** input[25].to_u64(), -9223372036854775808);
    assert_eq_i64(input[26].to_i64() ** input[27].to_u64(), 0);
    assert_eq_i64(input[28].to_i64() ** input[29].to_u64(), 1);
}

fn test_u64_literals() -> unit {
    assert_eq_u64(0u ** 0u, 1u);
    assert_eq_u64(0u ** 5u, 0u);
    assert_eq_u64(1u ** 64u, 1u);
    assert_eq_u64(2u ** 10u, 1024u);
    assert_eq_u64(2u ** 63u, 9223372036854775808u);
    assert_eq_u64(2u ** 64u, 0u);
    assert_eq_u64(3u ** 40u, 12157665459056928801u);
    assert_eq_u64(18446744073709551615u ** 1u, 18446744073709551615u);
    assert_eq_u64(18446744073709551615u ** 2u, 1u);
    assert_eq_u64(4000000000u ** 3u, 17591076886291677184u);
}

fn test_u64_constants() -> unit {
    var zero: u64 = 0u;
    var one: u64 = 1u;
    var two: u64 = 2u;
    var three: u64 = 3u;
    var max: u64 = 18446744073709551615u;
    var big: u64 = 4000000000u;

    var e0: u64 = 0u;
    var e1: u64 = 1u;
    var e2: u64 = 2u;
    var e3: u64 = 3u;
    var e5: u64 = 5u;
    var e10: u64 = 10u;
    var e40: u64 = 40u;
    var e63: u64 = 63u;
    var e64: u64 = 64u;

    assert_eq_u64(zero ** e0, 1u);
    assert_eq_u64(zero ** e5, 0u);
    assert_eq_u64(one ** e64, 1u);
    assert_eq_u64(two ** e10, 1024u);
    assert_eq_u64(two ** e63, 9223372036854775808u);
    assert_eq_u64(two ** e64, 0u);
    assert_eq_u64(three ** e40, 12157665459056928801u);
    assert_eq_u64(max ** e1, 18446744073709551615u);
    assert_eq_u64(max ** e2, 1u);
    assert_eq_u64(big ** e3, 17591076886291677184u);
}

fn test_u64_args(input: Str[]) -> unit {
    assert_eq_u64(input[0].to_u64() ** input[1].to_u64(), 1u);
    assert_eq_u64(input[2].to_u64() ** input[3].to_u64(), 0u);
    assert_eq_u64(input[4].to_u64() ** input[5].to_u64(), 1u);
    assert_eq_u64(input[6].to_u64() ** input[7].to_u64(), 1024u);
    assert_eq_u64(input[8].to_u64() ** input[9].to_u64(), 9223372036854775808u);
    assert_eq_u64(input[10].to_u64() ** input[11].to_u64(), 0u);
    assert_eq_u64(input[12].to_u64() ** input[13].to_u64(), 12157665459056928801u);
    assert_eq_u64(input[14].to_u64() ** input[15].to_u64(), 18446744073709551615u);
    assert_eq_u64(input[16].to_u64() ** input[17].to_u64(), 1u);
    assert_eq_u64(input[18].to_u64() ** input[19].to_u64(), 17591076886291677184u);
}

fn test_u8_literals() -> unit {
    assert_eq_u8(0u8 ** 0u, 1u8);
    assert_eq_u8(0u8 ** 5u, 0u8);
    assert_eq_u8(1u8 ** 255u, 1u8);
    assert_eq_u8(2u8 ** 7u, 128u8);
    assert_eq_u8(2u8 ** 8u, 0u8);
    assert_eq_u8(3u8 ** 5u, 243u8);
    assert_eq_u8(5u8 ** 3u, 125u8);
    assert_eq_u8(16u8 ** 2u, 0u8);
    assert_eq_u8(17u8 ** 2u, 33u8);
    assert_eq_u8(200u8 ** 2u, 64u8);
    assert_eq_u8(255u8 ** 2u, 1u8);
}

fn test_u8_constants() -> unit {
    var zero: u8 = 0u8;
    var one: u8 = 1u8;
    var two: u8 = 2u8;
    var three: u8 = 3u8;
    var five: u8 = 5u8;
    var sixteen: u8 = 16u8;
    var seventeen: u8 = 17u8;
    var two_hundred: u8 = 200u8;
    var max: u8 = 255u8;

    var e0: u64 = 0u;
    var e2: u64 = 2u;
    var e3: u64 = 3u;
    var e5: u64 = 5u;
    var e7: u64 = 7u;
    var e8: u64 = 8u;
    var e255: u64 = 255u;

    assert_eq_u8(zero ** e0, 1u8);
    assert_eq_u8(zero ** e5, 0u8);
    assert_eq_u8(one ** e255, 1u8);
    assert_eq_u8(two ** e7, 128u8);
    assert_eq_u8(two ** e8, 0u8);
    assert_eq_u8(three ** e5, 243u8);
    assert_eq_u8(five ** e3, 125u8);
    assert_eq_u8(sixteen ** e2, 0u8);
    assert_eq_u8(seventeen ** e2, 33u8);
    assert_eq_u8(two_hundred ** e2, 64u8);
    assert_eq_u8(max ** e2, 1u8);
}

fn test_u8_args(input: Str[]) -> unit {
    assert_eq_u8((u8)input[0].to_u64() ** input[1].to_u64(), 1u8);
    assert_eq_u8((u8)input[2].to_u64() ** input[3].to_u64(), 0u8);
    assert_eq_u8((u8)input[4].to_u64() ** input[5].to_u64(), 1u8);
    assert_eq_u8((u8)input[6].to_u64() ** input[7].to_u64(), 128u8);
    assert_eq_u8((u8)input[8].to_u64() ** input[9].to_u64(), 0u8);
    assert_eq_u8((u8)input[10].to_u64() ** input[11].to_u64(), 243u8);
    assert_eq_u8((u8)input[12].to_u64() ** input[13].to_u64(), 125u8);
    assert_eq_u8((u8)input[14].to_u64() ** input[15].to_u64(), 0u8);
    assert_eq_u8((u8)input[16].to_u64() ** input[17].to_u64(), 33u8);
    assert_eq_u8((u8)input[18].to_u64() ** input[19].to_u64(), 64u8);
    assert_eq_u8((u8)input[20].to_u64() ** input[21].to_u64(), 1u8);
}

fn test_precedence_literals() -> unit {
    assert_eq_u64(2u ** 3u ** 2u, 512u);
    assert_eq_u64((2u ** 3u) ** 2u, 64u);
    assert_eq_u64(2u ** 3u * 4u, 32u);
    assert_eq_u64(2u * 3u ** 4u, 162u);
}

fn test_precedence_constants() -> unit {
    var two: u64 = 2u;
    var three: u64 = 3u;
    var four: u64 = 4u;
    var e2: u64 = 2u;
    var e3: u64 = 3u;
    var e4: u64 = 4u;

    assert_eq_u64(two ** three ** e2, 512u);
    assert_eq_u64((two ** e3) ** e2, 64u);
    assert_eq_u64(two ** e3 * four, 32u);
    assert_eq_u64(two * three ** e4, 162u);
}

fn test_precedence_args(input: Str[]) -> unit {
    var two: u64 = input[0].to_u64();
    var three: u64 = input[1].to_u64();
    var four: u64 = input[2].to_u64();
    var e2: u64 = input[3].to_u64();
    var e3: u64 = input[4].to_u64();
    var e4: u64 = input[5].to_u64();

    assert_eq_u64(two ** three ** e2, 512u);
    assert_eq_u64((two ** e3) ** e2, 64u);
    assert_eq_u64(two ** e3 * four, 32u);
    assert_eq_u64(two * three ** e4, 162u);
}

fn test_integer_power_identities(input: Str[]) -> unit {
    var exponent_one: u64 = 1u;

    var i64_value_arg: i64 = input[0].to_i64();
    assert_eq_i64(i64_value_arg ** 1u, i64_value_arg);
    assert_eq_i64(i64_value_arg ** exponent_one, i64_value_arg);

    var u64_value_arg: u64 = input[1].to_u64();
    assert_eq_u64(u64_value_arg ** 1u, u64_value_arg);
    assert_eq_u64(u64_value_arg ** exponent_one, u64_value_arg);

    var u8_value_arg: u8 = (u8)input[2].to_u64();
    assert_eq_u8(u8_value_arg ** 1u, u8_value_arg);
    assert_eq_u8(u8_value_arg ** exponent_one, u8_value_arg);
}

fn main() -> i64 {
    var args: Str[] = read_program_args();
    var select: u64 = args[1].to_u64();

    if select == 1u { test_i64_literals(); return 0; }
    if select == 2u { test_i64_constants(); return 0; }
    if select == 3u { test_i64_args(args[2:]); return 0; }
    if select == 4u { test_u64_literals(); return 0; }
    if select == 5u { test_u64_constants(); return 0; }
    if select == 6u { test_u64_args(args[2:]); return 0; }
    if select == 7u { test_u8_literals(); return 0; }
    if select == 8u { test_u8_constants(); return 0; }
    if select == 9u { test_u8_args(args[2:]); return 0; }
    if select == 10u { test_precedence_literals(); return 0; }
    if select == 11u { test_precedence_constants(); return 0; }
    if select == 12u { test_precedence_args(args[2:]); return 0; }
    if select == 13u { test_integer_power_identities(args[2:]); return 0; }

    fail("power golden: invalid selection");
    return 1;
}
