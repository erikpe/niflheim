import std.io;
import std.str;
import std.test;

fn test_u64_literals() -> unit {
    assert_eq_u64(1u << 0u, 1u);
    assert_eq_u64(1u >> 0u, 1u);
    assert_eq_u64(1u << 1u, 2u);
    assert_eq_u64(1u >> 1u, 0u);
    assert_eq_u64(1u << 63u, 9223372036854775808u);
    assert_eq_u64(1u >> 63u, 0u);
    assert_eq_u64(9223372036854775808u << 63u, 0u);
    assert_eq_u64(9223372036854775808u >> 63u, 1u);
    assert_eq_u64(18446744073709551615u << 1u, 18446744073709551614u);
    assert_eq_u64(18446744073709551615u >> 1u, 9223372036854775807u);
    assert_eq_u64(1311768467463790320u << 4u, 2541551405711093504u);
    assert_eq_u64(1311768467463790320u >> 4u, 81985529216486895u);
}

fn test_u64_constants() -> unit {
    var one: u64 = 1u;
    var high_bit: u64 = 9223372036854775808u;
    var max: u64 = 18446744073709551615u;
    var pattern: u64 = 1311768467463790320u;
    var s0: u64 = 0u;
    var s1: u64 = 1u;
    var s4: u64 = 4u;
    var s63: u64 = 63u;

    assert_eq_u64(one << s0, 1u);
    assert_eq_u64(one >> s0, 1u);
    assert_eq_u64(one << s1, 2u);
    assert_eq_u64(one >> s1, 0u);
    assert_eq_u64(one << s63, 9223372036854775808u);
    assert_eq_u64(one >> s63, 0u);
    assert_eq_u64(high_bit << s63, 0u);
    assert_eq_u64(high_bit >> s63, 1u);
    assert_eq_u64(max << s1, 18446744073709551614u);
    assert_eq_u64(max >> s1, 9223372036854775807u);
    assert_eq_u64(pattern << s4, 2541551405711093504u);
    assert_eq_u64(pattern >> s4, 81985529216486895u);
}

fn test_u64_args(input: Str[]) -> unit {
    assert_eq_u64(input[0].to_u64() << input[1].to_u64(), 1u);
    assert_eq_u64(input[0].to_u64() >> input[1].to_u64(), 1u);
    assert_eq_u64(input[2].to_u64() << input[3].to_u64(), 2u);
    assert_eq_u64(input[2].to_u64() >> input[3].to_u64(), 0u);
    assert_eq_u64(input[4].to_u64() << input[5].to_u64(), 9223372036854775808u);
    assert_eq_u64(input[4].to_u64() >> input[5].to_u64(), 0u);
    assert_eq_u64(input[6].to_u64() << input[7].to_u64(), 0u);
    assert_eq_u64(input[6].to_u64() >> input[7].to_u64(), 1u);
    assert_eq_u64(input[8].to_u64() << input[9].to_u64(), 18446744073709551614u);
    assert_eq_u64(input[8].to_u64() >> input[9].to_u64(), 9223372036854775807u);
    assert_eq_u64(input[10].to_u64() << input[11].to_u64(), 2541551405711093504u);
    assert_eq_u64(input[10].to_u64() >> input[11].to_u64(), 81985529216486895u);
}

fn test_i64_literals() -> unit {
    assert_eq_i64(1 << 0u, 1);
    assert_eq_i64(1 >> 0u, 1);
    assert_eq_i64(1 << 62u, 4611686018427387904);
    assert_eq_i64(1 >> 62u, 0);
    assert_eq_i64(-1 << 1u, -2);
    assert_eq_i64(-1 >> 1u, -1);
    assert_eq_i64(-8 << 1u, -16);
    assert_eq_i64(-8 >> 1u, -4);
    assert_eq_i64(-8 << 3u, -64);
    assert_eq_i64(-8 >> 3u, -1);
    assert_eq_i64(-9223372036854775808 << 63u, 0);
    assert_eq_i64(-9223372036854775808 >> 63u, -1);
    assert_eq_i64(4611686018427387904 << 1u, -9223372036854775808);
    assert_eq_i64(4611686018427387904 >> 1u, 2305843009213693952);
    assert_eq_i64(9223372036854775807 << 1u, -2);
    assert_eq_i64(9223372036854775807 >> 1u, 4611686018427387903);
}

fn test_i64_constants() -> unit {
    var one: i64 = 1;
    var neg_one: i64 = -1;
    var neg_eight: i64 = -8;
    var min: i64 = -9223372036854775808;
    var high_positive: i64 = 4611686018427387904;
    var max: i64 = 9223372036854775807;
    var s0: u64 = 0u;
    var s1: u64 = 1u;
    var s3: u64 = 3u;
    var s62: u64 = 62u;
    var s63: u64 = 63u;

    assert_eq_i64(one << s0, 1);
    assert_eq_i64(one >> s0, 1);
    assert_eq_i64(one << s62, 4611686018427387904);
    assert_eq_i64(one >> s62, 0);
    assert_eq_i64(neg_one << s1, -2);
    assert_eq_i64(neg_one >> s1, -1);
    assert_eq_i64(neg_eight << s1, -16);
    assert_eq_i64(neg_eight >> s1, -4);
    assert_eq_i64(neg_eight << s3, -64);
    assert_eq_i64(neg_eight >> s3, -1);
    assert_eq_i64(min << s63, 0);
    assert_eq_i64(min >> s63, -1);
    assert_eq_i64(high_positive << s1, -9223372036854775808);
    assert_eq_i64(high_positive >> s1, 2305843009213693952);
    assert_eq_i64(max << s1, -2);
    assert_eq_i64(max >> s1, 4611686018427387903);
}

fn test_i64_args(input: Str[]) -> unit {
    assert_eq_i64(input[0].to_i64() << input[1].to_u64(), 1);
    assert_eq_i64(input[0].to_i64() >> input[1].to_u64(), 1);
    assert_eq_i64(input[2].to_i64() << input[3].to_u64(), 4611686018427387904);
    assert_eq_i64(input[2].to_i64() >> input[3].to_u64(), 0);
    assert_eq_i64(input[4].to_i64() << input[5].to_u64(), -2);
    assert_eq_i64(input[4].to_i64() >> input[5].to_u64(), -1);
    assert_eq_i64(input[6].to_i64() << input[7].to_u64(), -16);
    assert_eq_i64(input[6].to_i64() >> input[7].to_u64(), -4);
    assert_eq_i64(input[8].to_i64() << input[9].to_u64(), -64);
    assert_eq_i64(input[8].to_i64() >> input[9].to_u64(), -1);
    assert_eq_i64(input[10].to_i64() << input[11].to_u64(), 0);
    assert_eq_i64(input[10].to_i64() >> input[11].to_u64(), -1);
    assert_eq_i64(input[12].to_i64() << input[13].to_u64(), -9223372036854775808);
    assert_eq_i64(input[12].to_i64() >> input[13].to_u64(), 2305843009213693952);
    assert_eq_i64(input[14].to_i64() << input[15].to_u64(), -2);
    assert_eq_i64(input[14].to_i64() >> input[15].to_u64(), 4611686018427387903);
}

fn test_u8_literals() -> unit {
    assert_eq_u8(1u8 << 0u, 1u8);
    assert_eq_u8(1u8 >> 0u, 1u8);
    assert_eq_u8(1u8 << 1u, 2u8);
    assert_eq_u8(1u8 >> 1u, 0u8);
    assert_eq_u8(1u8 << 7u, 128u8);
    assert_eq_u8(1u8 >> 7u, 0u8);
    assert_eq_u8(128u8 << 7u, 0u8);
    assert_eq_u8(128u8 >> 7u, 1u8);
    assert_eq_u8(200u8 << 1u, 144u8);
    assert_eq_u8(200u8 >> 1u, 100u8);
    assert_eq_u8(200u8 << 3u, 64u8);
    assert_eq_u8(200u8 >> 3u, 25u8);
    assert_eq_u8(255u8 << 1u, 254u8);
    assert_eq_u8(255u8 >> 1u, 127u8);
    assert_eq_u8(15u8 << 4u, 240u8);
    assert_eq_u8(15u8 >> 4u, 0u8);
}

fn test_u8_constants() -> unit {
    var one: u8 = 1u8;
    var high_bit: u8 = 128u8;
    var two_hundred: u8 = 200u8;
    var max: u8 = 255u8;
    var fifteen: u8 = 15u8;
    var s0: u64 = 0u;
    var s1: u64 = 1u;
    var s3: u64 = 3u;
    var s4: u64 = 4u;
    var s7: u64 = 7u;

    assert_eq_u8(one << s0, 1u8);
    assert_eq_u8(one >> s0, 1u8);
    assert_eq_u8(one << s1, 2u8);
    assert_eq_u8(one >> s1, 0u8);
    assert_eq_u8(one << s7, 128u8);
    assert_eq_u8(one >> s7, 0u8);
    assert_eq_u8(high_bit << s7, 0u8);
    assert_eq_u8(high_bit >> s7, 1u8);
    assert_eq_u8(two_hundred << s1, 144u8);
    assert_eq_u8(two_hundred >> s1, 100u8);
    assert_eq_u8(two_hundred << s3, 64u8);
    assert_eq_u8(two_hundred >> s3, 25u8);
    assert_eq_u8(max << s1, 254u8);
    assert_eq_u8(max >> s1, 127u8);
    assert_eq_u8(fifteen << s4, 240u8);
    assert_eq_u8(fifteen >> s4, 0u8);
}

fn test_u8_args(input: Str[]) -> unit {
    assert_eq_u8((u8)input[0].to_u64() << input[1].to_u64(), 1u8);
    assert_eq_u8((u8)input[0].to_u64() >> input[1].to_u64(), 1u8);
    assert_eq_u8((u8)input[2].to_u64() << input[3].to_u64(), 2u8);
    assert_eq_u8((u8)input[2].to_u64() >> input[3].to_u64(), 0u8);
    assert_eq_u8((u8)input[4].to_u64() << input[5].to_u64(), 128u8);
    assert_eq_u8((u8)input[4].to_u64() >> input[5].to_u64(), 0u8);
    assert_eq_u8((u8)input[6].to_u64() << input[7].to_u64(), 0u8);
    assert_eq_u8((u8)input[6].to_u64() >> input[7].to_u64(), 1u8);
    assert_eq_u8((u8)input[8].to_u64() << input[9].to_u64(), 144u8);
    assert_eq_u8((u8)input[8].to_u64() >> input[9].to_u64(), 100u8);
    assert_eq_u8((u8)input[10].to_u64() << input[11].to_u64(), 64u8);
    assert_eq_u8((u8)input[10].to_u64() >> input[11].to_u64(), 25u8);
    assert_eq_u8((u8)input[12].to_u64() << input[13].to_u64(), 254u8);
    assert_eq_u8((u8)input[12].to_u64() >> input[13].to_u64(), 127u8);
    assert_eq_u8((u8)input[14].to_u64() << input[15].to_u64(), 240u8);
    assert_eq_u8((u8)input[14].to_u64() >> input[15].to_u64(), 0u8);
}

fn test_precedence_literals() -> unit {
    assert_eq_u64(1u << 2u + 1u, 8u);
    assert_eq_u64((1u << 2u) + 1u, 5u);
    assert_eq_u64(16u >> 1u + 1u, 4u);
    assert_eq_u64((16u >> 1u) + 1u, 9u);
}

fn test_precedence_constants() -> unit {
    var one: u64 = 1u;
    var two: u64 = 2u;
    var sixteen: u64 = 16u;

    assert_eq_u64(one << two + one, 8u);
    assert_eq_u64((one << two) + one, 5u);
    assert_eq_u64(sixteen >> one + one, 4u);
    assert_eq_u64((sixteen >> one) + one, 9u);
}

fn test_precedence_args(input: Str[]) -> unit {
    var one: u64 = input[0].to_u64();
    var two: u64 = input[1].to_u64();
    var sixteen: u64 = input[2].to_u64();

    assert_eq_u64(one << two + one, 8u);
    assert_eq_u64((one << two) + one, 5u);
    assert_eq_u64(sixteen >> one + one, 4u);
    assert_eq_u64((sixteen >> one) + one, 9u);
}

fn test_u8_literal_oob_panics() -> unit {
    var x: u8 = 1u8 << 8u;
}

fn test_u8_arg_oob_panics(input: Str[]) -> unit {
    var x: u8 = (u8)input[0].to_u64() >> input[1].to_u64();
}

fn test_u64_literal_oob_panics() -> unit {
    var x: u64 = 1u >> 64u;
}

fn test_u64_arg_oob_panics(input: Str[]) -> unit {
    var x: u64 = input[0].to_u64() << input[1].to_u64();
}

fn test_i64_arg_oob_panics(input: Str[]) -> unit {
    var x: i64 = input[0].to_i64() >> input[1].to_u64();
}

fn test_integer_shift_identities(input: Str[]) -> unit {
    var shift_zero: u64 = 0u;

    var u64_value_arg: u64 = input[0].to_u64();
    assert_eq_u64(u64_value_arg << 0u, u64_value_arg);
    assert_eq_u64(u64_value_arg >> 0u, u64_value_arg);
    assert_eq_u64(u64_value_arg << shift_zero, u64_value_arg);
    assert_eq_u64(u64_value_arg >> shift_zero, u64_value_arg);

    var i64_value_arg: i64 = input[1].to_i64();
    assert_eq_i64(i64_value_arg << 0u, i64_value_arg);
    assert_eq_i64(i64_value_arg >> 0u, i64_value_arg);
    assert_eq_i64(i64_value_arg << shift_zero, i64_value_arg);
    assert_eq_i64(i64_value_arg >> shift_zero, i64_value_arg);

    var u8_value_arg: u8 = (u8)input[2].to_u64();
    assert_eq_u8(u8_value_arg << 0u, u8_value_arg);
    assert_eq_u8(u8_value_arg >> 0u, u8_value_arg);
    assert_eq_u8(u8_value_arg << shift_zero, u8_value_arg);
    assert_eq_u8(u8_value_arg >> shift_zero, u8_value_arg);
}

fn main() -> i64 {
    var args: Str[] = read_program_args();
    var select: u64 = args[1].to_u64();

    if select == 1u { test_u64_literals(); return 0; }
    if select == 2u { test_u64_constants(); return 0; }
    if select == 3u { test_u64_args(args[2:]); return 0; }
    if select == 4u { test_i64_literals(); return 0; }
    if select == 5u { test_i64_constants(); return 0; }
    if select == 6u { test_i64_args(args[2:]); return 0; }
    if select == 7u { test_u8_literals(); return 0; }
    if select == 8u { test_u8_constants(); return 0; }
    if select == 9u { test_u8_args(args[2:]); return 0; }
    if select == 10u { test_precedence_literals(); return 0; }
    if select == 11u { test_precedence_constants(); return 0; }
    if select == 12u { test_precedence_args(args[2:]); return 0; }
    if select == 13u { test_u8_literal_oob_panics(); return 0; }
    if select == 14u { test_u8_arg_oob_panics(args[2:]); return 0; }
    if select == 15u { test_u64_literal_oob_panics(); return 0; }
    if select == 16u { test_u64_arg_oob_panics(args[2:]); return 0; }
    if select == 17u { test_i64_arg_oob_panics(args[2:]); return 0; }
    if select == 18u { test_integer_shift_identities(args[2:]); return 0; }

    fail("shift golden: invalid selection");
    return 1;
}
