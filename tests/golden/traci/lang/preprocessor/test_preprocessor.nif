import std.io;
import std.str;
import std.test;
import std.error;
import proj.traci_nif.main.Result as result;
import proj.traci_nif.main.Settings as settings;
import proj.traci_nif.lang.preprocessor.PreprocessorRunner as preprocessor_runner;

fn _new_settings(path: Str) -> settings.Settings {
    var cfg: settings.Settings = settings.Settings.mock();
    cfg.set_input_filename(path);
    return cfg;
}

fn _matches_at(text: Str, offset: i64, needle: Str) -> bool {
    var needle_len: i64 = (i64)needle.len();
    if offset < 0 || (u64)(offset + needle_len) > text.len() {
        return false;
    }

    var i: i64 = 0;
    while i < needle_len {
        if text[offset + i] != needle[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn _replace_all(text: Str, needle: Str, replacement: Str) -> Str {
    var out: StrBuf = StrBuf.new(text.len());
    var i: i64 = 0;
    while (u64)i < text.len() {
        if _matches_at(text, i, needle) {
            out.append(replacement);
            i = i + (i64)needle.len();
            continue;
        }
        out.append_char(text[i]);
        i = i + 1;
    }
    return out.to_str();
}

fn _normalize_airplane_include_prefixes(text: Str) -> Str {
    return _replace_all(text, "\"tests/golden/traci/scenes/lego/", "\"lego/");
}

fn test_real_include_order() -> unit {
    var cfg: settings.Settings = _new_settings("tests/golden/traci/testcode/a.traci");
    var pre: preprocessor_runner.PreprocessorRunner = preprocessor_runner.PreprocessorRunner(cfg);
    assert_eq_i64(pre.run().code, result.Result.success().code);
    print(pre.get_processed_code());
}

fn test_include_guard_flattens_once() -> unit {
    var cfg: settings.Settings = _new_settings("tests/golden/traci/lang/preprocessor/pp_double_include_root.traci");
    var pre: preprocessor_runner.PreprocessorRunner = preprocessor_runner.PreprocessorRunner(cfg);
    assert_eq_i64(pre.run().code, result.Result.success().code);
    print(pre.get_processed_code());
}

fn test_fast_lego_branch_enabled() -> unit {
    var cfg: settings.Settings = _new_settings("tests/golden/traci/lang/preprocessor/pp_fast_lego_branch.traci");
    cfg.add_preprocessor_macro("FAST_LEGO=1");
    var pre: preprocessor_runner.PreprocessorRunner = preprocessor_runner.PreprocessorRunner(cfg);
    assert_eq_i64(pre.run().code, result.Result.success().code);
    print(pre.get_processed_code());
}

fn test_fast_lego_branch_disabled() -> unit {
    var cfg: settings.Settings = _new_settings("tests/golden/traci/lang/preprocessor/pp_fast_lego_branch.traci");
    cfg.add_preprocessor_macro("FAST_LEGO=0");
    var pre: preprocessor_runner.PreprocessorRunner = preprocessor_runner.PreprocessorRunner(cfg);
    assert_eq_i64(pre.run().code, result.Result.success().code);
    print(pre.get_processed_code());
}

fn test_missing_include_chain() -> unit {
    var cfg: settings.Settings = _new_settings("tests/golden/traci/lang/preprocessor/pp_missing_root.traci");
    var pre: preprocessor_runner.PreprocessorRunner = preprocessor_runner.PreprocessorRunner(cfg);
    assert_eq_i64(pre.run().code, result.Result.preprocessor_error().code);
    assert_eq_u64(pre.get_diagnostics().len(), 1u);
    println(pre.get_diagnostics().get(0).full_msg());
}

fn test_airplane_matches_java_reference() -> unit {
    var cfg: settings.Settings = _new_settings("tests/golden/traci/scenes/lego/airplane.traci");
    var pre: preprocessor_runner.PreprocessorRunner = preprocessor_runner.PreprocessorRunner(cfg);
    assert_eq_i64(pre.run().code, result.Result.success().code);
    print(_normalize_airplane_include_prefixes(pre.get_processed_code()));
}

fn main() -> i64 {
    var args: Str[] = read_program_args();
    if args.len() < 2u {
        fail("test_preprocessor: missing mode argument");
    }

    var mode: Str = args[1];
    if mode.equals("real_include") {
        test_real_include_order();
        return 0;
    }
    if mode.equals("guard") {
        test_include_guard_flattens_once();
        return 0;
    }
    if mode.equals("fast_on") {
        test_fast_lego_branch_enabled();
        return 0;
    }
    if mode.equals("fast_off") {
        test_fast_lego_branch_disabled();
        return 0;
    }
    if mode.equals("missing") {
        test_missing_include_chain();
        return 0;
    }
    if mode.equals("airplane_java_reference") {
        test_airplane_matches_java_reference();
        return 0;
    }

    fail("test_preprocessor: unknown mode");
    return 1;
}
