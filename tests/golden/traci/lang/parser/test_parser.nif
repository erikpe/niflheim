import std.io;
import std.str;
import std.test;
import std.error;
import proj.traci_nif.main.Result as result;
import proj.traci_nif.main.Settings as settings;
import proj.traci_nif.lang.parser.ParserRunner as parser_runner;
import proj.traci_nif.lang.parser.SyntaxNodes;
import proj.traci_nif.lang.preprocessor.PreprocessorRunner as preprocessor_runner;

fn _parse_code(code: Str, filename: Str) -> parser_runner.ParserRunner {
    var cfg: settings.Settings = settings.Settings.mock();
    cfg.set_input_filename(filename);

    var runner: parser_runner.ParserRunner = parser_runner.ParserRunner(cfg, code);
    assert_eq_i64(runner.run().code, result.Result.success().code);
    assert_eq_u64(runner.get_diagnostics().len(), 0u);
    assert_true(runner.get_scene() != null);
    return runner;
}

fn _parse_file(path: Str) -> parser_runner.ParserRunner {
    var cfg: settings.Settings = settings.Settings.mock();
    cfg.set_input_filename(path);

    var runner: parser_runner.ParserRunner = parser_runner.ParserRunner(cfg, null);
    assert_eq_i64(runner.run().code, result.Result.success().code);
    assert_eq_u64(runner.get_diagnostics().len(), 0u);
    assert_true(runner.get_scene() != null);
    return runner;
}

fn _parse_preprocessed_file(path: Str) -> parser_runner.ParserRunner {
    var cfg: settings.Settings = settings.Settings.mock();
    cfg.set_input_filename(path);

    var pre: preprocessor_runner.PreprocessorRunner = preprocessor_runner.PreprocessorRunner(cfg);
    assert_eq_i64(pre.run().code, result.Result.success().code);

    var runner: parser_runner.ParserRunner = parser_runner.ParserRunner(cfg, pre.get_processed_code());
    assert_eq_i64(runner.run().code, result.Result.success().code);
    assert_eq_u64(runner.get_diagnostics().len(), 0u);
    assert_true(runner.get_scene() != null);
    return runner;
}

fn _print_scene_summary(scene_obj: Obj) -> unit {
    var scene: SceneSyntax = (SceneSyntax)scene_obj;
    var out: StrBuf = StrBuf.new(96u);
    out.append("functions=");
    out.append_i64((i64)scene.functions.len());
    out.append("|statements=");
    out.append_i64((i64)scene.statements.len());

    if scene.functions.len() > 0u {
        out.append("|names=");
        var i: i64 = 0;
        while (u64)i < scene.functions.len() {
            if i > 0 {
                out.append(",");
            }
            out.append(((FunctionSyntax)scene.functions[i]).name);
            i = i + 1;
        }
    }

    println(out.to_str());
}

fn _print_scene_edge_summary(scene_obj: Obj) -> unit {
    var scene: SceneSyntax = (SceneSyntax)scene_obj;
    var out: StrBuf = StrBuf.new(96u);
    out.append("functions=");
    out.append_i64((i64)scene.functions.len());
    out.append("|statements=");
    out.append_i64((i64)scene.statements.len());
    if scene.functions.len() > 0u {
        out.append("|first=");
        out.append(((FunctionSyntax)scene.functions[0]).name);
    }
    println(out.to_str());
}

fn test_basic_expression_dump() -> unit {
    var runner: parser_runner.ParserRunner = _parse_code("17+23;", "basic_parser.traci");
    print(dump_scene((Obj)runner.get_scene()));
}

fn test_constructs_dump() -> unit {
    var code: Str = "def outer(n)\n{\n    def inner(x)\n    {\n        return x + 1;\n    }\n    if (n == 0) {\n        return inner(n) {\n            translate [1, 2, 3];\n        };\n    }\n    elif (n < 10) {\n        while (n < 3) {\n            n = n + 1;\n        }\n    }\n    else {\n        for (i in 0 .. n) {\n            global total = color [1, 0.5, 0.25, 1];\n        }\n    }\n    return union {\n        box {\n            scale [1, 2, 3];\n        };\n        translate [4, 5, 6];\n    };\n}\n";

    var runner: parser_runner.ParserRunner = _parse_code(code, "constructs.traci");
    print(dump_scene((Obj)runner.get_scene()));
}

fn test_fibonacci_preprocessed_file_parses() -> unit {
    var runner: parser_runner.ParserRunner = _parse_preprocessed_file("proj/traci_java/testcode/fibonacci.traci");
    _print_scene_summary(runner.get_scene());
}

fn test_prime_checker_file_parses() -> unit {
    var runner: parser_runner.ParserRunner = _parse_file("proj/traci_java/testcode/prime-checker.traci");
    _print_scene_summary(runner.get_scene());
}

fn test_basic_shapes_preprocessed_file_parses() -> unit {
    var runner: parser_runner.ParserRunner = _parse_preprocessed_file("proj/traci_java/scenes/lego/common/basic-shapes.traci");
    _print_scene_edge_summary(runner.get_scene());
}

fn test_missing_semicolon_reports_parse_error() -> unit {
    var cfg: settings.Settings = settings.Settings.mock();
    cfg.set_input_filename("missing_semicolon.traci");

    var runner: parser_runner.ParserRunner = parser_runner.ParserRunner(cfg, "17+23");
    assert_eq_i64(runner.run().code, result.Result.parse_error().code);
    assert_eq_u64(runner.get_diagnostics().len(), 1u);
    println(runner.get_diagnostics().get(0).full_msg());
}

fn main() -> i64 {
    var args: Str[] = read_program_args();
    if args.len() < 2u {
        fail("test_parser: missing mode argument");
    }

    var mode: Str = args[1];
    if mode.equals("basic") {
        test_basic_expression_dump();
        return 0;
    }
    if mode.equals("constructs") {
        test_constructs_dump();
        return 0;
    }
    if mode.equals("fibonacci") {
        test_fibonacci_preprocessed_file_parses();
        return 0;
    }
    if mode.equals("prime") {
        test_prime_checker_file_parses();
        return 0;
    }
    if mode.equals("basic_shapes") {
        test_basic_shapes_preprocessed_file_parses();
        return 0;
    }
    if mode.equals("missing_semicolon") {
        test_missing_semicolon_reports_parse_error();
        return 0;
    }

    fail("test_parser: unknown mode");
    return 1;
}