import std.io;
import std.str;
import std.test;
import std.error;
import proj.traci_nif.main.Result as result;
import proj.traci_nif.main.Settings as settings;
import proj.traci_nif.lang.interpreter.node.AssignNode;
import proj.traci_nif.lang.interpreter.node.BinaryOpNode;
import proj.traci_nif.lang.interpreter.node.BlockNode;
import proj.traci_nif.lang.interpreter.node.ConstNode;
import proj.traci_nif.lang.interpreter.node.FunctionNode;
import proj.traci_nif.lang.interpreter.node.ObjectNode;
import proj.traci_nif.lang.interpreter.node.ReturnNode;
import proj.traci_nif.lang.interpreter.node.TraciNode;
import proj.traci_nif.lang.parser.ParserRunner as parser_runner;
import proj.traci_nif.lang.preprocessor.PreprocessorRunner as preprocessor_runner;

fn _walk_code(code: Str, filename: Str) -> parser_runner.ParserRunner {
    var cfg: settings.Settings = settings.Settings.mock();
    cfg.set_input_filename(filename);

    var runner: parser_runner.ParserRunner = parser_runner.ParserRunner(cfg, code);
    assert_eq_i64(runner.run().code, result.Result.success().code);
    assert_eq_u64(runner.get_diagnostics().len(), 0u);
    assert_true(runner.get_root_node() != null);
    return runner;
}

fn _walk_file(path: Str) -> parser_runner.ParserRunner {
    var cfg: settings.Settings = settings.Settings.mock();
    cfg.set_input_filename(path);

    var runner: parser_runner.ParserRunner = parser_runner.ParserRunner(cfg, null);
    assert_eq_i64(runner.run().code, result.Result.success().code);
    assert_eq_u64(runner.get_diagnostics().len(), 0u);
    assert_true(runner.get_root_node() != null);
    return runner;
}

fn _walk_preprocessed_file(path: Str) -> parser_runner.ParserRunner {
    var cfg: settings.Settings = settings.Settings.mock();
    cfg.set_input_filename(path);

    var pre: preprocessor_runner.PreprocessorRunner = preprocessor_runner.PreprocessorRunner(cfg);
    assert_eq_i64(pre.run().code, result.Result.success().code);

    var runner: parser_runner.ParserRunner = parser_runner.ParserRunner(cfg, pre.get_processed_code());
    assert_eq_i64(runner.run().code, result.Result.success().code);
    assert_eq_u64(runner.get_diagnostics().len(), 0u);
    assert_true(runner.get_root_node() != null);
    return runner;
}

fn _node_kind(node: Obj) -> Str {
    if node is AssignNode { return "AssignNode"; }
    if node is ReturnNode { return "ReturnNode"; }
    if node is BinaryOpNode { return "BinaryOpNode"; }
    if node is ConstNode { return "ConstNode"; }
    if node is ObjectNode { return "ObjectNode"; }
    return "UnknownNode";
}

fn _print_root_summary(root: BlockNode) -> unit {
    var out: StrBuf = StrBuf.new(96u);
    out.append("functions=");
    out.append_i64((i64)root.functions.len());
    out.append("|statements=");
    out.append_i64((i64)root.statements.len());
    if root.functions.len() > 0u {
        out.append("|first_function=");
        out.append(((FunctionNode)root.functions[0]).id);
    }
    if root.statements.len() > 0u {
        out.append("|first_statement=");
        out.append(_node_kind(root.statements[0]));
    }
    println(out.to_str());
}

fn test_tree_walker_basic() -> unit {
    var runner: parser_runner.ParserRunner = _walk_code("17+23;", "basic_tree.traci");
    print(dump_block((Obj)runner.get_root_node()));
}

fn test_tree_walker_string() -> unit {
    var runner: parser_runner.ParserRunner = _walk_code("\"foo/bar.hej\";", "string_tree.traci");
    print(dump_block((Obj)runner.get_root_node()));
}

fn test_tree_walker_constructs() -> unit {
    var code: Str = "def outer(n)\n{\n    def inner(x)\n    {\n        return x + 1;\n    }\n    if (n == 0) {\n        return inner(n) {\n            translate [1, 2, 3];\n        };\n    }\n    elif (n < 10) {\n        while (n < 3) {\n            n = n + 1;\n        }\n    }\n    else {\n        for (i in 0 .. n) {\n            global total = color [1, 0.5, 0.25, 1];\n        }\n    }\n    return union {\n        box {\n            scale [1, 2, 3];\n        };\n        translate [4, 5, 6];\n    };\n}\n";

    var runner: parser_runner.ParserRunner = _walk_code(code, "constructs_tree.traci");
    print(dump_block((Obj)runner.get_root_node()));
}

fn test_tree_walker_fibonacci_preprocessed() -> unit {
    var runner: parser_runner.ParserRunner = _walk_preprocessed_file("tests/golden/traci/testcode/fibonacci.traci");
    _print_root_summary(runner.get_root_node());
}

fn test_tree_walker_prime_checker() -> unit {
    var runner: parser_runner.ParserRunner = _walk_file("tests/golden/traci/testcode/prime-checker.traci");
    _print_root_summary(runner.get_root_node());
}

fn test_tree_walker_basic_shapes_preprocessed() -> unit {
    var runner: parser_runner.ParserRunner = _walk_preprocessed_file("tests/golden/traci/scenes/lego/common/basic-shapes.traci");
    _print_root_summary(runner.get_root_node());
}

fn main() -> i64 {
    var args: Str[] = read_program_args();
    if args.len() < 2u {
        fail("test_tree_walker: missing mode argument");
    }

    var mode: Str = args[1];
    if mode.equals("basic") {
        test_tree_walker_basic();
        return 0;
    }
    if mode.equals("string") {
        test_tree_walker_string();
        return 0;
    }
    if mode.equals("constructs") {
        test_tree_walker_constructs();
        return 0;
    }
    if mode.equals("fibonacci") {
        test_tree_walker_fibonacci_preprocessed();
        return 0;
    }
    if mode.equals("prime") {
        test_tree_walker_prime_checker();
        return 0;
    }
    if mode.equals("basic_shapes") {
        test_tree_walker_basic_shapes_preprocessed();
        return 0;
    }

    fail("test_tree_walker: unknown mode");
    return 1;
}