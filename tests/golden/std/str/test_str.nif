import std.io;
import std.math as math;
import std.str;
import std.test;
import std.vec;


fn test_baseline_get_slice() -> unit {
    var s: Str = "abcd";
    assert_true(s.len() == 4u);
    assert_true(s[0] == 'a');
    assert_true(s[-1] == 'd');

    var mid: Str = s[1:3];
    assert_true(mid.len() == 2u);
    assert_true(mid[0] == 'b');
    assert_true(mid[1] == 'c');
}


fn test_strip() -> unit {
    var s: Str = " \tA\n ";
    var t: Str = s.strip();
    assert_true(t.len() == 1u);
    assert_true(t[0] == 'A');
}


fn test_numeric_parse_ok() -> unit {
    assert_true(("18446744073709551615").to_u64() == 18446744073709551615u);
    assert_true(("-9223372036854775808").to_i64() == -9223372036854775808);
    assert_true(("9223372036854775807").to_i64() == 9223372036854775807);
}


fn test_from_u8_array() -> unit {
    var bytes: u8[] = u8[](3u);
    bytes[0] = 'A';
    bytes[1] = 'B';
    bytes[2] = 'C';

    var s: Str = Str.from_u8_array(bytes);
    bytes[0] = 'Z';
    assert_true(s.len() == 3u);
    assert_true(s[0] == 'A');
    assert_true(s[2] == 'C');
}


fn test_to_u8_array() -> unit {
    var s: Str = "ABC";
    var bytes: u8[] = s.to_u8_array();

    assert_true(bytes.len() == 3u);
    assert_true(bytes[0] == 'A');
    assert_true(bytes[1] == 'B');
    assert_true(bytes[2] == 'C');

    bytes[0] = 'Z';
    assert_true(s[0] == 'A');
}


fn test_strbuf_baseline() -> unit {
    var s: Str = "foobar";
    var buf: StrBuf = StrBuf.from_str(s);

    assert_true(buf.len() == 6u);
    assert_true(buf[0] == 'f');
    assert_true(buf[-1] == 'r');

    buf[2] = 'x';
    assert_true(buf[2] == 'x');

    var mid: StrBuf = buf[1:4];
    assert_true(mid.len() == 3u);
    assert_true(mid[0] == 'o');
    assert_true(mid[1] == 'x');
    assert_true(mid[2] == 'b');

    var out: Str = buf.to_str();
    assert_true(out[0] == 'f');
    assert_true(out[1] == 'o');
    assert_true(out[2] == 'x');
    assert_true(out[3] == 'b');
    assert_true(out[4] == 'a');
    assert_true(out[5] == 'r');
}


fn test_strbuf_get_oob_panics() -> unit {
    var buf: StrBuf = StrBuf.new(0u);
    var c: u8 = buf[0];
}


fn test_strbuf_append_char() -> unit {
    var buf: StrBuf = StrBuf.new(1u);
    buf.append_char('f').append_char('o').append_char('o').append_char('b').append_char('a').append_char('r');

    assert_true(buf.len() == 6u);
    assert_true(buf[0] == 'f');
    assert_true(buf[1] == 'o');
    assert_true(buf[2] == 'o');
    assert_true(buf[3] == 'b');
    assert_true(buf[4] == 'a');
    assert_true(buf[5] == 'r');

    var out: Str = buf.to_str();
    assert_true(out[0] == 'f');
    assert_true(out[1] == 'o');
    assert_true(out[2] == 'o');
    assert_true(out[3] == 'b');
    assert_true(out[4] == 'a');
    assert_true(out[5] == 'r');
}


fn test_strbuf_append() -> unit {
    var buf: StrBuf = StrBuf.new(1u);
    buf.append("foo").append("bar").append("");

    assert_true(buf.len() == 6u);
    var out: Str = buf.to_str();
    assert_true(out.compare_to("foobar") == 0);
}


fn test_strbuf_append_u64() -> unit {
    var buf: StrBuf = StrBuf.new(1u);
    buf.append_u64(0u).append("-").append_u64(42u).append("-").append_u64(18446744073709551615u);

    var out: Str = buf.to_str();
    assert_true(out.compare_to("0-42-18446744073709551615") == 0);
}


fn test_strbuf_append_i64() -> unit {
    var buf: StrBuf = StrBuf.new(1u);
    buf.append_i64(0).append("-").append_i64(-42).append("-").append_i64(9223372036854775807).append("-").append_i64(-9223372036854775808);

    var out: Str = buf.to_str();
    assert_true(out.compare_to("0--42-9223372036854775807--9223372036854775808") == 0);
}


fn test_get_oob_panics() -> unit {
    var s: Str = Str.from_char('A');
    var c: u8 = s[1];
}


fn test_negative_index_get() -> unit {
    var s: Str = "abcdef";
    assert_true(s[-1] == 'f');
    assert_true(s[-2] == 'e');
}


fn test_slice_oob_panics() -> unit {
    var s: Str = "ab";
    var t: Str = s[0:3];
}


fn test_to_u64_invalid_digit_panics() -> unit {
    ("12x").to_u64();
}


fn test_to_i64_overflow_panics() -> unit {
    ("9223372036854775808").to_i64();
}


fn test_merge_to_u64() -> unit {
    assert_true("0".to_u64() == 0u);
    assert_true("1".to_u64() == 1u);
    assert_true("1000000".to_u64() == 1000000u);
    assert_true("18446744073709551615".to_u64() == 18446744073709551615u);
}


fn test_merge_to_i64() -> unit {
    assert_true("0".to_i64() == 0);
    assert_true("1".to_i64() == 1);
    assert_true("-1".to_i64() == -1);
    assert_true("1000000".to_i64() == 1000000);
    assert_true("-1000000".to_i64() == -1000000);
    assert_true("9223372036854775807".to_i64() == 9223372036854775807);
    assert_true("-9223372036854775808".to_i64() == -9223372036854775808);
}


fn test_merge_to_bool() -> unit {
    assert_true("true".to_bool());
    assert_true(!"false".to_bool());
}


fn test_merge_to_bool_invalid_value() -> unit {
    "True".to_bool();
}


fn test_merge_to_bool_empty_string() -> unit {
    "".to_bool();
}


fn test_merge_to_double() -> unit {
    assert_true("0".to_double() == 0.0);
    assert_true("1.5".to_double() == 1.5);
    assert_true("-2.25".to_double() == -2.25);
    assert_true("123456.125".to_double() == 123456.125);
    assert_true(".5".to_double() == 0.5);
    assert_true("42.".to_double() == 42.0);

    var neg_zero: double = "-0.0".to_double();
    assert_true(neg_zero == 0.0);
    var neg_zero_reciprocal: double = 1.0 / neg_zero;
    assert_true(math.is_infinite(neg_zero_reciprocal));
    assert_true(neg_zero_reciprocal < 0.0);

    var nan_val: double = "nan".to_double();
    assert_true(math.is_nan(nan_val));

    var pos_inf: double = "inf".to_double();
    assert_true(math.is_infinite(pos_inf));
    assert_true(pos_inf > 0.0);

    var neg_inf: double = "-inf".to_double();
    assert_true(math.is_infinite(neg_inf));
    assert_true(neg_inf < 0.0);
}


fn test_merge_to_double_invalid_digit() -> unit {
    "12x.5".to_double();
}


fn test_merge_to_double_invalid_format() -> unit {
    "1.2.3".to_double();
}


fn test_merge_to_double_empty_string() -> unit {
    "".to_double();
}


fn test_merge_to_u64_overflow1() -> unit {
    "18446744073709551616".to_u64();
}


fn test_merge_to_u64_overflow2() -> unit {
    "18446744073709551624".to_u64();
}


fn test_merge_to_u64_invalid_digit() -> unit {
    "123x123".to_u64();
}


fn test_merge_to_u64_empty_string() -> unit {
    "".to_u64();
}


fn test_merge_to_i64_overflow1() -> unit {
    "9223372036854775808".to_i64();
}


fn test_merge_to_i64_overflow2() -> unit {
    "9223372036854775811".to_i64();
}


fn test_merge_to_i64_overflow3() -> unit {
    "-9223372036854775809".to_i64();
}


fn test_merge_to_i64_overflow4() -> unit {
    "-9223372036854775811".to_i64();
}


fn test_merge_to_i64_invalid_digit() -> unit {
    "abcd".to_i64();
}


fn test_merge_to_i64_empty_string() -> unit {
    "".to_i64();
}


fn test_merge_e2e_str_from_char() -> unit {
    var s: Str = Str.from_char('Z');
    var c: u8 = s[0];
    assert_true((i64)c == 90);
}


fn test_merge_e2e_str_hex_escape() -> unit {
    var s: Str = "\x41\x42";
    var b: u8 = s[0];
    assert_true((i64)b == 65);
}


fn test_merge_e2e_str_literal_indexing() -> unit {
    var s: Str = "AB\n";
    var b: u8 = s[1];
    assert_true((i64)b == 66);
}


fn test_merge_e2e_str_oob_index_panics() -> unit {
    var v: Str = "Hello world!";
    var c1: u8 = v[-15];
    var c2: u8 = v[15];
    assert_true((i64)c1 + (i64)c2 == 0);
}


fn test_merge_e2e_str_oob_slice_panics() -> unit {
    var v: Str = "Hello world!";
    var s1: Str = v[-15:5];
    var s2: Str = v[15:20];
    assert_true((i64)s1[0] + (i64)s2[0] == 0);
}


fn test_merge_e2e_str_negative_index_and_slice() -> unit {
    var v: Str = "Hello world!";
    var c1: u8 = v[-1];
    var c2: u8 = v[-3];
    var s1: Str = v[:-1];
    var s2: Str = v[-8:8];
    var c3: u8 = s1[-1];
    var c4: u8 = s2[2];
    var sum: i64 = (i64)c1 + (i64)c2 + (i64)c3 + (i64)c4;
    assert_true(sum == 360);
}


fn test_merge_e2e_str_slice_syntax() -> unit {
    var v: Str = "Hello world!";
    var s1: Str = v[3:5];
    var s2: Str = v[:7];
    var s3: Str = v[4:];
    var s4: Str = v[:];
    var c1: u8 = s1[0];
    var c2: u8 = s2[6];
    var c3: u8 = s3[0];
    var c4: u8 = s4[11];
    var sum: i64 = (i64)c1 + (i64)c2 + (i64)c3 + (i64)c4;
    assert_true(sum == 371);
}


fn test_merge_e2e_str_strip_whitespace() -> unit {
    var v: Str = " \tHello world!\n";
    var s: Str = v.strip();
    assert_true(s[0] == (u8)72);
    assert_true(s[-1] == (u8)33);

    var w: Str = " \n\t\r";
    var empty: Str = w.strip();
    assert_true(empty.len() == 0u);
}


fn test_from_u64_edges() -> unit {
    var zero: Str = Str.from_u64(0u);
    assert_true(zero.compare_to("0") == 0);

    var one: Str = Str.from_u64(1u);
    assert_true(one.compare_to("1") == 0);

    var max: Str = Str.from_u64(18446744073709551615u);
    assert_true(max.compare_to("18446744073709551615") == 0);
}


fn test_from_u64_roundtrip() -> unit {
    assert_true(Str.from_u64(0u).to_u64() == 0u);
    assert_true(Str.from_u64(7u).to_u64() == 7u);
    assert_true(Str.from_u64(42u).to_u64() == 42u);
    assert_true(Str.from_u64(1000000000000000000u).to_u64() == 1000000000000000000u);
    assert_true(Str.from_u64(18446744073709551615u).to_u64() == 18446744073709551615u);
}


fn test_compare_to() -> unit {
    assert_true("abc".compare_to("abc") == 0);
    assert_true("abc".compare_to("abd") < 0);
    assert_true("abd".compare_to("abc") > 0);

    assert_true("ab".compare_to("abc") == -99);
    assert_true("abc".compare_to("ab") == 99);
    assert_true("A".compare_to("a") == -32);
}


fn test_from_i64_edges() -> unit {
    assert_true(Str.from_i64(0).compare_to("0") == 0);
    assert_true(Str.from_i64(1).compare_to("1") == 0);
    assert_true(Str.from_i64(-1).compare_to("-1") == 0);
    assert_true(Str.from_i64(9223372036854775807).compare_to("9223372036854775807") == 0);
    assert_true(Str.from_i64(-9223372036854775808).compare_to("-9223372036854775808") == 0);
    assert_true(Str.from_i64(-9223372036854775807).compare_to("-9223372036854775807") == 0);
}


fn test_from_i64_roundtrip() -> unit {
    assert_true(Str.from_i64(0).to_i64() == 0);
    assert_true(Str.from_i64(7).to_i64() == 7);
    assert_true(Str.from_i64(-7).to_i64() == -7);
    assert_true(Str.from_i64(1234567890123456789).to_i64() == 1234567890123456789);
    assert_true(Str.from_i64(-1234567890123456789).to_i64() == -1234567890123456789);
    assert_true(Str.from_i64(9223372036854775807).to_i64() == 9223372036854775807);
    assert_true(Str.from_i64(-9223372036854775808).to_i64() == -9223372036854775808);
}


fn test_from_misc_scalars() -> unit {
    assert_true(Str.from_u8(0u8).compare_to("0") == 0);
    assert_true(Str.from_u8(255u8).compare_to("255") == 0);

    assert_true(Str.from_bool(true).compare_to("true") == 0);
    assert_true(Str.from_bool(false).compare_to("false") == 0);
    assert_true(Str.from_bool(true).to_bool());
    assert_true(!Str.from_bool(false).to_bool());

    assert_true(Str.from_double(0.0).compare_to("0.000000") == 0);
    assert_true(Str.from_double(1.5).compare_to("1.500000") == 0);
    assert_true(Str.from_double(-2.25).compare_to("-2.250000") == 0);
    assert_true(Str.from_double(123456.125).compare_to("123456.125000") == 0);
    assert_true(Str.from_double(1.5).to_double() == 1.5);
}


fn test_strbuf_append_scalars() -> unit {
    var buf: StrBuf = StrBuf.new(1u);
    buf.append_u8(255u8)
        .append("|")
        .append_bool(true)
        .append("|")
        .append_bool(false)
        .append("|")
        .append_double(-2.25);

    var out: Str = buf.to_str();
    assert_true(out.compare_to("255|true|false|-2.250000") == 0);
}


fn test_splitlines() -> unit {
    var lines1: Vec = "a\nb\r\nc\n".splitlines();
    assert_true(lines1.len() == 3u);
    assert_true(((Str)lines1[0]).compare_to("a") == 0);
    assert_true(((Str)lines1[1]).compare_to("b") == 0);
    assert_true(((Str)lines1[2]).compare_to("c") == 0);

    var lines2: Vec = "x\r\ny".splitlines();
    assert_true(lines2.len() == 2u);
    assert_true(((Str)lines2[0]).compare_to("x") == 0);
    assert_true(((Str)lines2[1]).compare_to("y") == 0);

    var lines3: Vec = "p\rq".splitlines();
    assert_true(lines3.len() == 2u);
    assert_true(((Str)lines3[0]).compare_to("p") == 0);
    assert_true(((Str)lines3[1]).compare_to("q") == 0);

    var lines4: Vec = "\r\na\r\rb\n\n".splitlines();
    assert_true(lines4.len() == 5u);
    assert_true(((Str)lines4[0]).compare_to("") == 0);
    assert_true(((Str)lines4[1]).compare_to("a") == 0);
    assert_true(((Str)lines4[2]).compare_to("") == 0);
    assert_true(((Str)lines4[3]).compare_to("b") == 0);
    assert_true(((Str)lines4[4]).compare_to("") == 0);
}


fn test_split_trailing_delimiter() -> unit {
    var parts0: Vec = "".split(',');
    assert_true(parts0.len() == 1u);
    assert_true(((Str)parts0[0]).compare_to("") == 0);

    var parts1: Vec = "a,b,".split(',');
    assert_true(parts1.len() == 3u);
    assert_true(((Str)parts1[0]).compare_to("a") == 0);
    assert_true(((Str)parts1[1]).compare_to("b") == 0);
    assert_true(((Str)parts1[2]).compare_to("") == 0);

    var parts2: Vec = ",".split(',');
    assert_true(parts2.len() == 2u);
    assert_true(((Str)parts2[0]).compare_to("") == 0);
    assert_true(((Str)parts2[1]).compare_to("") == 0);

    var parts3: Vec = "x,,".split(',');
    assert_true(parts3.len() == 3u);
    assert_true(((Str)parts3[0]).compare_to("x") == 0);
    assert_true(((Str)parts3[1]).compare_to("") == 0);
    assert_true(((Str)parts3[2]).compare_to("") == 0);
}


fn test_concat_operator() -> unit {
    var merged: Str = "hello, " + "world";
    assert_true(merged.compare_to("hello, world") == 0);

    var left: Str = "x";
    var right: Str = "";
    assert_true((left + right).compare_to("x") == 0);

    var chain: Str = "a" + "b" + "c";
    assert_true(chain.compare_to("abc") == 0);
}


fn test_str_for_in_iteration() -> unit {
    var s: Str = "Ab0";
    var sum: i64 = 0;

    for ch in s {
        sum = sum + (i64)ch;
    }

    assert_true(sum == 211);
}


fn test_strbuf_for_in_iteration() -> unit {
    var buf: StrBuf = StrBuf.new(1u);
    buf.append("Hi!");

    var sum: i64 = 0;
    for ch in buf {
        sum = sum + (i64)ch;
    }

    assert_true(sum == 210);
}


fn test_hash_code_equal_content() -> unit {
    var a: Str = "hash-me";
    var b: Str = Str.from_u8_array("hash-me".to_u8_array());
    var c: Str = "hash-you";

    assert_true(a.hash_code() == b.hash_code());
    assert_true(a.hash_code() != c.hash_code());
}


fn test_equals_obj() -> unit {
    var a: Str = "same";
    var b: Str = Str.from_u8_array("same".to_u8_array());
    var c: Str = "diff";
    var boxed_other: Obj = (Obj)Vec.new();

    assert_true(a.equals((Obj)a));
    assert_true(a.equals((Obj)b));
    assert_true(!a.equals((Obj)c));
    assert_true(!a.equals(null));
    assert_true(!a.equals(boxed_other));
}


fn main() -> i64 {
    var select: u64 = read_stdin().strip().to_u64();

    if select == 1u { test_baseline_get_slice(); }
    if select == 2u { test_strip(); }
    if select == 3u { test_numeric_parse_ok(); }
    if select == 4u { test_from_u8_array(); }
    if select == 5u { test_get_oob_panics(); }
    if select == 6u { test_negative_index_get(); }
    if select == 7u { test_slice_oob_panics(); }
    if select == 8u { test_to_u64_invalid_digit_panics(); }
    if select == 9u { test_to_i64_overflow_panics(); }
    if select == 10u { test_strbuf_baseline(); }
    if select == 11u { test_strbuf_get_oob_panics(); }
    if select == 12u { test_strbuf_append_char(); }
    if select == 13u { test_merge_to_u64(); test_merge_to_i64(); }
    if select == 14u { test_merge_to_u64_overflow1(); }
    if select == 15u { test_merge_to_u64_overflow2(); }
    if select == 16u { test_merge_to_u64_invalid_digit(); }
    if select == 17u { test_merge_to_u64_empty_string(); }
    if select == 18u { test_merge_to_i64_overflow1(); }
    if select == 19u { test_merge_to_i64_overflow2(); }
    if select == 20u { test_merge_to_i64_overflow3(); }
    if select == 21u { test_merge_to_i64_overflow4(); }
    if select == 22u { test_merge_to_i64_invalid_digit(); }
    if select == 23u { test_merge_to_i64_empty_string(); }
    if select == 24u { test_merge_to_bool(); }
    if select == 25u { test_merge_to_bool_invalid_value(); }
    if select == 26u { test_merge_to_bool_empty_string(); }
    if select == 27u { test_merge_to_double(); }
    if select == 28u { test_merge_to_double_invalid_digit(); }
    if select == 29u { test_merge_to_double_invalid_format(); }
    if select == 30u { test_merge_to_double_empty_string(); }
    if select == 31u { test_merge_e2e_str_from_char(); }
    if select == 32u { test_merge_e2e_str_hex_escape(); }
    if select == 33u { test_merge_e2e_str_literal_indexing(); }
    if select == 34u { test_merge_e2e_str_oob_index_panics(); }
    if select == 35u { test_merge_e2e_str_oob_slice_panics(); }
    if select == 36u { test_merge_e2e_str_negative_index_and_slice(); }
    if select == 37u { test_merge_e2e_str_slice_syntax(); }
    if select == 38u { test_merge_e2e_str_strip_whitespace(); }
    if select == 39u { test_from_u64_edges(); }
    if select == 40u { test_from_u64_roundtrip(); }
    if select == 41u { test_compare_to(); }
    if select == 42u { test_from_i64_edges(); }
    if select == 43u { test_from_i64_roundtrip(); }
    if select == 44u { test_strbuf_append(); }
    if select == 45u { test_strbuf_append_u64(); }
    if select == 46u { test_strbuf_append_i64(); }
    if select == 47u { test_to_u8_array(); }
    if select == 48u { test_from_misc_scalars(); }
    if select == 49u { test_strbuf_append_scalars(); }
    if select == 50u { test_splitlines(); }
    if select == 51u { test_str_for_in_iteration(); }
    if select == 52u { test_strbuf_for_in_iteration(); }
    if select == 53u { test_hash_code_equal_content(); }
    if select == 54u { test_equals_obj(); }
    if select == 55u { test_split_trailing_delimiter(); }
    if select == 56u { test_concat_operator(); }
    return 0;
}
