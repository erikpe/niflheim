import std.test;
import std.lang;
import std.map;
import std.box;
import std.io;
import std.str;
import std.range;

class Key implements Hashable, Equalable {
    raw: u64;

    fn hash_code() -> u64 {
        return __self.raw * 11400714819323198485u;
    }

    fn equals(other: Obj) -> bool {
        if other == null {
            return false;
        }
        return ((Key)other).raw == __self.raw;
    }
}

class Plain {
    raw: u64;
}

class HashOnly implements Hashable {
    raw: u64;

    fn hash_code() -> u64 {
        return __self.raw * 11400714819323198485u;
    }
}

fn test_map_put_get_contains() -> unit {
    var m: Map = Map.new();
    assert(m.len() == 0u);

    m[(Obj)Key(10u)] = BoxI64(111);
    m[(Obj)Key(20u)] = BoxI64(222);

    assert(m.len() == 2u);
    assert(m.contains((Obj)Key(10u)));
    assert(m.contains((Obj)Key(20u)));
    assert(!m.contains((Obj)Key(30u)));

    assert(((BoxI64)m[(Obj)Key(10u)]).val == 111);
    assert(((BoxI64)m[(Obj)Key(20u)]).val == 222);
}

fn test_map_overwrite_same_logical_key() -> unit {
    var m: Map = Map.new();
    m[(Obj)Key(7u)] = BoxI64(1);
    m[(Obj)Key(7u)] = BoxI64(9);

    assert(m.len() == 1u);
    assert(((BoxI64)m[(Obj)Key(7u)]).val == 9);
}

fn test_map_growth_and_probe_chains() -> unit {
    var m: Map = Map.with_capacity(2u);

    for build_i in Range(0, 80) {
        var idx: u64 = (u64)build_i;
        var key: Obj = (Obj)Key(idx * 17u + 3u);
        m[key] = BoxU64(idx);
    }

    assert(m.len() == 80u);

    for verify_i in Range(0, 80) {
        var verify_idx: u64 = (u64)verify_i;
        var verify_key: Obj = (Obj)Key(verify_idx * 17u + 3u);
        assert(m.contains(verify_key));
        assert(((BoxU64)m[verify_key]).val == verify_idx);
    }
}

fn test_map_index_sugar_write_and_read() -> unit {
    var m: Map = Map.new();

    m[(Obj)Key(1u)] = BoxI64(42);
    m[(Obj)Key(2u)] = BoxI64(99);

    assert(((BoxI64)m[(Obj)Key(1u)]).val == 42);
    assert(((BoxI64)m[(Obj)Key(2u)]).val == 99);
    assert(m.len() == 2u);
}

fn test_map_null_key_panics() -> unit {
    var m: Map = Map.new();
    m[null] = BoxI64(5);
}

fn test_map_get_missing_panics() -> unit {
    var m: Map = Map.new();
    var v: Obj = m[(Obj)Key(999u)];
}

fn test_map_str_keys_under_load() -> unit {
    var m: Map = Map.with_capacity(4u);
    var count: i64 = 1200;

    for insert_i in Range(0, count) {
        var k: Str = Str.from_i64(insert_i);
        m[(Obj)k] = BoxU64((u64)insert_i * 3u + 1u);
    }

    assert(m.len() == (u64)count);

    for lookup_i in Range(0, count) {
        var lookup: Str = Str.from_i64(lookup_i);
        assert(m.contains((Obj)lookup));
        assert(((BoxU64)m[(Obj)lookup]).val == (u64)lookup_i * 3u + 1u);
    }

    for rewrite_i in Range(0, count) {
        var rewrite: Str = Str.from_i64(rewrite_i);
        m[(Obj)rewrite] = BoxU64((u64)rewrite_i + 1000u);
    }

    assert(m.len() == (u64)count);

    for check_i in Range(0, count) {
        var check: Str = Str.from_i64(check_i);
        assert(((BoxU64)m[(Obj)check]).val == (u64)check_i + 1000u);
    }

    assert(!m.contains((Obj)"missing"));
}

fn test_map_non_hashable_key_panics() -> unit {
    var m: Map = Map.new();
    m[(Obj)Plain(7u)] = BoxI64(1);
}

fn test_map_non_equalable_key_panics() -> unit {
    var m: Map = Map.new();
    m[(Obj)HashOnly(7u)] = BoxI64(1);
    var v: Obj = m[(Obj)HashOnly(7u)];
}

fn main() -> i64 {
    var select: u64 = read_stdin().strip().to_u64();

    if select == 1u { test_map_put_get_contains(); }
    if select == 2u { test_map_overwrite_same_logical_key(); }
    if select == 3u { test_map_growth_and_probe_chains(); }
    if select == 4u { test_map_index_sugar_write_and_read(); }
    if select == 5u { test_map_null_key_panics(); }
    if select == 6u { test_map_get_missing_panics(); }
    if select == 7u { test_map_str_keys_under_load(); }
    if select == 8u { test_map_non_hashable_key_panics(); }
    if select == 9u { test_map_non_equalable_key_panics(); }

    return 0;
}
