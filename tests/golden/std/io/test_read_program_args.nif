import std.io;
import std.str;

fn main() -> i64 {
    var args: Str[] = read_program_args();
    println_u64(args.len());

    if args.len() > 1u {
        println(args[1]);
    }
    if args.len() > 2u {
        println(args[2]);
    }
    if args.len() > 3u {
        println(args[3]);
    }

    return 0;
}
