import std.test;
import std.io;
import std.object;
import std.str;
import std.vec;
import std.box;


fn test_same_type_str_instances() -> unit {
    var a: Obj = (Obj)"hello";
    var b: Obj = (Obj)Str.from_u8_array("world".to_u8_array());
    assert(same_type(a, b));
}


fn test_different_type_str_vs_vec() -> unit {
    var s: Obj = (Obj)"hello";
    var v: Obj = (Obj)Vec.new();
    assert(!same_type(s, v));
}


fn test_null_behavior() -> unit {
    var s: Obj = (Obj)"hello";
    assert(!same_type(null, s));
    assert(!same_type(s, null));
    assert(!same_type(null, null));
}


fn test_array_type_matching() -> unit {
    var a1: i64[] = i64[](2u);
    var a2: u8[] = u8[](1u);
    var r: Obj[] = Obj[](2u);

    assert(same_type((Obj)a1, (Obj)a2));
    assert(!same_type((Obj)a1, (Obj)r));
}


fn test_box_type_matching() -> unit {
    var i1: Obj = (Obj)BoxI64(1);
    var i2: Obj = (Obj)BoxI64(2);
    var u: Obj = (Obj)BoxU64(1u);

    assert(same_type(i1, i2));
    assert(!same_type(i1, u));
}


fn main() -> i64 {
    var select: u64 = read_all().strip().to_u64();

    if select == 1u { test_same_type_str_instances(); }
    if select == 2u { test_different_type_str_vs_vec(); }
    if select == 3u { test_null_behavior(); }
    if select == 4u { test_array_type_matching(); }
    if select == 5u { test_box_type_matching(); }

    return 0;
}
