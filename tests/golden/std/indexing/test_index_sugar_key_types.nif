import std.test;

class FlagMap {
    yes: i64;
    no: i64;

    fn index_get(key: bool) -> i64 {
        if key {
            return __self.yes;
        }
        return __self.no;
    }

    fn index_set(key: bool, value: i64) -> unit {
        if key {
            __self.yes = value;
            return;
        }
        __self.no = value;
    }
}

class WeirdStore {
    stored: bool;

    fn index_get(index: i64) -> bool {
        return __self.stored;
    }

    fn index_set(index: i64, value: i64) -> unit {
        __self.stored = value > 0;
    }
}

class SplitKey {
    value: i64;

    fn index_get(flag: bool) -> i64 {
        if flag {
            return __self.value;
        }
        return 0;
    }

    fn index_set(index: i64, value: i64) -> unit {
        if index == 0 {
            __self.value = value;
        }
    }
}

class ReadOnlyIndex {
    value: i64;

    fn index_get(index: i64) -> i64 {
        if index == 0 {
            return __self.value;
        }
        return -1;
    }
}

class WriteOnlyIndex {
    value: i64;

    fn index_set(index: i64, value: i64) -> unit {
        if index == 0 {
            __self.value = value;
        }
    }

    fn reveal() -> i64 {
        return __self.value;
    }
}

class SliceWindow {
    values: i64[];

    static fn from_three(a: i64, b: i64, c: i64) -> SliceWindow {
        var data: i64[] = i64[](3u);
        data[0] = a;
        data[1] = b;
        data[2] = c;
        return SliceWindow(data);
    }

    fn len() -> u64 {
        return __self.values.len();
    }

    fn index_get(index: i64) -> i64 {
        return __self.values[index];
    }

    fn slice_set(begin: i64, end: i64, value: SliceWindow) -> unit {
        var i: i64 = 0;
        while begin + i < end {
            __self.values[begin + i] = value.values[i];
            i = i + 1;
        }
    }
}

class SliceBoolFlag {
    value: bool;

    fn slice_set(begin: i64, end: i64, value: bool) -> unit {
        __self.value = value;
    }

    fn index_get() -> bool {
        return __self.value;
    }
}

fn main() -> i64 {
    var m: FlagMap = FlagMap(10, 20);
    assert(m[true] == 10);
    assert(m[false] == 20);

    m[false] = 99;
    assert(m[false] == 99);

    var w: WeirdStore = WeirdStore(false);
    assert(w[0] == false);
    w[0] = 7;
    assert(w[0] == true);
    w[0] = -1;
    assert(w[0] == false);

    var s: SplitKey = SplitKey(5);
    assert(s[true] == 5);
    s[0] = 42;
    assert(s[true] == 42);

    var ro: ReadOnlyIndex = ReadOnlyIndex(77);
    assert(ro[0] == 77);

    var wo: WriteOnlyIndex = WriteOnlyIndex(0);
    wo[0] = 123;
    assert(wo.reveal() == 123);

    var sw: SliceWindow = SliceWindow.from_three(1, 2, 3);
    var repl: SliceWindow = SliceWindow.from_three(9, 8, 7);
    sw[1:3] = repl;
    assert(sw[0] == 1);
    assert(sw[1] == 9);
    assert(sw[2] == 8);

    var sb: SliceBoolFlag = SliceBoolFlag(false);
    sb[0:0] = true;
    assert(sb.index_get() == true);
    sb[1:2] = false;
    assert(sb.index_get() == false);

    return 0;
}
