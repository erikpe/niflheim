import std.test;
import std.io;
import std.vec;
import std.box;
import std.error;


class VisitBox {
    value: i64;
    keep: bool;
    seen: bool;
}


fn is_even_box(value: Obj) -> bool {
    return (((BoxI64)value).val % 2) != 0;
}


fn is_negative_box(value: Obj) -> bool {
    return ((BoxI64)value).val >= 0;
}


fn keep_visit_box_once(value: Obj) -> bool {
    var item: VisitBox = (VisitBox)value;
    if item.seen {
        panic("filter called predicate twice for same element");
    }
    item.seen = true;
    return item.keep;
}


fn double_box_i64(value: Obj) -> Obj {
    return BoxI64(((BoxI64)value).val * 2);
}


fn sum_box_i64(acc: Obj, value: Obj) -> Obj {
    return BoxI64(((BoxI64)acc).val + ((BoxI64)value).val);
}


fn test_vec_baseline() -> unit {
    var v: Vec = Vec.new();
    assert_eq_u64(v.len(), 0u);

    v.push(BoxI64(10));
    v.push(BoxI64(20));
    assert_eq_u64(v.len(), 2u);

    var first: i64 = ((BoxI64)v[0]).val;
    var second: i64 = ((BoxI64)v[1]).val;
    assert_eq_i64(first, 10);
    assert_eq_i64(second, 20);

    v[1] = BoxI64(99);
    assert_eq_i64(((BoxI64)v[1]).val, 99);
}


fn test_vec_index_sugar_with_wrapping_negative_indexes() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(10));
    v.push(BoxI64(20));
    v.push(BoxI64(30));
    v.push(BoxI64(40));

    assert_eq_i64(((BoxI64)v[-1]).val, 40);
    assert_eq_i64(((BoxI64)v[-4]).val, 10);

    v[-1] = BoxI64(99);
    assert_eq_i64(((BoxI64)v[3]).val, 99);

    v[-4] = BoxI64(77);
    assert_eq_i64(((BoxI64)v[0]).val, 77);
}


fn test_vec_slice_sugar_forms_and_negative_wrapping() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(10));
    v.push(BoxI64(20));
    v.push(BoxI64(30));
    v.push(BoxI64(40));

    var a: Vec = v[1:3];
    assert_eq_u64(a.len(), 2u);
    assert_eq_i64(((BoxI64)a[0]).val, 20);
    assert_eq_i64(((BoxI64)a[1]).val, 30);

    var b: Vec = v[:2];
    assert_eq_u64(b.len(), 2u);
    assert_eq_i64(((BoxI64)b[0]).val, 10);
    assert_eq_i64(((BoxI64)b[1]).val, 20);

    var c: Vec = v[2:];
    assert_eq_u64(c.len(), 2u);
    assert_eq_i64(((BoxI64)c[0]).val, 30);
    assert_eq_i64(((BoxI64)c[1]).val, 40);

    var d: Vec = v[:];
    assert_eq_u64(d.len(), 4u);
    assert_eq_i64(((BoxI64)d[0]).val, 10);
    assert_eq_i64(((BoxI64)d[3]).val, 40);

    var e: Vec = v[-3:-1];
    assert_eq_u64(e.len(), 2u);
    assert_eq_i64(((BoxI64)e[0]).val, 20);
    assert_eq_i64(((BoxI64)e[1]).val, 30);

    var f: Vec = v[:-1];
    assert_eq_u64(f.len(), 3u);
    assert_eq_i64(((BoxI64)f[0]).val, 10);
    assert_eq_i64(((BoxI64)f[2]).val, 30);

    var g: Vec = v[-2:];
    assert_eq_u64(g.len(), 2u);
    assert_eq_i64(((BoxI64)g[0]).val, 30);
    assert_eq_i64(((BoxI64)g[1]).val, 40);
}


fn test_vec_slice_copy_independence() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(10));
    v.push(BoxI64(20));
    v.push(BoxI64(30));

    var s: Vec = v[1:3];
    assert_eq_u64(s.len(), 2u);
    assert_eq_i64(((BoxI64)s[0]).val, 20);
    assert_eq_i64(((BoxI64)s[1]).val, 30);

    v[1] = BoxI64(99);
    assert_eq_i64(((BoxI64)s[0]).val, 20);
}


fn test_vec_grow_and_copy() -> unit {
    var v: Vec = Vec.with_capacity(1u);
    var i: i64 = 0;
    while i < 20 {
        v.push(BoxI64(i));
        i = i + 1;
    }

    assert_eq_u64(v.len(), 20u);
    assert_eq_i64(((BoxI64)v[0]).val, 0);
    assert_eq_i64(((BoxI64)v[19]).val, 19);
}


fn test_vec_get_oob_panics() -> unit {
    var v: Vec = Vec.new();
    var x: Obj = v[0];
}


fn test_vec_set_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v[0] = BoxI64(1);
}


fn test_vec_get_negative_wrap_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(1));
    v.push(BoxI64(2));
    var x: Obj = v[-3];
}


fn test_vec_set_negative_wrap_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(1));
    v.push(BoxI64(2));
    v[-3] = BoxI64(7);
}


fn test_vec_slice_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(1));
    v[0:2];
}


fn test_vec_slice_negative_begin_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(1));
    v.push(BoxI64(2));
    v[-3:1];
}


fn test_vec_slice_negative_end_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(1));
    v.push(BoxI64(2));
    v[0:-3];
}


fn test_vec_slice_reversed_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(1));
    v.push(BoxI64(2));
    v[2:1];
}


fn test_vec_with_capacity_zero_is_allowed() -> unit {
    var v: Vec = Vec.with_capacity(0u);
    assert_eq_u64(v.len(), 0u);
    v.push(BoxI64(7));
    assert_eq_u64(v.len(), 1u);
    assert_eq_i64(((BoxI64)v[0]).val, 7);
}


fn test_vec_slice_write_sugar_updates_range() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(10));
    v.push(BoxI64(20));
    v.push(BoxI64(30));
    v.push(BoxI64(40));

    var repl: Vec = Vec.new();
    repl.push(BoxI64(7));
    repl.push(BoxI64(8));

    v[1:3] = repl;
    assert_eq_i64(((BoxI64)v[0]).val, 10);
    assert_eq_i64(((BoxI64)v[1]).val, 7);
    assert_eq_i64(((BoxI64)v[2]).val, 8);
    assert_eq_i64(((BoxI64)v[3]).val, 40);
}


fn test_vec_slice_write_length_mismatch_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(10));
    v.push(BoxI64(20));
    v.push(BoxI64(30));

    var repl: Vec = Vec.new();
    repl.push(BoxI64(99));

    v[0:2] = repl;
}


fn test_vec_slice_write_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(10));
    var repl: Vec = Vec.new();
    repl.push(BoxI64(77));
    v[0:2] = repl;
}


fn test_vec_for_in_iteration() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(3));
    v.push(BoxI64(5));
    v.push(BoxI64(-2));

    var sum: i64 = 0;
    for elem in v {
        sum = sum + ((BoxI64)elem).val;
    }

    assert_eq_i64(sum, 6);
}


fn test_vec_map_returns_transformed_copy() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(2));
    v.push(BoxI64(-3));
    v.push(BoxI64(5));

    var out: Vec = v.map(double_box_i64);

    assert_eq_u64(v.len(), 3u);
    assert_eq_u64(out.len(), 3u);
    assert_eq_i64(((BoxI64)v[0]).val, 2);
    assert_eq_i64(((BoxI64)v[1]).val, -3);
    assert_eq_i64(((BoxI64)v[2]).val, 5);
    assert_eq_i64(((BoxI64)out[0]).val, 4);
    assert_eq_i64(((BoxI64)out[1]).val, -6);
    assert_eq_i64(((BoxI64)out[2]).val, 10);
}


fn test_vec_reduce_accumulates_values() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(4));
    v.push(BoxI64(-1));
    v.push(BoxI64(7));

    var out: Obj = v.reduce(sum_box_i64, BoxI64(10));

    assert_eq_i64(((BoxI64)out).val, 20);
}


fn test_vec_clear_resets_length_and_allows_reuse() -> unit {
    var v: Vec = Vec.with_capacity(16u);
    v.push(BoxI64(1));
    v.push(BoxI64(2));
    v.push(BoxI64(3));

    v.clear();

    assert_eq_u64(v.len(), 0u);

    v.push(BoxI64(9));
    assert_eq_u64(v.len(), 1u);
    assert_eq_i64(((BoxI64)v[0]).val, 9);
}


fn test_vec_filter_copies_kept_runs() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(1));
    v.push(BoxI64(2));
    v.push(BoxI64(4));
    v.push(BoxI64(3));
    v.push(BoxI64(5));
    v.push(BoxI64(6));
    v.push(BoxI64(8));
    v.push(BoxI64(7));

    var out: Vec = v.filter(is_even_box);

    assert_eq_u64(v.len(), 8u);
    assert_eq_u64(out.len(), 4u);
    assert_eq_i64(((BoxI64)out[0]).val, 1);
    assert_eq_i64(((BoxI64)out[1]).val, 3);
    assert_eq_i64(((BoxI64)out[2]).val, 5);
    assert_eq_i64(((BoxI64)out[3]).val, 7);
}


fn test_vec_filter_all_removed() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(-1));
    v.push(BoxI64(-2));
    v.push(BoxI64(-3));

    var out: Vec = v.filter(is_negative_box);

    assert_eq_u64(v.len(), 3u);
    assert_eq_u64(out.len(), 0u);
}


fn test_vec_filter_calls_predicate_once_per_element() -> unit {
    var v: Vec = Vec.new();
    v.push(VisitBox(1, true, false));
    v.push(VisitBox(2, false, false));
    v.push(VisitBox(3, true, false));
    v.push(VisitBox(4, true, false));
    v.push(VisitBox(5, false, false));

    var out: Vec = v.filter(keep_visit_box_once);

    assert_eq_u64(v.len(), 5u);
    assert_eq_u64(out.len(), 3u);
    assert(((VisitBox)v[0]).seen);
    assert(((VisitBox)v[1]).seen);
    assert(((VisitBox)v[2]).seen);
    assert(((VisitBox)v[3]).seen);
    assert(((VisitBox)v[4]).seen);
    assert_eq_i64(((VisitBox)out[0]).value, 1);
    assert_eq_i64(((VisitBox)out[1]).value, 3);
    assert_eq_i64(((VisitBox)out[2]).value, 4);
}


fn main() -> i64 {
    var select: u64 = read_stdin().strip().to_u64();

    if select == 1u { test_vec_baseline(); }
    if select == 2u { test_vec_index_sugar_with_wrapping_negative_indexes(); }
    if select == 3u { test_vec_slice_sugar_forms_and_negative_wrapping(); }
    if select == 4u { test_vec_slice_copy_independence(); }
    if select == 5u { test_vec_grow_and_copy(); }
    if select == 6u { test_vec_get_oob_panics(); }
    if select == 7u { test_vec_set_oob_panics(); }
    if select == 8u { test_vec_get_negative_wrap_oob_panics(); }
    if select == 9u { test_vec_set_negative_wrap_oob_panics(); }
    if select == 10u { test_vec_slice_oob_panics(); }
    if select == 11u { test_vec_slice_negative_begin_oob_panics(); }
    if select == 12u { test_vec_slice_negative_end_oob_panics(); }
    if select == 13u { test_vec_slice_reversed_panics(); }
    if select == 14u { test_vec_with_capacity_zero_is_allowed(); }
    if select == 15u { test_vec_slice_write_sugar_updates_range(); }
    if select == 16u { test_vec_slice_write_length_mismatch_panics(); }
    if select == 17u { test_vec_slice_write_oob_panics(); }
    if select == 18u { test_vec_for_in_iteration(); }
    if select == 19u { test_vec_filter_copies_kept_runs(); }
    if select == 20u { test_vec_filter_all_removed(); }
    if select == 21u { test_vec_filter_calls_predicate_once_per_element(); }
    if select == 22u { test_vec_map_returns_transformed_copy(); }
    if select == 23u { test_vec_reduce_accumulates_values(); }
    if select == 24u { test_vec_clear_resets_length_and_allows_reuse(); }

    return 0;
}
