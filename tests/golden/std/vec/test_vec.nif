import std.test;
import std.io;
import std.vec;
import std.box;


fn test_vec_baseline() -> unit {
    var v: Vec = Vec.new();
    assert(v.len() == 0u);

    v.push(BoxI64(10));
    v.push(BoxI64(20));
    assert(v.len() == 2u);

    var first: i64 = ((BoxI64)v[0]).val;
    var second: i64 = ((BoxI64)v[1]).val;
    assert(first == 10);
    assert(second == 20);

    v[1] = BoxI64(99);
    assert(((BoxI64)v[1]).val == 99);
}


fn test_vec_index_sugar_with_wrapping_negative_indexes() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(10));
    v.push(BoxI64(20));
    v.push(BoxI64(30));
    v.push(BoxI64(40));

    assert(((BoxI64)v[-1]).val == 40);
    assert(((BoxI64)v[-4]).val == 10);

    v[-1] = BoxI64(99);
    assert(((BoxI64)v[3]).val == 99);

    v[-4] = BoxI64(77);
    assert(((BoxI64)v[0]).val == 77);
}


fn test_vec_slice_sugar_forms_and_negative_wrapping() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(10));
    v.push(BoxI64(20));
    v.push(BoxI64(30));
    v.push(BoxI64(40));

    var a: Vec = v[1:3];
    assert(a.len() == 2u);
    assert(((BoxI64)a[0]).val == 20);
    assert(((BoxI64)a[1]).val == 30);

    var b: Vec = v[:2];
    assert(b.len() == 2u);
    assert(((BoxI64)b[0]).val == 10);
    assert(((BoxI64)b[1]).val == 20);

    var c: Vec = v[2:];
    assert(c.len() == 2u);
    assert(((BoxI64)c[0]).val == 30);
    assert(((BoxI64)c[1]).val == 40);

    var d: Vec = v[:];
    assert(d.len() == 4u);
    assert(((BoxI64)d[0]).val == 10);
    assert(((BoxI64)d[3]).val == 40);

    var e: Vec = v[-3:-1];
    assert(e.len() == 2u);
    assert(((BoxI64)e[0]).val == 20);
    assert(((BoxI64)e[1]).val == 30);

    var f: Vec = v[:-1];
    assert(f.len() == 3u);
    assert(((BoxI64)f[0]).val == 10);
    assert(((BoxI64)f[2]).val == 30);

    var g: Vec = v[-2:];
    assert(g.len() == 2u);
    assert(((BoxI64)g[0]).val == 30);
    assert(((BoxI64)g[1]).val == 40);
}


fn test_vec_slice_copy_independence() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(10));
    v.push(BoxI64(20));
    v.push(BoxI64(30));

    var s: Vec = v[1:3];
    assert(s.len() == 2u);
    assert(((BoxI64)s[0]).val == 20);
    assert(((BoxI64)s[1]).val == 30);

    v[1] = BoxI64(99);
    assert(((BoxI64)s[0]).val == 20);
}


fn test_vec_grow_and_copy() -> unit {
    var v: Vec = Vec.with_capacity(1u);
    var i: i64 = 0;
    while i < 20 {
        v.push(BoxI64(i));
        i = i + 1;
    }

    assert(v.len() == 20u);
    assert(((BoxI64)v[0]).val == 0);
    assert(((BoxI64)v[19]).val == 19);
}


fn test_vec_get_oob_panics() -> unit {
    var v: Vec = Vec.new();
    var x: Obj = v[0];
}


fn test_vec_set_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v[0] = BoxI64(1);
}


fn test_vec_get_negative_wrap_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(1));
    v.push(BoxI64(2));
    var x: Obj = v[-3];
}


fn test_vec_set_negative_wrap_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(1));
    v.push(BoxI64(2));
    v[-3] = BoxI64(7);
}


fn test_vec_slice_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(1));
    v[0:2];
}


fn test_vec_slice_negative_begin_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(1));
    v.push(BoxI64(2));
    v[-3:1];
}


fn test_vec_slice_negative_end_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(1));
    v.push(BoxI64(2));
    v[0:-3];
}


fn test_vec_slice_reversed_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(1));
    v.push(BoxI64(2));
    v[2:1];
}


fn test_vec_with_capacity_zero_is_allowed() -> unit {
    var v: Vec = Vec.with_capacity(0u);
    assert(v.len() == 0u);
    v.push(BoxI64(7));
    assert(v.len() == 1u);
    assert(((BoxI64)v[0]).val == 7);
}


fn test_vec_slice_write_sugar_updates_range() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(10));
    v.push(BoxI64(20));
    v.push(BoxI64(30));
    v.push(BoxI64(40));

    var repl: Vec = Vec.new();
    repl.push(BoxI64(7));
    repl.push(BoxI64(8));

    v[1:3] = repl;
    assert(((BoxI64)v[0]).val == 10);
    assert(((BoxI64)v[1]).val == 7);
    assert(((BoxI64)v[2]).val == 8);
    assert(((BoxI64)v[3]).val == 40);
}


fn test_vec_slice_write_length_mismatch_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(10));
    v.push(BoxI64(20));
    v.push(BoxI64(30));

    var repl: Vec = Vec.new();
    repl.push(BoxI64(99));

    v[0:2] = repl;
}


fn test_vec_slice_write_oob_panics() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(10));
    var repl: Vec = Vec.new();
    repl.push(BoxI64(77));
    v[0:2] = repl;
}


fn test_vec_for_in_iteration() -> unit {
    var v: Vec = Vec.new();
    v.push(BoxI64(3));
    v.push(BoxI64(5));
    v.push(BoxI64(-2));

    var sum: i64 = 0;
    for elem in v {
        sum = sum + ((BoxI64)elem).val;
    }

    assert(sum == 6);
}


fn main() -> i64 {
    var select: u64 = read_all().strip().to_u64();

    if select == 1u { test_vec_baseline(); }
    if select == 2u { test_vec_index_sugar_with_wrapping_negative_indexes(); }
    if select == 3u { test_vec_slice_sugar_forms_and_negative_wrapping(); }
    if select == 4u { test_vec_slice_copy_independence(); }
    if select == 5u { test_vec_grow_and_copy(); }
    if select == 6u { test_vec_get_oob_panics(); }
    if select == 7u { test_vec_set_oob_panics(); }
    if select == 8u { test_vec_get_negative_wrap_oob_panics(); }
    if select == 9u { test_vec_set_negative_wrap_oob_panics(); }
    if select == 10u { test_vec_slice_oob_panics(); }
    if select == 11u { test_vec_slice_negative_begin_oob_panics(); }
    if select == 12u { test_vec_slice_negative_end_oob_panics(); }
    if select == 13u { test_vec_slice_reversed_panics(); }
    if select == 14u { test_vec_with_capacity_zero_is_allowed(); }
    if select == 15u { test_vec_slice_write_sugar_updates_range(); }
    if select == 16u { test_vec_slice_write_length_mismatch_panics(); }
    if select == 17u { test_vec_slice_write_oob_panics(); }
    if select == 18u { test_vec_for_in_iteration(); }

    return 0;
}
