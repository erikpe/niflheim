fn test_round(args: Str[]) -> unit {
    var pos_half: double = 1.5;
    var neg_half: double = -1.5;
    var below_half: double = 1.49;
    var above_half: double = 1.51;
    var below_neg_half: double = -1.51;
    var neg_quarter: double = -0.25;
    var pos_inf: double = 1.0 / 0.0;
    var nan_val: double = 0.0 / 0.0;

    // literals
    assert_eq_double(math.round(1.5), 2.0);
    assert_eq_double(math.round(-1.5), -2.0);
    assert_eq_double(math.round(1.49), 1.0);
    assert_eq_double(math.round(1.51), 2.0);
    assert_eq_double(math.round(-1.51), -2.0);
    assert_neg_zero(math.round(-0.25));
    assert_pos_inf(math.round(1.0 / 0.0));
    assert_nan(math.round(0.0 / 0.0));

    // locals
    assert_eq_double(math.round(pos_half), 2.0);
    assert_eq_double(math.round(neg_half), -2.0);
    assert_eq_double(math.round(below_half), 1.0);
    assert_eq_double(math.round(above_half), 2.0);
    assert_eq_double(math.round(below_neg_half), -2.0);
    assert_neg_zero(math.round(neg_quarter));
    assert_pos_inf(math.round(pos_inf));
    assert_nan(math.round(nan_val));

    // argv
    assert_eq_double(math.round(arg_double(args, 0)), 2.0);
    assert_eq_double(math.round(arg_double(args, 1)), -2.0);
    assert_eq_double(math.round(arg_double(args, 2)), 1.0);
    assert_eq_double(math.round(arg_double(args, 3)), 2.0);
    assert_eq_double(math.round(arg_double(args, 4)), -2.0);
    assert_neg_zero(math.round(arg_double(args, 5)));
    assert_pos_inf(math.round(arg_double(args, 6)));
    assert_nan(math.round(arg_double(args, 7)));
}

