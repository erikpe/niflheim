fn test_abs(args: Str[]) -> unit {
    var neg_three_point_five: double = -3.5;
    var zero: double = 0.0;
    var neg_value: double = -123.25;
    var neg_forty_two_point_five: double = -42.5;
    var seven: double = 7.0;
    var neg_zero: double = -0.0;
    var neg_inf: double = -1.0 / 0.0;
    var nan_val: double = 0.0 / 0.0;

    // literals
    assert_eq_double(math.abs(-3.5), 3.5);
    assert_eq_double(math.abs(0.0), 0.0);
    assert_eq_double(math.abs(-123.25), 123.25);
    assert_eq_double(math.abs(-42.5), 42.5);
    assert_eq_double(math.abs(7.0), 7.0);
    assert_pos_zero(math.abs(-0.0));
    assert_pos_inf(math.abs(-1.0 / 0.0));
    assert_nan(math.abs(0.0 / 0.0));

    // locals
    assert_eq_double(math.abs(neg_three_point_five), 3.5);
    assert_eq_double(math.abs(zero), 0.0);
    assert_eq_double(math.abs(neg_value), 123.25);
    assert_eq_double(math.abs(neg_forty_two_point_five), 42.5);
    assert_eq_double(math.abs(seven), 7.0);
    assert_pos_zero(math.abs(neg_zero));
    assert_pos_inf(math.abs(neg_inf));
    assert_nan(math.abs(nan_val));

    // argv
    assert_eq_double(math.abs(arg_double(args, 0)), 3.5);
    assert_eq_double(math.abs(arg_double(args, 1)), 0.0);
    assert_eq_double(math.abs(arg_double(args, 2)), 123.25);
    assert_eq_double(math.abs(arg_double(args, 3)), 42.5);
    assert_eq_double(math.abs(arg_double(args, 4)), 7.0);
    assert_pos_zero(math.abs(arg_double(args, 5)));
    assert_pos_inf(math.abs(arg_double(args, 6)));
    assert_nan(math.abs(arg_double(args, 7)));
}

fn test_min(args: Str[]) -> unit {
    var left_one: double = 1.0;
    var right_two: double = 2.0;
    var left_neg_four: double = -4.0;
    var right_three: double = 3.0;
    var left_seven: double = 7.0;
    var right_neg_two: double = -2.0;
    var left_four: double = 4.0;
    var right_neg_nine: double = -9.0;
    var left_three: double = 3.0;
    var right_nine: double = 9.0;
    var neg_zero: double = -0.0;
    var zero: double = 0.0;
    var nan_val: double = 0.0 / 0.0;

    // literals
    assert_eq_double(math.min(1.0, 2.0), 1.0);
    assert_eq_double(math.min(-4.0, 3.0), -4.0);
    assert_eq_double(math.min(7.0, -2.0), -2.0);
    assert_eq_double(math.min(4.0, -9.0), -9.0);
    assert_eq_double(math.min(3.0, 9.0), 3.0);
    assert_neg_zero(math.min(-0.0, 0.0));
    assert_nan(math.min(0.0 / 0.0, 1.0));

    // locals
    assert_eq_double(math.min(left_one, right_two), 1.0);
    assert_eq_double(math.min(left_neg_four, right_three), -4.0);
    assert_eq_double(math.min(left_seven, right_neg_two), -2.0);
    assert_eq_double(math.min(left_four, right_neg_nine), -9.0);
    assert_eq_double(math.min(left_three, right_nine), 3.0);
    assert_neg_zero(math.min(neg_zero, zero));
    assert_nan(math.min(nan_val, left_one));

    // argv
    assert_eq_double(math.min(arg_double(args, 0), arg_double(args, 1)), 1.0);
    assert_eq_double(math.min(arg_double(args, 2), arg_double(args, 3)), -4.0);
    assert_eq_double(math.min(arg_double(args, 4), arg_double(args, 5)), -2.0);
    assert_eq_double(math.min(arg_double(args, 6), arg_double(args, 7)), -9.0);
    assert_eq_double(math.min(arg_double(args, 8), arg_double(args, 9)), 3.0);
    assert_neg_zero(math.min(arg_double(args, 10), arg_double(args, 11)));
    assert_nan(math.min(arg_double(args, 12), arg_double(args, 13)));
}

fn test_max(args: Str[]) -> unit {
    var left_one: double = 1.0;
    var right_two: double = 2.0;
    var left_neg_four: double = -4.0;
    var right_three: double = 3.0;
    var left_seven: double = 7.0;
    var right_neg_two: double = -2.0;
    var left_four: double = 4.0;
    var right_neg_nine: double = -9.0;
    var left_three: double = 3.0;
    var right_nine: double = 9.0;
    var neg_zero: double = -0.0;
    var zero: double = 0.0;
    var nan_val: double = 0.0 / 0.0;

    // literals
    assert_eq_double(math.max(1.0, 2.0), 2.0);
    assert_eq_double(math.max(-4.0, 3.0), 3.0);
    assert_eq_double(math.max(7.0, -2.0), 7.0);
    assert_eq_double(math.max(4.0, -9.0), 4.0);
    assert_eq_double(math.max(3.0, 9.0), 9.0);
    assert_pos_zero(math.max(-0.0, 0.0));
    assert_nan(math.max(0.0 / 0.0, 1.0));

    // locals
    assert_eq_double(math.max(left_one, right_two), 2.0);
    assert_eq_double(math.max(left_neg_four, right_three), 3.0);
    assert_eq_double(math.max(left_seven, right_neg_two), 7.0);
    assert_eq_double(math.max(left_four, right_neg_nine), 4.0);
    assert_eq_double(math.max(left_three, right_nine), 9.0);
    assert_pos_zero(math.max(neg_zero, zero));
    assert_nan(math.max(nan_val, left_one));

    // argv
    assert_eq_double(math.max(arg_double(args, 0), arg_double(args, 1)), 2.0);
    assert_eq_double(math.max(arg_double(args, 2), arg_double(args, 3)), 3.0);
    assert_eq_double(math.max(arg_double(args, 4), arg_double(args, 5)), 7.0);
    assert_eq_double(math.max(arg_double(args, 6), arg_double(args, 7)), 4.0);
    assert_eq_double(math.max(arg_double(args, 8), arg_double(args, 9)), 9.0);
    assert_pos_zero(math.max(arg_double(args, 10), arg_double(args, 11)));
    assert_nan(math.max(arg_double(args, 12), arg_double(args, 13)));
}

fn test_hypot(args: Str[]) -> unit {
    var left_three: double = 3.0;
    var right_four: double = 4.0;
    var left_five: double = 5.0;
    var right_twelve: double = 12.0;
    var left_eight: double = 8.0;
    var right_fifteen: double = 15.0;
    var left_seven: double = 7.0;
    var right_twenty_four: double = 24.0;
    var left_six: double = 6.0;
    var right_eight: double = 8.0;
    var pos_inf: double = 1.0 / 0.0;
    var one: double = 1.0;
    var nan_val: double = 0.0 / 0.0;

    // literals
    assert_close(math.hypot(3.0, 4.0), 5.0, default_tolerance());
    assert_close(math.hypot(5.0, 12.0), 13.0, default_tolerance());
    assert_close(math.hypot(8.0, 15.0), 17.0, default_tolerance());
    assert_close(math.hypot(7.0, 24.0), 25.0, default_tolerance());
    assert_close(math.hypot(6.0, 8.0), 10.0, default_tolerance());
    assert_pos_inf(math.hypot(1.0 / 0.0, 1.0));
    assert_nan(math.hypot(0.0 / 0.0, 1.0));

    // locals
    assert_close(math.hypot(left_three, right_four), 5.0, default_tolerance());
    assert_close(math.hypot(left_five, right_twelve), 13.0, default_tolerance());
    assert_close(math.hypot(left_eight, right_fifteen), 17.0, default_tolerance());
    assert_close(math.hypot(left_seven, right_twenty_four), 25.0, default_tolerance());
    assert_close(math.hypot(left_six, right_eight), 10.0, default_tolerance());
    assert_pos_inf(math.hypot(pos_inf, one));
    assert_nan(math.hypot(nan_val, one));

    // argv
    assert_close(math.hypot(arg_double(args, 0), arg_double(args, 1)), 5.0, default_tolerance());
    assert_close(math.hypot(arg_double(args, 2), arg_double(args, 3)), 13.0, default_tolerance());
    assert_close(math.hypot(arg_double(args, 4), arg_double(args, 5)), 17.0, default_tolerance());
    assert_close(math.hypot(arg_double(args, 6), arg_double(args, 7)), 25.0, default_tolerance());
    assert_close(math.hypot(arg_double(args, 8), arg_double(args, 9)), 10.0, default_tolerance());
    assert_pos_inf(math.hypot(arg_double(args, 10), arg_double(args, 11)));
    assert_nan(math.hypot(arg_double(args, 12), arg_double(args, 13)));
}

fn test_is_nan(args: Str[]) -> unit {
    var nan_val: double = 0.0 / 0.0;
    var one: double = 1.0;
    var neg_one: double = -1.0;
    var zero: double = 0.0;
    var pos_inf: double = 1.0 / 0.0;
    var neg_inf: double = -1.0 / 0.0;

    // literals
    assert_true(math.is_nan(0.0 / 0.0));
    assert_false(math.is_nan(1.0));
    assert_false(math.is_nan(-1.0));
    assert_false(math.is_nan(0.0));
    assert_false(math.is_nan(1.0 / 0.0));
    assert_false(math.is_nan(-1.0 / 0.0));

    // locals
    assert_true(math.is_nan(nan_val));
    assert_false(math.is_nan(one));
    assert_false(math.is_nan(neg_one));
    assert_false(math.is_nan(zero));
    assert_false(math.is_nan(pos_inf));
    assert_false(math.is_nan(neg_inf));

    // argv
    assert_true(math.is_nan(arg_double(args, 0)));
    assert_false(math.is_nan(arg_double(args, 1)));
    assert_false(math.is_nan(arg_double(args, 2)));
    assert_false(math.is_nan(arg_double(args, 3)));
    assert_false(math.is_nan(arg_double(args, 4)));
    assert_false(math.is_nan(arg_double(args, 5)));
}

fn test_is_infinite(args: Str[]) -> unit {
    var pos_inf: double = 1.0 / 0.0;
    var neg_inf: double = -1.0 / 0.0;
    var forty_two: double = 42.0;
    var one: double = 1.0;
    var neg_seven: double = -7.0;
    var nan_val: double = 0.0 / 0.0;
    var zero: double = 0.0;

    // literals
    assert_true(math.is_infinite(1.0 / 0.0));
    assert_true(math.is_infinite(-1.0 / 0.0));
    assert_false(math.is_infinite(42.0));
    assert_false(math.is_infinite(1.0));
    assert_false(math.is_infinite(-7.0));
    assert_false(math.is_infinite(0.0 / 0.0));
    assert_false(math.is_infinite(0.0));

    // locals
    assert_true(math.is_infinite(pos_inf));
    assert_true(math.is_infinite(neg_inf));
    assert_false(math.is_infinite(forty_two));
    assert_false(math.is_infinite(one));
    assert_false(math.is_infinite(neg_seven));
    assert_false(math.is_infinite(nan_val));
    assert_false(math.is_infinite(zero));

    // argv
    assert_true(math.is_infinite(arg_double(args, 0)));
    assert_true(math.is_infinite(arg_double(args, 1)));
    assert_false(math.is_infinite(arg_double(args, 2)));
    assert_false(math.is_infinite(arg_double(args, 3)));
    assert_false(math.is_infinite(arg_double(args, 4)));
    assert_false(math.is_infinite(arg_double(args, 5)));
    assert_false(math.is_infinite(arg_double(args, 6)));
}

fn assert_eq_bool(actual: bool, expected: bool) -> unit {
    if actual {
        assert_true(expected);
        return;
    }
    assert_false(expected);
}

fn main() -> i64 {
    var args: Str[] = read_program_args();
    var test_name: Str = args[1];
    var values: Str[] = args[2:];

    if test_name.equals("sin") { test_sin(values); return 0; }
    if test_name.equals("cos") { test_cos(values); return 0; }
    if test_name.equals("tan") { test_tan(values); return 0; }
    if test_name.equals("asin") { test_asin(values); return 0; }
    if test_name.equals("acos") { test_acos(values); return 0; }
    if test_name.equals("atan") { test_atan(values); return 0; }
    if test_name.equals("atan2") { test_atan2(values); return 0; }
    if test_name.equals("exp") { test_exp(values); return 0; }
    if test_name.equals("log") { test_log(values); return 0; }
    if test_name.equals("log10") { test_log10(values); return 0; }
    if test_name.equals("pow") { test_pow(values); return 0; }
    if test_name.equals("sqrt") { test_sqrt(values); return 0; }
    if test_name.equals("cbrt") { test_cbrt(values); return 0; }
    if test_name.equals("floor") { test_floor(values); return 0; }
    if test_name.equals("ceil") { test_ceil(values); return 0; }
    if test_name.equals("round") { test_round(values); return 0; }
    if test_name.equals("trunc") { test_trunc(values); return 0; }
    if test_name.equals("abs") { test_abs(values); return 0; }
    if test_name.equals("min") { test_min(values); return 0; }
    if test_name.equals("max") { test_max(values); return 0; }
    if test_name.equals("hypot") { test_hypot(values); return 0; }
    if test_name.equals("is_nan") { test_is_nan(values); return 0; }
    if test_name.equals("is_infinite") { test_is_infinite(values); return 0; }

    fail("Unknown test selector: " + test_name);
    return 1;
}
