    assert_eq_double(math.ceil(-1.75), -1.0);
    assert_eq_double(math.ceil(-2.0), -2.0);
    assert_eq_double(math.ceil(7.01), 8.0);
    assert_eq_double(math.ceil(-7.99), -7.0);
    assert_neg_zero(math.ceil(-0.0));
    assert_pos_inf(math.ceil(1.0 / 0.0));
    assert_nan(math.ceil(0.0 / 0.0));

    // locals
    assert_eq_double(math.ceil(positive), 2.0);
    assert_eq_double(math.ceil(negative), -1.0);
    assert_eq_double(math.ceil(already_int), -2.0);
    assert_eq_double(math.ceil(almost_eight), 8.0);
    assert_eq_double(math.ceil(almost_neg_seven), -7.0);
    assert_neg_zero(math.ceil(neg_zero));
    assert_pos_inf(math.ceil(pos_inf));
    assert_nan(math.ceil(nan_val));

