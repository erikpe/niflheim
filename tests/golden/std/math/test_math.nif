    assert_eq_double(math.ceil(arg_double(args, 2)), -2.0);
    assert_eq_double(math.ceil(arg_double(args, 3)), 8.0);
    assert_eq_double(math.ceil(arg_double(args, 4)), -7.0);
    assert_neg_zero(math.ceil(arg_double(args, 5)));
    assert_pos_inf(math.ceil(arg_double(args, 6)));
    assert_nan(math.ceil(arg_double(args, 7)));
