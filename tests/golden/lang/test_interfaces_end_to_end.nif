import std.test;
import std.io;
import std.object;

interface Metric {
    fn score() -> u64;
}

interface Doubler {
    fn twice() -> u64;
}

class Counter implements Metric, Doubler {
    value: u64;

    fn score() -> u64 {
        return __self.value + 1u;
    }

    fn twice() -> u64 {
        return __self.value * 2u;
    }
}

class Gauge implements Metric {
    value: u64;

    fn score() -> u64 {
        return __self.value + 10u;
    }
}

class Holder {
    primary: Metric;
    values: Metric[];
}

fn measure(value: Metric) -> u64 {
    return value.score();
}

fn bounce_metric(value: Metric) -> Metric {
    return value;
}

fn cast_metric(value: Obj) -> Metric {
    return (Metric)value;
}

fn test_basic_dispatch() -> unit {
    assert_eq_u64(measure(Counter(41u)), 42u);
}

fn test_successful_obj_and_interface_casts() -> unit {
    var value: Obj = Counter(9u);
    var metric: Metric = (Metric)value;
    assert_eq_u64(metric.score(), 10u);

    var doubler: Doubler = (Doubler)metric;
    assert_eq_u64(doubler.twice(), 18u);
}

fn test_null_obj_to_interface_cast_yields_null() -> unit {
    var value: Obj = null;
    var metric: Metric = (Metric)value;
    var obj: Obj = (Obj)metric;

    assert_true(obj == null);
}

fn test_interface_round_trip_through_obj() -> unit {
    var metric: Metric = Counter(6u);
    var rebound: Metric = cast_metric((Obj)metric);

    assert_eq_u64(rebound.score(), 7u);
    assert_true(same_type((Obj)metric, (Obj)rebound));
}

fn test_interface_storage_and_returns() -> unit {
    var values: Metric[] = Metric[](2u);
    values[0] = Counter(2u);
    values[1] = Gauge(5u);

    var holder: Holder = Holder(Counter(9u), values);
    var bounced: Metric = bounce_metric(holder.primary);

    assert_eq_u64(bounced.score(), 10u);
    assert_eq_u64(holder.values[0].score(), 3u);
    assert_eq_u64(holder.values[1].score(), 15u);
}

fn test_dynamic_type_visible_through_obj() -> unit {
    var a: Metric = Counter(1u);
    var b: Metric = Counter(5u);
    var c: Metric = Gauge(1u);

    assert_true(same_type((Obj)a, (Obj)b));
    assert_false(same_type((Obj)a, (Obj)c));
}

fn main() -> i64 {
    var select: u64 = read_program_args()[1].to_u64();

    if select == 1u { test_basic_dispatch(); return 0; }
    if select == 2u { test_successful_obj_and_interface_casts(); return 0; }
    if select == 3u { test_null_obj_to_interface_cast_yields_null(); return 0; }
    if select == 4u { test_interface_round_trip_through_obj(); return 0; }
    if select == 5u { test_interface_storage_and_returns(); return 0; }
    if select == 6u { test_dynamic_type_visible_through_obj(); return 0; }

    fail("Invalid test selection.");
    return 1;
}