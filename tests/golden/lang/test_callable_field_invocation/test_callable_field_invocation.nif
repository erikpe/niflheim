import std.test;
import std.io;

fn inc(v: i64) -> i64 {
    return v + 1;
}

fn dec(v: i64) -> i64 {
    return v - 1;
}

fn add(a: i64, b: i64) -> i64 {
    return a + b;
}

fn mul(a: i64, b: i64) -> i64 {
    return a * b;
}

class Math {
    static fn twice(v: i64) -> i64 {
        return v * 2;
    }
}

class UnaryHolder {
    f: fn(i64) -> i64;

    fn run(v: i64) -> i64 {
        return __self.f(v);
    }
}

class BinaryHolder {
    op: fn(i64, i64) -> i64;

    fn run(a: i64, b: i64) -> i64 {
        return __self.op(a, b);
    }
}

class BaseHolder {
    f: fn(i64) -> i64;
}

class DerivedHolder extends BaseHolder {
    bias: i64;

    constructor(f: fn(i64) -> i64, bias: i64) {
        super(f);
        __self.bias = bias;
        return;
    }

    fn run(v: i64) -> i64 {
        return __self.f(v) + __self.bias;
    }
}

fn test_direct_callable_field_call() -> unit {
    var h: UnaryHolder = UnaryHolder(inc);
    assert_eq_i64(h.run(41), 42);
    h.f = dec;
    assert_eq_i64(h.run(41), 40);
}

fn test_direct_callable_field_in_expression() -> unit {
    var h: UnaryHolder = UnaryHolder(inc);
    assert_eq_i64(h.f(9), 10);
    h.f = dec;
    assert_eq_i64(h.f(9), 8);
}

fn test_binary_callable_field_call() -> unit {
    var h: BinaryHolder = BinaryHolder(add);
    assert_eq_i64(h.run(20, 22), 42);
    h.op = mul;
    assert_eq_i64(h.run(6, 7), 42);
}

fn test_binary_callable_field_direct_call() -> unit {
    var h: BinaryHolder = BinaryHolder(add);
    assert_eq_i64(h.op(11, 31), 42);
    h.op = mul;
    assert_eq_i64(h.op(6, 7), 42);
}

fn test_callable_field_static_method_symbol() -> unit {
    var h: UnaryHolder = UnaryHolder(Math.twice);
    assert_eq_i64(h.run(21), 42);
    assert_eq_i64(h.f(12), 24);
}

fn test_callable_field_extracted_to_local_value() -> unit {
    var h: UnaryHolder = UnaryHolder(inc);
    var f: fn(i64) -> i64 = h.f;
    assert_eq_i64(f(41), 42);
    h.f = dec;
    var g: fn(i64) -> i64 = h.f;
    assert_eq_i64(g(41), 40);
}

fn test_inherited_callable_field_invocation() -> unit {
    var h: DerivedHolder = DerivedHolder(Math.twice, 2);
    assert_eq_i64(h.run(20), 42);
    h.f = inc;
    assert_eq_i64(h.run(39), 42);
}

fn main() -> i64 {
    var select: u64 = read_program_args()[1].to_u64();

    if select == 1u { test_direct_callable_field_call(); return 0; }
    if select == 2u { test_direct_callable_field_in_expression(); return 0; }
    if select == 3u { test_binary_callable_field_call(); return 0; }
    if select == 4u { test_binary_callable_field_direct_call(); return 0; }
    if select == 5u { test_callable_field_static_method_symbol(); return 0; }
    if select == 6u { test_callable_field_extracted_to_local_value(); return 0; }
    if select == 7u { test_inherited_callable_field_invocation(); return 0; }

    fail("Invalid test selection.");
    return 1;
}
