import std.io;
import std.str;
import std.test;


fn test_bool_to_bool(input: Str[]) -> unit {
    var bool_false: bool = false;
    var bool_true: bool = true;

    assert_false((bool)false);
    assert_true((bool)true);

    assert_false((bool)bool_false);
    assert_true((bool)bool_true);

    assert_false((bool)input[0].to_bool());
    assert_true((bool)input[1].to_bool());
}


fn test_bool_to_i64(input: Str[]) -> unit {
    var bool_false: bool = false;
    var bool_true: bool = true;

    assert_eq_i64((i64)false, 0);
    assert_eq_i64((i64)true, 1);

    assert_eq_i64((i64)bool_false, 0);
    assert_eq_i64((i64)bool_true, 1);

    assert_eq_i64((i64)input[0].to_bool(), 0);
    assert_eq_i64((i64)input[1].to_bool(), 1);
}


fn test_bool_to_u64(input: Str[]) -> unit {
    var bool_false: bool = false;
    var bool_true: bool = true;

    assert_eq_u64((u64)false, 0u);
    assert_eq_u64((u64)true, 1u);

    assert_eq_u64((u64)bool_false, 0u);
    assert_eq_u64((u64)bool_true, 1u);

    assert_eq_u64((u64)input[0].to_bool(), 0u);
    assert_eq_u64((u64)input[1].to_bool(), 1u);
}


fn test_bool_to_u8(input: Str[]) -> unit {
    var bool_false: bool = false;
    var bool_true: bool = true;

    assert_eq_u8((u8)false, 0u8);
    assert_eq_u8((u8)true, 1u8);

    assert_eq_u8((u8)bool_false, 0u8);
    assert_eq_u8((u8)bool_true, 1u8);

    assert_eq_u8((u8)input[0].to_bool(), 0u8);
    assert_eq_u8((u8)input[1].to_bool(), 1u8);
}


fn test_bool_to_double(input: Str[]) -> unit {
    var bool_false: bool = false;
    var bool_true: bool = true;

    assert_eq_double((double)false, 0.0);
    assert_eq_double((double)true, 1.0);

    assert_eq_double((double)bool_false, 0.0);
    assert_eq_double((double)bool_true, 1.0);

    assert_eq_double((double)input[0].to_bool(), 0.0);
    assert_eq_double((double)input[1].to_bool(), 1.0);
}


fn test_i64_to_bool(input: Str[]) -> unit {
    var i64_zero: i64 = 0;
    var i64_one: i64 = 1;
    var i64_neg1: i64 = -1;
    var i64_min: i64 = -9223372036854775808;

    assert_false((bool)0);
    assert_true((bool)1);
    assert_true((bool)(-1));
    assert_true((bool)(-9223372036854775808));

    assert_false((bool)i64_zero);
    assert_true((bool)i64_one);
    assert_true((bool)i64_neg1);
    assert_true((bool)i64_min);

    assert_false((bool)input[0].to_i64());
    assert_true((bool)input[1].to_i64());
    assert_true((bool)input[2].to_i64());
    assert_true((bool)input[3].to_i64());
}


fn test_i64_to_i64(input: Str[]) -> unit {
    var i64_zero: i64 = 0;
    var i64_pos: i64 = 42;
    var i64_neg: i64 = -42;
    var i64_min: i64 = -9223372036854775808;
    var i64_max: i64 = 9223372036854775807;

    assert_eq_i64((i64)0, 0);
    assert_eq_i64((i64)42, 42);
    assert_eq_i64((i64)(-42), -42);
    assert_eq_i64((i64)(-9223372036854775808), -9223372036854775808);
    assert_eq_i64((i64)9223372036854775807, 9223372036854775807);

    assert_eq_i64((i64)i64_zero, 0);
    assert_eq_i64((i64)i64_pos, 42);
    assert_eq_i64((i64)i64_neg, -42);
    assert_eq_i64((i64)i64_min, -9223372036854775808);
    assert_eq_i64((i64)i64_max, 9223372036854775807);

    assert_eq_i64((i64)input[0].to_i64(), 0);
    assert_eq_i64((i64)input[1].to_i64(), 42);
    assert_eq_i64((i64)input[2].to_i64(), -42);
    assert_eq_i64((i64)input[3].to_i64(), -9223372036854775808);
    assert_eq_i64((i64)input[4].to_i64(), 9223372036854775807);
}


fn test_i64_to_u64(input: Str[]) -> unit {
    var i64_zero: i64 = 0;
    var i64_pos: i64 = 42;
    var i64_neg1: i64 = -1;
    var i64_max: i64 = 9223372036854775807;
    var i64_min: i64 = -9223372036854775808;
    var i64_min_plus_one: i64 = -9223372036854775807;

    assert_eq_u64((u64)0, 0u);
    assert_eq_u64((u64)42, 42u);
    assert_eq_u64((u64)(-1), 18446744073709551615u);
    assert_eq_u64((u64)(9223372036854775807), 9223372036854775807u);
    assert_eq_u64((u64)(-9223372036854775808), 9223372036854775808u);
    assert_eq_u64((u64)(-9223372036854775807), 9223372036854775809u);

    assert_eq_u64((u64)i64_zero, 0u);
    assert_eq_u64((u64)i64_pos, 42u);
    assert_eq_u64((u64)i64_neg1, 18446744073709551615u);
    assert_eq_u64((u64)i64_max, 9223372036854775807u);
    assert_eq_u64((u64)i64_min, 9223372036854775808u);
    assert_eq_u64((u64)i64_min_plus_one, 9223372036854775809u);

    assert_eq_u64((u64)input[0].to_i64(), 0u);
    assert_eq_u64((u64)input[1].to_i64(), 42u);
    assert_eq_u64((u64)input[2].to_i64(), 18446744073709551615u);
    assert_eq_u64((u64)input[3].to_i64(), 9223372036854775807u);
    assert_eq_u64((u64)input[4].to_i64(), 9223372036854775808u);
    assert_eq_u64((u64)input[5].to_i64(), 9223372036854775809u);
}


fn test_i64_to_u8(input: Str[]) -> unit {
    var i64_zero: i64 = 0;
    var i64_one: i64 = 1;
    var i64_255: i64 = 255;
    var i64_256: i64 = 256;
    var i64_257: i64 = 257;
    var i64_neg1: i64 = -1;
    var i64_neg2: i64 = -2;

    assert_eq_u8((u8)0, 0u8);
    assert_eq_u8((u8)1, 1u8);
    assert_eq_u8((u8)255, 255u8);
    assert_eq_u8((u8)256, 0u8);
    assert_eq_u8((u8)257, 1u8);
    assert_eq_u8((u8)(-1), 255u8);
    assert_eq_u8((u8)(-2), 254u8);

    assert_eq_u8((u8)i64_zero, 0u8);
    assert_eq_u8((u8)i64_one, 1u8);
    assert_eq_u8((u8)i64_255, 255u8);
    assert_eq_u8((u8)i64_256, 0u8);
    assert_eq_u8((u8)i64_257, 1u8);
    assert_eq_u8((u8)i64_neg1, 255u8);
    assert_eq_u8((u8)i64_neg2, 254u8);

    assert_eq_u8((u8)input[0].to_i64(), 0u8);
    assert_eq_u8((u8)input[1].to_i64(), 1u8);
    assert_eq_u8((u8)input[2].to_i64(), 255u8);
    assert_eq_u8((u8)input[3].to_i64(), 0u8);
    assert_eq_u8((u8)input[4].to_i64(), 1u8);
    assert_eq_u8((u8)input[5].to_i64(), 255u8);
    assert_eq_u8((u8)input[6].to_i64(), 254u8);
}


fn test_i64_to_double(input: Str[]) -> unit {
    var i64_zero: i64 = 0;
    var i64_pos: i64 = 42;
    var i64_neg: i64 = -42;
    var i64_max: i64 = 9223372036854775807;
    var i64_min: i64 = -9223372036854775808;

    assert_eq_double((double)0, 0.0);
    assert_eq_double((double)42, 42.0);
    assert_eq_double((double)(-42), -42.0);
    assert_true((double)9223372036854775807 > 9000000000000000000.0);
    assert_true((double)(-9223372036854775808) < -9000000000000000000.0);

    assert_eq_double((double)i64_zero, 0.0);
    assert_eq_double((double)i64_pos, 42.0);
    assert_eq_double((double)i64_neg, -42.0);
    assert_true((double)i64_max > 9000000000000000000.0);
    assert_true((double)i64_min < -9000000000000000000.0);

    assert_eq_double((double)input[0].to_i64(), 0.0);
    assert_eq_double((double)input[1].to_i64(), 42.0);
    assert_eq_double((double)input[2].to_i64(), -42.0);
    assert_true((double)input[3].to_i64() > 9000000000000000000.0);
    assert_true((double)input[4].to_i64() < -9000000000000000000.0);
}


fn test_u64_to_bool(input: Str[]) -> unit {
    var u64_zero: u64 = 0u;
    var u64_one: u64 = 1u;
    var u64_max: u64 = 18446744073709551615u;

    assert_false((bool)0u);
    assert_true((bool)1u);
    assert_true((bool)18446744073709551615u);

    assert_false((bool)u64_zero);
    assert_true((bool)u64_one);
    assert_true((bool)u64_max);

    assert_false((bool)input[0].to_u64());
    assert_true((bool)input[1].to_u64());
    assert_true((bool)input[2].to_u64());
}


fn test_u64_to_i64(input: Str[]) -> unit {
    var u64_zero: u64 = 0u;
    var u64_one: u64 = 1u;
    var u64_i64_max: u64 = 9223372036854775807u;
    var u64_i64_wrap: u64 = 9223372036854775808u;
    var u64_max: u64 = 18446744073709551615u;

    assert_eq_i64((i64)0u, 0);
    assert_eq_i64((i64)1u, 1);
    assert_eq_i64((i64)9223372036854775807u, 9223372036854775807);
    assert_eq_i64((i64)9223372036854775808u, -9223372036854775808);
    assert_eq_i64((i64)18446744073709551615u, -1);

    assert_eq_i64((i64)u64_zero, 0);
    assert_eq_i64((i64)u64_one, 1);
    assert_eq_i64((i64)u64_i64_max, 9223372036854775807);
    assert_eq_i64((i64)u64_i64_wrap, -9223372036854775808);
    assert_eq_i64((i64)u64_max, -1);

    assert_eq_i64((i64)input[0].to_u64(), 0);
    assert_eq_i64((i64)input[1].to_u64(), 1);
    assert_eq_i64((i64)input[2].to_u64(), 9223372036854775807);
    assert_eq_i64((i64)input[3].to_u64(), -9223372036854775808);
    assert_eq_i64((i64)input[4].to_u64(), -1);
}


fn test_u64_to_u64(input: Str[]) -> unit {
    var u64_zero: u64 = 0u;
    var u64_42: u64 = 42u;
    var u64_hi: u64 = 9223372036854775808u;
    var u64_max: u64 = 18446744073709551615u;

    assert_eq_u64((u64)0u, 0u);
    assert_eq_u64((u64)42u, 42u);
    assert_eq_u64((u64)9223372036854775808u, 9223372036854775808u);
    assert_eq_u64((u64)18446744073709551615u, 18446744073709551615u);

    assert_eq_u64((u64)u64_zero, 0u);
    assert_eq_u64((u64)u64_42, 42u);
    assert_eq_u64((u64)u64_hi, 9223372036854775808u);
    assert_eq_u64((u64)u64_max, 18446744073709551615u);

    assert_eq_u64((u64)input[0].to_u64(), 0u);
    assert_eq_u64((u64)input[1].to_u64(), 42u);
    assert_eq_u64((u64)input[2].to_u64(), 9223372036854775808u);
    assert_eq_u64((u64)input[3].to_u64(), 18446744073709551615u);
}


fn test_u64_to_u8(input: Str[]) -> unit {
    var u64_zero: u64 = 0u;
    var u64_255: u64 = 255u;
    var u64_256: u64 = 256u;
    var u64_257: u64 = 257u;
    var u64_max: u64 = 18446744073709551615u;

    assert_eq_u8((u8)0u, 0u8);
    assert_eq_u8((u8)255u, 255u8);
    assert_eq_u8((u8)256u, 0u8);
    assert_eq_u8((u8)257u, 1u8);
    assert_eq_u8((u8)18446744073709551615u, 255u8);

    assert_eq_u8((u8)u64_zero, 0u8);
    assert_eq_u8((u8)u64_255, 255u8);
    assert_eq_u8((u8)u64_256, 0u8);
    assert_eq_u8((u8)u64_257, 1u8);
    assert_eq_u8((u8)u64_max, 255u8);

    assert_eq_u8((u8)input[0].to_u64(), 0u8);
    assert_eq_u8((u8)input[1].to_u64(), 255u8);
    assert_eq_u8((u8)input[2].to_u64(), 0u8);
    assert_eq_u8((u8)input[3].to_u64(), 1u8);
    assert_eq_u8((u8)input[4].to_u64(), 255u8);
}


fn test_u64_to_double(input: Str[]) -> unit {
    var u64_zero: u64 = 0u;
    var u64_one: u64 = 1u;
    var u64_42: u64 = 42u;
    var u64_max: u64 = 18446744073709551615u;

    assert_eq_double((double)0u, 0.0);
    assert_eq_double((double)1u, 1.0);
    assert_eq_double((double)42u, 42.0);
    assert_true((double)18446744073709551615u > 18000000000000000000.0);
    assert_true((double)18446744073709551615u > (double)9223372036854775807);

    assert_eq_double((double)u64_zero, 0.0);
    assert_eq_double((double)u64_one, 1.0);
    assert_eq_double((double)u64_42, 42.0);
    assert_true((double)u64_max > 18000000000000000000.0);
    assert_true((double)u64_max > (double)9223372036854775807);

    assert_eq_double((double)input[0].to_u64(), 0.0);
    assert_eq_double((double)input[1].to_u64(), 1.0);
    assert_eq_double((double)input[2].to_u64(), 42.0);
    assert_true((double)input[3].to_u64() > 18000000000000000000.0);
    assert_true((double)input[3].to_u64() > (double)9223372036854775807);
}


fn test_u8_to_bool(input: Str[]) -> unit {
    var u8_zero: u8 = 0u8;
    var u8_one: u8 = 1u8;
    var u8_max: u8 = 255u8;

    assert_false((bool)0u8);
    assert_true((bool)1u8);
    assert_true((bool)255u8);

    assert_false((bool)u8_zero);
    assert_true((bool)u8_one);
    assert_true((bool)u8_max);

    assert_false((bool)(u8)input[0].to_u64());
    assert_true((bool)(u8)input[1].to_u64());
    assert_true((bool)(u8)input[2].to_u64());
}


fn test_u8_to_i64(input: Str[]) -> unit {
    var u8_zero: u8 = 0u8;
    var u8_one: u8 = 1u8;
    var u8_max: u8 = 255u8;

    assert_eq_i64((i64)0u8, 0);
    assert_eq_i64((i64)1u8, 1);
    assert_eq_i64((i64)255u8, 255);

    assert_eq_i64((i64)u8_zero, 0);
    assert_eq_i64((i64)u8_one, 1);
    assert_eq_i64((i64)u8_max, 255);

    assert_eq_i64((i64)(u8)input[0].to_u64(), 0);
    assert_eq_i64((i64)(u8)input[1].to_u64(), 1);
    assert_eq_i64((i64)(u8)input[2].to_u64(), 255);
}


fn test_u8_to_u64(input: Str[]) -> unit {
    var u8_zero: u8 = 0u8;
