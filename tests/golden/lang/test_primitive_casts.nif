    assert_eq_u64((u64)(u8)input[0].to_u64(), 0u);
    assert_eq_u64((u64)(u8)input[1].to_u64(), 1u);
    assert_eq_u64((u64)(u8)input[2].to_u64(), 255u);
}


fn test_u8_to_u8(input: Str[]) -> unit {
    var u8_zero: u8 = 0u8;
    var u8_one: u8 = 1u8;
