import std.test;
import std.io;
import std.object;

interface Metric {
    fn score() -> u64;
}

interface Doubler {
    fn twice() -> u64;
}

class Counter implements Metric, Doubler {
    value: u64;

    fn score() -> u64 {
        return __self.value + 1u;
    }

    fn twice() -> u64 {
        return __self.value * 2u;
    }
}

fn cast_metric(value: Obj) -> Metric {
    return (Metric)value;
}

fn cast_doubler(value: Metric) -> Doubler {
    return (Doubler)value;
}

fn test_class_to_interface_cast() -> unit {
    var metric: Metric = (Metric)Counter(9u);
    assert_eq_u64(metric.score(), 10u);
}

fn test_obj_to_interface_cast() -> unit {
    var value: Obj = (Obj)Counter(4u);
    var metric: Metric = (Metric)value;
    assert_eq_u64(metric.score(), 5u);
}

fn test_interface_to_obj_round_trip() -> unit {
    var metric: Metric = Counter(6u);
    var obj: Obj = (Obj)metric;
    var rebound: Metric = cast_metric(obj);

    assert_eq_u64(rebound.score(), 7u);
    assert_true(same_type((Obj)metric, (Obj)rebound));
}

fn test_interface_to_interface_cast() -> unit {
    var metric: Metric = Counter(8u);
    var doubler: Doubler = (Doubler)metric;
    assert_eq_u64(doubler.twice(), 16u);
}

fn test_obj_interface_interface_chain() -> unit {
    var value: Obj = (Obj)Counter(3u);
    var metric: Metric = cast_metric(value);
    var doubler: Doubler = cast_doubler(metric);

    assert_eq_u64(metric.score(), 4u);
    assert_eq_u64(doubler.twice(), 6u);
}

fn test_null_obj_to_interface_cast() -> unit {
    var value: Obj = null;
    var metric: Metric = (Metric)value;
    assert_true((Obj)metric == null);
}

fn test_null_interface_to_interface_cast() -> unit {
    var metric: Metric = (Metric)null;
    var doubler: Doubler = (Doubler)metric;
    assert_true((Obj)doubler == null);
}

fn main() -> i64 {
    var select: u64 = read_program_args()[1].to_u64();

    if select == 1u { test_class_to_interface_cast(); return 0; }
    if select == 2u { test_obj_to_interface_cast(); return 0; }
    if select == 3u { test_interface_to_obj_round_trip(); return 0; }
    if select == 4u { test_interface_to_interface_cast(); return 0; }
    if select == 5u { test_obj_interface_interface_chain(); return 0; }
    if select == 6u { test_null_obj_to_interface_cast(); return 0; }
    if select == 7u { test_null_interface_to_interface_cast(); return 0; }

    fail("Invalid test selection.");
    return 1;
}