import std.io;

fn mix(a: i64, b: double, c: u64, d: double) -> double {
    return (double)a + b + (double)c + d;
}

fn add_i64(a: i64, b: i64) -> i64 {
    return a + b;
}

fn sub_i64(a: i64, b: i64) -> i64 {
    return a - b;
}

fn mul_i64(a: i64, b: i64) -> i64 {
    return a * b;
}

fn always_true() -> bool {
    return true;
}

fn always_false() -> bool {
    return false;
}

fn panic_on_call() -> i64 {
    var arr: i64[] = i64[](1u);
    return arr[3];
}

class Ops {
    static fn mixed(a: i64, b: double, c: u64, d: double) -> double {
        return (double)a + b + (double)c + d;
    }
}

class Counter {
    value: i64;
}

class OpHolder {
    op: fn(i64, i64) -> i64;

    fn eval(a: i64, b: i64) -> i64 {
        var f: fn(i64, i64) -> i64 = __self.op;
        return f(a, b);
    }
}

fn call_mixed(f: fn(i64, double, u64, double) -> double) -> double {
    return f(2, 0.5, 3u, 0.25);
}

fn call_bool_0(f: fn() -> bool) -> bool {
    return f();
}

fn call_i64_0(f: fn() -> i64) -> i64 {
    return f();
}

fn call_op(f: fn(i64, i64) -> i64, a: i64, b: i64) -> i64 {
    return f(a, b);
}

fn choose_op(use_mul: bool) -> fn(i64, i64) -> i64 {
    if use_mul {
        return mul_i64;
    }
    return add_i64;
}

fn choose_pred(which: i64) -> fn() -> bool {
    if which == 0 {
        return always_true;
    }
    return always_false;
}

fn inc_counter(c: Counter, delta: i64) -> unit {
    c.value = c.value + delta;
    return;
}

fn apply_twice(f: fn(Counter, i64) -> unit, c: Counter, delta: i64) -> unit {
    f(c, delta);
    f(c, delta);
    return;
}

fn test_mixed_indirect_calls() -> i64 {
    var f1: fn(i64, double, u64, double) -> double = mix;
    var r1: double = call_mixed(f1);
    if (i64)(r1 * 4.0) != 23 {
        return 1;
    }

    var f2: fn(i64, double, u64, double) -> double = Ops.mixed;
    var r2: double = call_mixed(f2);
    if (i64)(r2 * 4.0) != 23 {
        return 2;
    }

    return 0;
}

fn test_returned_function_value_dispatch() -> i64 {
    var op1: fn(i64, i64) -> i64 = choose_op(true);
    if call_op(op1, 6, 7) != 42 {
        return 3;
    }

    var op2: fn(i64, i64) -> i64 = choose_op(false);
    if call_op(op2, 6, 7) != 13 {
        return 4;
    }

    var op3: fn(i64, i64) -> i64 = sub_i64;
    if call_op(op3, 6, 7) != -1 {
        return 5;
    }

    return 0;
}

fn test_zero_arg_bool_callback() -> i64 {
    var p1: fn() -> bool = choose_pred(0);
    var p2: fn() -> bool = choose_pred(1);
    if !call_bool_0(p1) {
        return 6;
    }
    if call_bool_0(p2) {
        return 7;
    }
    return 0;
}

fn test_unit_callback_side_effects() -> i64 {
    var c: Counter = Counter(10);
    var updater: fn(Counter, i64) -> unit = inc_counter;
    apply_twice(updater, c, 4);
    if c.value != 18 {
        return 8;
    }
    return 0;
}

fn test_function_value_in_class_field() -> i64 {
    var h: OpHolder = OpHolder(add_i64);
    if h.eval(9, 4) != 13 {
        return 9;
    }
    h.op = mul_i64;
    if h.eval(9, 4) != 36 {
        return 10;
    }
    return 0;
}

fn test_panic_propagates_through_indirect_call() -> unit {
    var bad: fn() -> i64 = panic_on_call;
    if call_i64_0(bad) == -1 {
        return;
    }
}

fn main() -> i64 {
    var select: u64 = read_stdin().strip().to_u64();

    if select == 1u { return test_mixed_indirect_calls(); }
    if select == 2u { return test_returned_function_value_dispatch(); }
    if select == 3u { return test_zero_arg_bool_callback(); }
    if select == 4u { return test_unit_callback_side_effects(); }
    if select == 5u { return test_function_value_in_class_field(); }
    if select == 6u {
        test_panic_propagates_through_indirect_call();
        return 11;
    }

    return 12;
}
