export fn score() -> i64 {
    return 10;
}

export fn add(a: i64, b: i64) -> i64 {
    return a + b;
}

export class Counter {
    value: i64;
}

export interface Shared {
    fn id() -> i64;
}

export class SharedBox implements Shared {
    value: i64;

    fn id() -> i64 {
        return __self.value;
    }
}