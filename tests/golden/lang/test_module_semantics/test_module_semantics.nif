import std.test;
import std.io;
import tests.golden.lang.test_module_semantics.contracts;
import tests.golden.lang.test_module_semantics.model as model;
import tests.golden.lang.test_module_semantics.util.math;
import tests.golden.lang.test_module_semantics.util.ops as ops;
import tests.golden.lang.test_module_semantics.util.shadow as shadow;
import tests.golden.lang.test_module_semantics.bridge as bridge;
import tests.golden.lang.test_module_semantics.plain_bindings as plain_bindings;
import tests.golden.lang.test_module_semantics.path_bridge as path_bridge;
import tests.golden.lang.test_module_semantics.flat_bridge as flat_bridge;
import tests.golden.lang.test_module_semantics.multi_flat_plain as multi_flat_plain;
import tests.golden.lang.test_module_semantics.multi_flat_export as multi_flat_export;
import tests.golden.lang.test_module_semantics.multi_flat_mixed as multi_flat_mixed;
import tests.golden.lang.test_module_semantics.left.math;
import tests.golden.lang.test_module_semantics.left.alias as left_alias;
import tests.golden.lang.test_module_semantics.right.math;
import tests.golden.lang.test_module_semantics.right.alias as right_alias;
import tests.golden.lang.test_module_semantics.relay as relay;
import tests.golden.lang.test_module_semantics.tools.worker as worker;

fn bounce_hashable(value: Hashable) -> Hashable {
    return value;
}

fn bounce_flat_face(value: flat_bridge.DirectFace) -> flat_bridge.DirectFace {
    return value;
}

fn pick() -> i64 {
    return 9;
}

class Token {
    value: i64;

    fn read() -> i64 {
        return __self.value;
    }
}

fn test_unique_unqualified_imports() -> unit {
    assert_eq_i64(add(20, 22), 42);

    var counter: Counter = Counter(40);
    assert_eq_i64(counter.inc(2), 42);

    var value: Hashable = model.as_hashable(5u);
    var bounced: Hashable = bounce_hashable(value);
    assert_eq_u64(bounced.hash_code(), 105u);
}

fn test_full_imported_path_qualification() -> unit {
    assert_eq_i64(tests.golden.lang.test_module_semantics.util.math.add(10, 32), 42);

    var counter: tests.golden.lang.test_module_semantics.util.math.Counter =
        tests.golden.lang.test_module_semantics.util.math.Counter(39);
    assert_eq_i64(counter.inc(3), 42);
}

fn test_explicit_alias_qualification() -> unit {
    assert_eq_i64(ops.mul(6, 7), 42);

    var box: ops.Box = ops.Box(42);
    assert_eq_i64(box.read(), 42);
}

fn test_reexport_alias_chain() -> unit {
    assert_eq_i64(bridge.math.add(19, 23), 42);

    var value: Hashable = bridge.model.as_hashable(6u);
    assert_eq_u64(value.hash_code(), 106u);

    var key: bridge.model.Key = bridge.model.Key(7u);
    assert_eq_u64(key.hash_code(), 107u);
}

fn test_same_leaf_full_path_disambiguation() -> unit {
    assert_eq_i64(tests.golden.lang.test_module_semantics.left.math.score(), 12);
    assert_eq_i64(tests.golden.lang.test_module_semantics.right.math.score(), 30);
}

fn test_same_leaf_alias_disambiguation() -> unit {
    assert_eq_i64(left_alias.score(), 14);
    assert_eq_i64(right_alias.score(), 28);
}

fn test_local_shadowing_and_qualified_access() -> unit {
    assert_eq_i64(pick(), 9);
    assert_eq_i64(Token(7).read(), 7);

    assert_eq_i64(shadow.pick(), 42);
    assert_eq_i64(shadow.Token(11).read(), 11);
}

fn test_imported_non_entry_main() -> unit {
    assert_eq_i64(worker.main(), 41);
}

fn test_alias_import_unique_unqualified_lookup() -> unit {
    assert_eq_i64(mul(6, 7), 42);

    var box: Box = Box(42);
    assert_eq_i64(box.read(), 42);
}

fn test_full_reexported_nested_module_path() -> unit {
    assert_eq_i64(relay.tests.golden.lang.test_module_semantics.pkg.inner.add(19, 23), 42);

    var counter: relay.tests.golden.lang.test_module_semantics.pkg.inner.Counter =
        relay.tests.golden.lang.test_module_semantics.pkg.inner.Counter(42);
    assert_eq_i64(counter.value, 42);
}

fn test_explicit_reexport_path_alias() -> unit {
    assert_eq_i64(path_bridge.local_add(), 42);
    assert_eq_i64(path_bridge.local_counter_total(), 42);

    assert_eq_i64(path_bridge.tools.calc.add(19, 23), 42);

    var counter: path_bridge.tools.calc.Counter = path_bridge.tools.calc.Counter(40);
    assert_eq_i64(counter.inc(2), 42);
}

fn test_root_flatten_reexport_function_class_and_interface() -> unit {
    assert_eq_i64(flat_bridge.local_twice(), 42);
    assert_eq_u64(flat_bridge.local_face_hash(), 507u);

    assert_eq_i64(flat_bridge.twice(21), 42);

    var key: flat_bridge.DirectKey = flat_bridge.DirectKey(7u);
    var face: flat_bridge.DirectFace = bounce_flat_face(key);
    assert_eq_u64(face.hash_code(), 507u);
}

fn test_root_flatten_reexport_preserves_nested_namespace() -> unit {
    assert_eq_i64(flat_bridge.local_math_total(), 42);

    assert_eq_i64(flat_bridge.math.add(19, 23), 42);

    var counter: flat_bridge.math.Counter = flat_bridge.math.Counter(39);
    assert_eq_i64(counter.inc(3), 42);
}

fn test_plain_import_bind_path_and_root_flatten() -> unit {
    assert_eq_i64(plain_bindings.dotted_add(), 42);
    assert_eq_i64(plain_bindings.dotted_counter_total(), 42);
    assert_eq_i64(plain_bindings.root_twice(), 42);
    assert_eq_i64(plain_bindings.root_math_total(), 42);
    assert_eq_u64(plain_bindings.root_face_hash(), 507u);
}

fn test_plain_multi_root_flatten_merge() -> unit {
    assert_eq_i64(multi_flat_plain.local_add(), 42);
    assert_eq_i64(multi_flat_plain.local_counter_total(), 42);
    assert_eq_i64(multi_flat_plain.local_mul(), 42);
    assert_eq_i64(multi_flat_plain.local_box_value(), 42);
}

fn test_export_multi_root_flatten_merge() -> unit {
    assert_eq_i64(multi_flat_export.local_add(), 42);
    assert_eq_i64(multi_flat_export.local_mul(), 42);

    assert_eq_i64(multi_flat_export.add(19, 23), 42);
    assert_eq_i64(multi_flat_export.mul(6, 7), 42);

    var counter: multi_flat_export.Counter = multi_flat_export.Counter(40);
    assert_eq_i64(counter.inc(2), 42);

    var box: multi_flat_export.Box = multi_flat_export.Box(42);
    assert_eq_i64(box.read(), 42);
}

fn test_mixed_multi_root_flatten_merge() -> unit {
    assert_eq_i64(multi_flat_mixed.local_add(), 42);
    assert_eq_i64(multi_flat_mixed.local_counter_total(), 42);
    assert_eq_i64(multi_flat_mixed.local_mul(), 42);

    assert_eq_i64(multi_flat_mixed.mul(6, 7), 42);

    var box: multi_flat_mixed.Box = multi_flat_mixed.Box(42);
    assert_eq_i64(box.read(), 42);
}

fn main() -> i64 {
    var select: u64 = read_program_args()[1].to_u64();

    if select == 1u { test_unique_unqualified_imports(); return 0; }
    if select == 2u { test_full_imported_path_qualification(); return 0; }
    if select == 3u { test_explicit_alias_qualification(); return 0; }
    if select == 4u { test_reexport_alias_chain(); return 0; }
    if select == 5u { test_same_leaf_full_path_disambiguation(); return 0; }
    if select == 6u { test_same_leaf_alias_disambiguation(); return 0; }
    if select == 7u { test_local_shadowing_and_qualified_access(); return 0; }
    if select == 8u { test_imported_non_entry_main(); return 0; }
    if select == 9u { test_alias_import_unique_unqualified_lookup(); return 0; }
    if select == 10u { test_full_reexported_nested_module_path(); return 0; }
    if select == 11u { test_explicit_reexport_path_alias(); return 0; }
    if select == 12u { test_root_flatten_reexport_function_class_and_interface(); return 0; }
    if select == 13u { test_root_flatten_reexport_preserves_nested_namespace(); return 0; }
    if select == 14u { test_plain_import_bind_path_and_root_flatten(); return 0; }
    if select == 15u { test_plain_multi_root_flatten_merge(); return 0; }
    if select == 16u { test_export_multi_root_flatten_merge(); return 0; }
    if select == 17u { test_mixed_multi_root_flatten_merge(); return 0; }

    fail("Invalid test selection.");
    return 1;
}