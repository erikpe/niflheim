import std.io;
import std.object;
import tests.golden.lang.test_inheritance.util;

interface Metric {
    fn score() -> u64;
}

class Base implements Metric {
    value: u64;

    fn score() -> u64 {
        return __self.value + 1u;
    }

    fn doubled() -> u64 {
        return __self.value * 2u;
    }
}

class Derived extends Base {
    extra: u64;

    constructor(value: u64, extra: u64) {
        super(value);
        __self.extra = extra;
        return;
    }

    fn total() -> u64 {
        return __self.value + __self.extra;
    }
}

class CompatLeaf extends Derived {
    marker: u64;
}

class ImportedDerived extends util.ImportedBase {
    extra: u64;

    constructor(value: u64, extra: u64) {
        super(value);
        __self.extra = extra;
        return;
    }

    fn total() -> u64 {
        return __self.read() + __self.extra;
    }
}

fn take_base(value: Base) -> u64 {
    return value.doubled();
}

fn test_inherited_fields_and_methods() -> i64 {
    var derived: Derived = Derived(7u, 4u);

    if derived.value != 7u {
        return 1;
    }
    if derived.score() != 8u {
        return 2;
    }
    if derived.doubled() != 14u {
        return 3;
    }
    if derived.total() != 11u {
        return 4;
    }

    return 0;
}

fn test_subclass_to_base_assignment_and_same_type() -> i64 {
    var derived: Derived = Derived(5u, 1u);
    var base: Base = derived;

    if take_base(derived) != 10u {
        return 5;
    }
    if base.score() != 6u {
        return 6;
    }
    if !same_type((Obj)derived, (Obj)base) {
        return 7;
    }
    if same_type((Obj)Base(5u), (Obj)derived) {
        return 8;
    }

    return 0;
}

fn test_inherited_interface_dispatch_and_cast_chain() -> i64 {
    var metric: Metric = Derived(9u, 3u);
    var as_base: Base = (Base)metric;
    var as_derived: Derived = (Derived)metric;

    if metric.score() != 10u {
        return 9;
    }
    if as_base.doubled() != 18u {
        return 10;
    }
    if as_derived.extra != 3u {
        return 11;
    }

    return 0;
}

fn test_subtype_aware_type_tests_and_obj_casts() -> i64 {
    var value: Obj = (Obj)Derived(4u, 2u);
    var as_base: Base = (Base)value;
    var as_derived: Derived = (Derived)value;

    if !(value is Base) {
        return 12;
    }
    if !(value is Derived) {
        return 13;
    }
    if !(value is Metric) {
        return 14;
    }
    if as_base.score() != 5u {
        return 15;
    }
    if as_derived.total() != 6u {
        return 16;
    }

    return 0;
}

fn test_explicit_constructor_chaining() -> i64 {
    var derived: Derived = Derived(12u, 7u);

    if derived.value != 12u {
        return 17;
    }
    if derived.extra != 7u {
        return 18;
    }
    if derived.score() != 13u {
        return 19;
    }

    return 0;
}

fn test_compatibility_constructor_chaining() -> i64 {
    var leaf: CompatLeaf = CompatLeaf(3u, 8u, 13u);

    if leaf.value != 3u {
        return 20;
    }
    if leaf.extra != 8u {
        return 21;
    }
    if leaf.marker != 13u {
        return 22;
    }
    if leaf.score() != 4u {
        return 23;
    }
    if !(leaf is Base) {
        return 24;
    }

    return 0;
}

fn test_multilevel_inherited_methods_and_interfaces() -> i64 {
    var leaf: CompatLeaf = CompatLeaf(2u, 5u, 11u);
    var metric: Metric = leaf;
    var as_obj: Obj = leaf;
    var as_base: Base = (Base)as_obj;
    var as_derived: Derived = (Derived)as_obj;

    if leaf.doubled() != 4u {
        return 25;
    }
    if leaf.total() != 7u {
        return 26;
    }
    if metric.score() != 3u {
        return 27;
    }
    if as_base.value != 2u {
        return 28;
    }
    if as_derived.extra != 5u {
        return 29;
    }
    if !(leaf is Derived) {
        return 30;
    }
    if !(leaf is Metric) {
        return 31;
    }
    if !same_type((Obj)leaf, (Obj)as_base) {
        return 32;
    }

    return 0;
}

fn test_imported_superclass_subtyping_and_inherited_members() -> i64 {
    var derived: ImportedDerived = ImportedDerived(6u, 4u);
    var base: util.ImportedBase = derived;
    var hashable: util.ImportedHashable = derived;
    var as_obj: Obj = derived;
    var casted: util.ImportedBase = (util.ImportedBase)as_obj;

    if derived.read() != 6u {
        return 33;
    }
    if derived.total() != 10u {
        return 34;
    }
    if base.read() != 6u {
        return 35;
    }
    if hashable.hash_code() != 106u {
        return 36;
    }
    if casted.read() != 6u {
        return 37;
    }
    if !(derived is util.ImportedBase) {
        return 38;
    }
    if !(as_obj is util.ImportedHashable) {
        return 39;
    }
    if !same_type((Obj)derived, (Obj)base) {
        return 40;
    }

    return 0;
}

fn main() -> i64 {
    var select: u64 = read_stdin().strip().to_u64();

    if select == 1u { return test_inherited_fields_and_methods(); }
    if select == 2u { return test_subclass_to_base_assignment_and_same_type(); }
    if select == 3u { return test_inherited_interface_dispatch_and_cast_chain(); }
    if select == 4u { return test_subtype_aware_type_tests_and_obj_casts(); }
    if select == 5u { return test_explicit_constructor_chaining(); }
    if select == 6u { return test_compatibility_constructor_chaining(); }
    if select == 7u { return test_multilevel_inherited_methods_and_interfaces(); }
    if select == 8u { return test_imported_superclass_subtyping_and_inherited_members(); }

    return 41;
}
