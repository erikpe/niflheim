import std.test;
import std.io;
import std.object;
import tests.golden.lang.test_inheritance.util as util;

interface Metric {
    fn score() -> u64;
}

class Base implements Metric {
    value: u64;

    fn score() -> u64 {
        return __self.value + 1u;
    }

    fn doubled() -> u64 {
        return __self.value * 2u;
    }
}

class Derived extends Base {
    extra: u64;

    constructor(value: u64, extra: u64) {
        super(value);
        __self.extra = extra;
        return;
    }

    fn total() -> u64 {
        return __self.value + __self.extra;
    }
}

class CompatLeaf extends Derived {
    marker: u64;
}

class ImportedDerived extends util.ImportedBase {
    extra: u64;

    constructor(value: u64, extra: u64) {
        super(value);
        __self.extra = extra;
        return;
    }

    fn total() -> u64 {
        return __self.read() + __self.extra;
    }
}

fn take_base(value: Base) -> u64 {
    return value.doubled();
}

fn test_inherited_fields_and_methods() -> unit {
    var derived: Derived = Derived(7u, 4u);

    assert_eq_u64(derived.value, 7u);
    assert_eq_u64(derived.score(), 8u);
    assert_eq_u64(derived.doubled(), 14u);
    assert_eq_u64(derived.total(), 11u);
}

fn test_subclass_to_base_assignment_and_same_type() -> unit {
    var derived: Derived = Derived(5u, 1u);
    var base: Base = derived;

    assert_eq_u64(take_base(derived), 10u);
    assert_eq_u64(base.score(), 6u);
    assert_true(same_type((Obj)derived, (Obj)base));
    assert_false(same_type((Obj)Base(5u), (Obj)derived));
}

fn test_inherited_interface_dispatch_and_cast_chain() -> unit {
    var metric: Metric = Derived(9u, 3u);
    var as_base: Base = (Base)metric;
    var as_derived: Derived = (Derived)metric;

    assert_eq_u64(metric.score(), 10u);
    assert_eq_u64(as_base.doubled(), 18u);
    assert_eq_u64(as_derived.extra, 3u);
}

fn test_subtype_aware_type_tests_and_obj_casts() -> unit {
    var value: Obj = (Obj)Derived(4u, 2u);
    var as_base: Base = (Base)value;
    var as_derived: Derived = (Derived)value;

    assert_true(value is Base);
    assert_true(value is Derived);
    assert_true(value is Metric);
    assert_eq_u64(as_base.score(), 5u);
    assert_eq_u64(as_derived.total(), 6u);
}

fn test_explicit_constructor_chaining() -> unit {
    var derived: Derived = Derived(12u, 7u);

    assert_eq_u64(derived.value, 12u);
    assert_eq_u64(derived.extra, 7u);
    assert_eq_u64(derived.score(), 13u);
}

fn test_compatibility_constructor_chaining() -> unit {
    var leaf: CompatLeaf = CompatLeaf(3u, 8u, 13u);

    assert_eq_u64(leaf.value, 3u);
    assert_eq_u64(leaf.extra, 8u);
    assert_eq_u64(leaf.marker, 13u);
    assert_eq_u64(leaf.score(), 4u);
    assert_true(leaf is Base);
}

fn test_multilevel_inherited_methods_and_interfaces() -> unit {
    var leaf: CompatLeaf = CompatLeaf(2u, 5u, 11u);
    var metric: Metric = leaf;
    var as_obj: Obj = leaf;
    var as_base: Base = (Base)as_obj;
    var as_derived: Derived = (Derived)as_obj;

    assert_eq_u64(leaf.doubled(), 4u);
    assert_eq_u64(leaf.total(), 7u);
    assert_eq_u64(metric.score(), 3u);
    assert_eq_u64(as_base.value, 2u);
    assert_eq_u64(as_derived.extra, 5u);
    assert_true(leaf is Derived);
    assert_true(leaf is Metric);
    assert_true(same_type((Obj)leaf, (Obj)as_base));
}

fn test_imported_superclass_subtyping_and_inherited_members() -> unit {
    var derived: ImportedDerived = ImportedDerived(6u, 4u);
    var base: util.ImportedBase = derived;
    var hashable: util.ImportedHashable = derived;
    var as_obj: Obj = derived;
    var casted: util.ImportedBase = (util.ImportedBase)as_obj;

    assert_eq_u64(derived.read(), 6u);
    assert_eq_u64(derived.total(), 10u);
    assert_eq_u64(base.read(), 6u);
    assert_eq_u64(hashable.hash_code(), 106u);
    assert_eq_u64(casted.read(), 6u);
    assert_true(derived is util.ImportedBase);
    assert_true(as_obj is util.ImportedHashable);
    assert_true(same_type((Obj)derived, (Obj)base));
}

fn main() -> i64 {
    var select: u64 = read_program_args()[1].to_u64();

    if select == 1u { test_inherited_fields_and_methods(); return 0; }
    if select == 2u { test_subclass_to_base_assignment_and_same_type(); return 0; }
    if select == 3u { test_inherited_interface_dispatch_and_cast_chain(); return 0; }
    if select == 4u { test_subtype_aware_type_tests_and_obj_casts(); return 0; }
    if select == 5u { test_explicit_constructor_chaining(); return 0; }
    if select == 6u { test_compatibility_constructor_chaining(); return 0; }
    if select == 7u { test_multilevel_inherited_methods_and_interfaces(); return 0; }
    if select == 8u { test_imported_superclass_subtyping_and_inherited_members(); return 0; }

    fail("Invalid test selection.");
    return 1;
}
