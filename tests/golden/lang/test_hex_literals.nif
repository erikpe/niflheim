import std.test;

fn main() -> i64 {
  var signed_value: i64 = 0x2a;
  var unsigned_value: u64 = 0X2Au;
  var byte_value: u8 = 0xffu8;
  var signed_min: i64 = -0x8000000000000000;

  assert_eq_i64(signed_value, 42);
  assert_eq_u64(unsigned_value, 42u);
  assert_eq_u8(byte_value, 255u8);
  assert_true(signed_min < 0);

  return 0;
}
