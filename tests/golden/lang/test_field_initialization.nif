import std.test;
import std.io;

class Point {
    x: i64;
    y: i64 = 10;
    z: i64 = -3;
}

class Mixed {
    a: i64;
    b: bool = false;
    c: u64;
    d: u8 = (u8)(1 + 2);
}

class Flags {
    on: bool = true;
    off: bool = false;
}

class WithCastDefaults {
    u: u64 = (u64)(1 + 2);
    i: i64 = -5;
    b: bool = !false;
}

fn test_defaults_applied() -> unit {
    var p: Point = Point(7);
    assert_eq_i64(p.x, 7);
    assert_eq_i64(p.y, 10);
    assert_eq_i64(p.z, -3);
}

fn test_only_required_ctor_args() -> unit {
    var m: Mixed = Mixed(4, 9u);
    assert_eq_i64(m.a, 4);
    assert_false(m.b);
    assert_eq_u64(m.c, 9u);
    assert_eq_u8(m.d, 3u8);
}

fn test_multiple_instances_keep_defaults() -> unit {
    var p1: Point = Point(1);
    var p2: Point = Point(2);
    assert_eq_i64(p1.y, 10);
    assert_eq_i64(p2.y, 10);
    assert_eq_i64(p1.z, -3);
    assert_eq_i64(p2.z, -3);
}

fn test_bool_defaults() -> unit {
    var f: Flags = Flags();
    assert_true(f.on);
    assert_false(f.off);
}

fn test_cast_and_expression_defaults() -> unit {
    var w: WithCastDefaults = WithCastDefaults();
    assert_eq_u64(w.u, 3u);
    assert_eq_i64(w.i, -5);
    assert_true(w.b);
}

fn main() -> i64 {
    var select: u64 = read_program_args()[1].to_u64();

    if select == 1u { test_defaults_applied(); return 0; }
    if select == 2u { test_only_required_ctor_args(); return 0; }
    if select == 3u { test_multiple_instances_keep_defaults(); return 0; }
    if select == 4u { test_bool_defaults(); return 0; }
    if select == 5u { test_cast_and_expression_defaults(); return 0; }

    fail("Invalid test selection.");
    return 1;
}
