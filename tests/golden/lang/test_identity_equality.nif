import std.test;
import std.io;
import std.object;

interface Hashable {
    fn hash_code() -> u64;
}

interface Equalable {
    fn equals(other: Obj) -> bool;
}

class Key implements Hashable, Equalable {
    value: u64;

    fn hash_code() -> u64 {
        return __self.value + 101u;
    }

    fn equals(other: Obj) -> bool {
        if other == null {
            return false;
        }
        return ((Key)other).value == __self.value;
    }
}

fn test_reference_obj_identity() -> unit {
    var key: Key = Key(7u);
    var alias: Obj = key;
    var other: Obj = Key(7u);

    assert_true(key == alias);
    assert_true(alias == key);
    assert_false(key != alias);
    assert_false(key == other);
}

fn test_reference_interface_identity() -> unit {
    var key: Key = Key(8u);
    var hashable: Hashable = key;
    var other_hashable: Hashable = Key(8u);

    assert_true(key == hashable);
    assert_true(hashable == key);
    assert_false(hashable == other_hashable);
}

fn test_interface_interface_identity() -> unit {
    var key: Key = Key(9u);
    var hashable: Hashable = key;
    var equalable: Equalable = key;
    var other_equalable: Equalable = Key(9u);

    assert_true(hashable == equalable);
    assert_false(hashable != equalable);
    assert_false(hashable == other_equalable);
}

fn test_obj_interface_null_identity() -> unit {
    var hashable: Hashable = (Hashable)null;
    var obj: Obj = null;

    assert_true(hashable == obj);
    assert_true(obj == hashable);
    assert_false(hashable != null);
}

fn main() -> i64 {
    var select: u64 = read_program_args()[1].to_u64();

    if select == 1u { test_reference_obj_identity(); return 0; }
    if select == 2u { test_reference_interface_identity(); return 0; }
    if select == 3u { test_interface_interface_identity(); return 0; }
    if select == 4u { test_obj_interface_null_identity(); return 0; }

    fail("Invalid test selection.");
    return 1;
}