import std.test;
import std.io;


class Person {
    age: i64;
}


interface Hashable {
    fn hash_code() -> u64;
}


class Key implements Hashable {
    value: u64;

    fn hash_code() -> u64 {
        return __self.value + 100u;
    }
}


fn test_primitive_smoke() -> unit {
    var bytes: u8[] = u8[](3u);
    assert_eq_u64(bytes.len(), 3u);
    assert_eq_u8(bytes[0], (u8)0);
    bytes[1] = (u8)17;
    assert_eq_u8(bytes.index_get(1), (u8)17);

    var nums: i64[] = i64[](2u);
    assert_eq_u64(nums.len(), 2u);
    assert_eq_i64(nums[0], 0);
    nums.index_set(1, -9);
    assert_eq_i64(nums[1], -9);
}


fn test_reference_default_null() -> unit {
    var people: Person[] = Person[](2u);
    assert_eq_u64(people.len(), 2u);
    assert_true(people[0] == null);
    assert_true(people[1] == null);

    people[1] = Person(7);
    assert_true(people[1] != null);
}


fn test_bool_and_double_arrays() -> unit {
    var flags: bool[] = bool[](3u);
    assert_eq_u64(flags.len(), 3u);
    assert_false(flags[0]);
    assert_false(flags[1]);
    assert_false(flags[2]);

    flags[1] = true;
    assert_false(flags[0]);
    assert_true(flags[1]);

    var values: double[] = double[](2u);
    assert_eq_double(values[0], 0.0);
    assert_eq_double(values[1], 0.0);

    values[0] = 1.25;
    values[1] = 2.5;
    assert_eq_double(values[0], 1.25);
    assert_eq_double(values[1], 2.5);
}


fn test_interface_element_arrays_support_storage_and_slice() -> unit {
    var values: Hashable[] = Hashable[](2u);
    values[0] = Key(5u);
    values[1] = Key(8u);

    assert_eq_u64(values[0].hash_code(), 105u);
    assert_eq_u64(values[1].hash_code(), 108u);

    var cut: Hashable[] = values[0:1];
    assert_eq_u64(cut.len(), 1u);
    assert_eq_u64(cut[0].hash_code(), 105u);

    var replacement: Hashable[] = Hashable[](1u);
    replacement[0] = Key(9u);
    values[0:1] = replacement;
    assert_eq_u64(values[0].hash_code(), 109u);
    assert_eq_u64(values[1].hash_code(), 108u);
}


fn test_slice_copy_behavior() -> unit {
    var src: u8[] = u8[](4u);
    src[0] = (u8)10;
    src[1] = (u8)20;
    src[2] = (u8)30;
    src[3] = (u8)40;

    var cut: u8[] = src[1:3];
    assert_eq_u64(cut.len(), 2u);
    assert_eq_u8(cut[0], (u8)20);
    assert_eq_u8(cut[1], (u8)30);

    src[1] = (u8)99;
    assert_eq_u8(cut[0], (u8)20);
}


fn test_set_slice_write_behavior() -> unit {
    var target: u8[] = u8[](4u);
    target[0] = (u8)10;
    target[1] = (u8)20;
    target[2] = (u8)30;
    target[3] = (u8)40;

    var src: u8[] = u8[](2u);
    src[0] = (u8)7;
    src[1] = (u8)8;

    target[1:3] = src;
    assert_eq_u8(target[0], (u8)10);
    assert_eq_u8(target[1], (u8)7);
    assert_eq_u8(target[2], (u8)8);
    assert_eq_u8(target[3], (u8)40);
}


fn test_get_oob_panics() -> unit {
    var arr: u8[] = u8[](1u);
    arr.index_get(1);
}


fn test_set_oob_panics() -> unit {
    var arr: u8[] = u8[](1u);
    arr.index_set(1, (u8)1);
}


fn test_slice_oob_panics() -> unit {
    var arr: u8[] = u8[](1u);
    arr.slice_get(0, 2);
}


fn test_negative_index_panics() -> unit {
    var arr: u8[] = u8[](1u);
    arr.index_get(-1);
}


fn test_set_slice_invalid_length_panics() -> unit {
    var target: u8[] = u8[](4u);
    var src: u8[] = u8[](1u);
    target[1:3] = src;
}


fn test_obj_to_u64_array_cast_ok() -> unit {
    var nums: u64[] = u64[](2u);
    nums[0] = 11u;
    nums[1] = 22u;

    var boxed: Obj = (Obj)nums;
    var roundtrip: u64[] = (u64[])boxed;

    assert_eq_u64(roundtrip.len(), 2u);
    assert_eq_u64(roundtrip[0], 11u);
    assert_eq_u64(roundtrip[1], 22u);
}


fn test_obj_to_u64_array_cast_bad_kind_panics() -> unit {
    var bytes: u8[] = u8[](1u);
    var boxed: Obj = (Obj)bytes;
    var bad: u64[] = (u64[])boxed;
    bad.len();
}


fn test_primitive_array_to_reference_array_cast_panics() -> unit {
    var nums: u64[] = u64[](1u);
    var boxed: Obj = (Obj)nums;
    var bad: Person[] = (Person[])boxed;
    bad.len();
}


fn test_reference_array_to_primitive_array_cast_panics() -> unit {
    var people: Person[] = Person[](1u);
    var boxed: Obj = (Obj)people;
    var bad: u64[] = (u64[])boxed;
    bad.len();
}


fn test_reference_array_roundtrip_cast_ok() -> unit {
    var people: Person[] = Person[](2u);
    people[0] = Person(41);
    people[1] = Person(99);

    var boxed: Obj = (Obj)people;
    var roundtrip: Person[] = (Person[])boxed;

    assert_eq_u64(roundtrip.len(), 2u);
    assert_true(roundtrip[0] != null);
    assert_true(roundtrip[1] != null);
    assert_eq_i64(roundtrip[0].age, 41);
    assert_eq_i64(roundtrip[1].age, 99);
}


fn test_nested_primitive_index_get_set_levels() -> unit {
    var grid: i64[][] = i64[][](2u);
    grid[0] = i64[](3u);
    grid[1] = i64[](3u);

    grid[0][1] = 11;
    grid[1][2] = 22;

    assert_eq_i64(grid[0].index_get(1), 11);
    assert_eq_i64(grid.index_get(1)[2], 22);

    var row: i64[] = i64[](3u);
    row[0] = 5;
    row[1] = 6;
    row[2] = 7;
    grid.index_set(1, row);
    assert_eq_i64(grid[1][0], 5);
    assert_eq_i64(grid[1][1], 6);
    assert_eq_i64(grid[1][2], 7);
}


fn test_nested_primitive_slice_get_set_levels() -> unit {
    var grid: i64[][] = i64[][](3u);
    grid[0] = i64[](4u);
    grid[1] = i64[](4u);
    grid[2] = i64[](4u);

    grid[0][0] = 10;
    grid[0][1] = 11;
    grid[0][2] = 12;
    grid[0][3] = 13;

    grid[1][0] = 20;
    grid[1][1] = 21;
    grid[1][2] = 22;
    grid[1][3] = 23;

    grid[2][0] = 30;
    grid[2][1] = 31;
    grid[2][2] = 32;
    grid[2][3] = 33;

    var inner_cut: i64[] = grid[1][1:3];
    assert_eq_u64(inner_cut.len(), 2u);
    assert_eq_i64(inner_cut[0], 21);
    assert_eq_i64(inner_cut[1], 22);

    var outer_cut: i64[][] = grid[0:2];
    assert_eq_u64(outer_cut.len(), 2u);
    assert_eq_i64(outer_cut[0][3], 13);
    assert_eq_i64(outer_cut[1][2], 22);

    var inner_src: i64[] = i64[](2u);
    inner_src[0] = 70;
    inner_src[1] = 71;
    grid[2][1:3] = inner_src;
    assert_eq_i64(grid[2][0], 30);
    assert_eq_i64(grid[2][1], 70);
    assert_eq_i64(grid[2][2], 71);
    assert_eq_i64(grid[2][3], 33);

    var repl_rows: i64[][] = i64[][](2u);
    repl_rows[0] = i64[](4u);
    repl_rows[1] = i64[](4u);
    repl_rows[0][0] = 100;
    repl_rows[0][1] = 101;
    repl_rows[0][2] = 102;
    repl_rows[0][3] = 103;
    repl_rows[1][0] = 110;
    repl_rows[1][1] = 111;
    repl_rows[1][2] = 112;
    repl_rows[1][3] = 113;

    grid[0:2] = repl_rows;
    assert_eq_i64(grid[0][0], 100);
    assert_eq_i64(grid[0][3], 103);
    assert_eq_i64(grid[1][0], 110);
    assert_eq_i64(grid[1][2], 112);
    assert_eq_i64(grid[2][0], 30);
}


fn test_nested_reference_index_slice_levels() -> unit {
    var teams: Person[][] = Person[][](2u);
    assert_true(teams[0] == null);
    assert_true(teams[1] == null);

    teams[0] = Person[](2u);
    teams[1] = Person[](1u);
    teams[0][0] = Person(10);
    teams[0][1] = Person(20);
    teams[1][0] = Person(30);

    assert_eq_i64(teams[0][0].age, 10);
    assert_eq_i64(teams[0][1].age, 20);
    assert_eq_i64(teams.index_get(1)[0].age, 30);

    var squad: Person[] = Person[](1u);
    squad[0] = Person(77);
    teams.index_set(1, squad);
    assert_eq_i64(teams[1][0].age, 77);

    var people_cut: Person[] = teams[0][0:2];
    assert_eq_u64(people_cut.len(), 2u);
    assert_eq_i64(people_cut[0].age, 10);
    assert_eq_i64(people_cut[1].age, 20);

    var team_cut: Person[][] = teams[0:1];
    assert_eq_u64(team_cut.len(), 1u);
    assert_eq_i64(team_cut[0][1].age, 20);

    var new_people: Person[] = Person[](2u);
    new_people[0] = Person(50);
    new_people[1] = Person(60);
    teams[0][0:2] = new_people;
    assert_eq_i64(teams[0][0].age, 50);
    assert_eq_i64(teams[0][1].age, 60);

    var new_teams: Person[][] = Person[][](1u);
    new_teams[0] = Person[](2u);
    new_teams[0][0] = Person(90);
    new_teams[0][1] = Person(91);
    teams[0:1] = new_teams;
    assert_eq_i64(teams[0][0].age, 90);
    assert_eq_i64(teams[0][1].age, 91);
    assert_eq_i64(teams[1][0].age, 77);
}


fn test_deeply_nested_u8_index_slice_levels() -> unit {
    var cube: u8[][][][] = u8[][][][](1u);
    cube[0] = u8[][][](2u);
    cube[0][0] = u8[][](1u);
    cube[0][1] = u8[][](1u);
    cube[0][0][0] = u8[](4u);
    cube[0][1][0] = u8[](4u);

    cube[0][0][0][0] = (u8)1;
    cube[0][0][0][1] = (u8)2;
    cube[0][0][0][2] = (u8)3;
    cube[0][0][0][3] = (u8)4;

    cube[0][1][0][0] = (u8)5;
    cube[0][1][0][1] = (u8)6;
    cube[0][1][0][2] = (u8)7;
    cube[0][1][0][3] = (u8)8;

    assert_eq_u8(cube[0][0][0][2], (u8)3);
    assert_eq_u8(cube.index_get(0).index_get(1).index_get(0).index_get(3), (u8)8);

    var deep_cut: u8[] = cube[0][1][0][1:3];
    assert_eq_u64(deep_cut.len(), 2u);
    assert_eq_u8(deep_cut[0], (u8)6);
    assert_eq_u8(deep_cut[1], (u8)7);

    var branch_cut: u8[][][][] = cube[0:1];
    assert_eq_u64(branch_cut.len(), 1u);
    assert_eq_u8(branch_cut[0][0][0][1], (u8)2);

    var deep_src: u8[] = u8[](2u);
    deep_src[0] = (u8)40;
    deep_src[1] = (u8)41;
    cube[0][0][0][1:3] = deep_src;
    assert_eq_u8(cube[0][0][0][0], (u8)1);
    assert_eq_u8(cube[0][0][0][1], (u8)40);
    assert_eq_u8(cube[0][0][0][2], (u8)41);
    assert_eq_u8(cube[0][0][0][3], (u8)4);

    var new_branch: u8[][] = u8[][](1u);
    new_branch[0] = u8[](4u);
    new_branch[0][0] = (u8)9;
    new_branch[0][1] = (u8)10;
    new_branch[0][2] = (u8)11;
    new_branch[0][3] = (u8)12;
    cube[0].index_set(1, new_branch);
    assert_eq_u8(cube[0][1][0][0], (u8)9);
    assert_eq_u8(cube[0][1][0][3], (u8)12);
}


fn test_nested_set_slice_invalid_length_panics() -> unit {
    var rows: i64[][] = i64[][](3u);
    var src: i64[][] = i64[][](1u);
    rows[0:2] = src;
}


fn test_nested_inner_slice_oob_panics() -> unit {
    var rows: i64[][] = i64[][](1u);
    rows[0] = i64[](1u);
    rows[0][0:2];
}


fn test_len_on_null_panics() -> unit {
    var values: i64[] = null;
    values.len();
}


fn main() -> i64 {
    var select: u64 = read_program_args()[1].to_u64();

    if select == 1u { test_primitive_smoke(); return 0; }
    if select == 2u { test_reference_default_null(); return 0; }
    if select == 3u { test_bool_and_double_arrays(); return 0; }
    if select == 4u { test_slice_copy_behavior(); return 0; }
    if select == 5u { test_get_oob_panics(); return 0; }
    if select == 6u { test_set_oob_panics(); return 0; }
    if select == 7u { test_slice_oob_panics(); return 0; }
    if select == 8u { test_negative_index_panics(); return 0; }
    if select == 9u { test_set_slice_write_behavior(); return 0; }
    if select == 10u { test_set_slice_invalid_length_panics(); return 0; }
    if select == 11u { test_obj_to_u64_array_cast_ok(); return 0; }
    if select == 12u { test_obj_to_u64_array_cast_bad_kind_panics(); return 0; }
    if select == 13u { test_primitive_array_to_reference_array_cast_panics(); return 0; }
    if select == 14u { test_reference_array_to_primitive_array_cast_panics(); return 0; }
    if select == 15u { test_reference_array_roundtrip_cast_ok(); return 0; }
    if select == 16u { test_nested_primitive_index_get_set_levels(); return 0; }
    if select == 17u { test_nested_primitive_slice_get_set_levels(); return 0; }
    if select == 18u { test_nested_reference_index_slice_levels(); return 0; }
    if select == 19u { test_deeply_nested_u8_index_slice_levels(); return 0; }
    if select == 20u { test_nested_set_slice_invalid_length_panics(); return 0; }
    if select == 21u { test_nested_inner_slice_oob_panics(); return 0; }
    if select == 22u { test_interface_element_arrays_support_storage_and_slice(); return 0; }
    if select == 23u { test_len_on_null_panics(); return 0; }

    fail("Invalid test selection.");
    return 1;
}
