import std.test;
import std.io;

interface Hashable {
    fn hash_code() -> u64;
}

interface Equalable {
    fn equals(other: Obj) -> bool;
}

class Config {
    final code: i64;
    enabled: bool = true;

    constructor() {
        __self.code = 42;
        return;
    }
}

class Early {
    value: i64;
    marker: i64 = 9;

    constructor(value: i64) {
        var temp: i64 = value + 1;
        __self.value = temp;
        if temp > 0 {
            return;
        }
        __self.marker = 0;
        return;
    }
}

class Span {
    start: i64;
    end: i64;

    constructor(start: i64) {
        __self.start = start;
        __self.end = start + 1;
        return;
    }

    constructor(start: i64, end: i64) {
        __self.start = start;
        __self.end = end;
        return;
    }
}

class Tagged {
    kind: i64;
    payload_i: i64 = 0;
    payload_b: bool = false;

    constructor(value: i64) {
        __self.kind = 1;
        __self.payload_i = value;
        return;
    }

    constructor(value: bool) {
        __self.kind = 2;
        __self.payload_b = value;
        return;
    }
}

class Envelope {
    data: i64;
    label: u64 = 5u;

    constructor(data: i64) {
        __self.data = data;
        return;
    }

    constructor(data: i64, label: u64) {
        __self.data = data;
        __self.label = label;
        return;
    }
}

class Secret {
    final value: i64;

    private constructor(value: i64) {
        __self.value = value;
        return;
    }

    static fn make_double(value: i64) -> Secret {
        return Secret(value * 2);
    }

    fn reveal() -> i64 {
        return __self.value;
    }
}

class PrivateCompat {
    private value: i64;

    static fn make_tripled(value: i64) -> PrivateCompat {
        return PrivateCompat(value * 3);
    }

    fn reveal() -> i64 {
        return __self.value;
    }
}

class ChainBase {
    first: i64;
    base_default: u64 = 10u;
}

class ChainMid extends ChainBase {
    second: i64;
    middle_default: bool = true;
}

class ChainLeaf extends ChainMid {
    third: i64 = 99;
}

class OverBase {
    tag: i64;
    value: i64;

    constructor(value: i64) {
        __self.tag = 1;
        __self.value = value;
        return;
    }

    constructor(flag: bool) {
        __self.tag = 2;
        if flag {
            __self.value = 1;
        } else {
            __self.value = 0;
        }
        return;
    }
}

class OverDerived extends OverBase {
    extra: i64;

    constructor(flag: bool, extra: i64) {
        super(flag);
        __self.extra = extra;
        return;
    }
}

class Key implements Hashable, Equalable {
    value: u64;

    constructor(value: u64) {
        __self.value = value;
        return;
    }

    fn hash_code() -> u64 {
        return __self.value + 100u;
    }

    fn equals(other: Obj) -> bool {
        return false;
    }
}

class SpecificSink {
    branch: i64;

    constructor(value: Obj) {
        __self.branch = 1;
        return;
    }

    constructor(value: Hashable) {
        __self.branch = 2;
        return;
    }
}

class CastSink {
    branch: i64;

    constructor(value: Hashable) {
        __self.branch = 3;
        return;
    }

    constructor(value: Equalable) {
        __self.branch = 4;
        return;
    }
}

fn test_explicit_zero_arg_constructor_sets_final_and_defaults() -> unit {
    var cfg: Config = Config();
    assert_eq_i64(cfg.code, 42);
    assert_eq_bool(cfg.enabled, true);
}

fn test_constructor_locals_and_early_return_keep_default_fields() -> unit {
    var e: Early = Early(6);
    assert_eq_i64(e.value, 7);
    assert_eq_i64(e.marker, 9);
}

fn test_overloaded_constructor_by_arity() -> unit {
    var short: Span = Span(10);
    var full: Span = Span(10, 25);
    assert_eq_i64(short.start, 10);
    assert_eq_i64(short.end, 11);
    assert_eq_i64(full.start, 10);
    assert_eq_i64(full.end, 25);
}

fn test_overloaded_constructor_by_exact_type() -> unit {
    var tagged_i: Tagged = Tagged(7);
    var tagged_b: Tagged = Tagged(true);
    assert_eq_i64(tagged_i.kind, 1);
    assert_eq_i64(tagged_i.payload_i, 7);
    assert_eq_i64(tagged_b.kind, 2);
    assert_eq_bool(tagged_b.payload_b, true);
}

fn test_explicit_constructor_defaults_and_override_paths() -> unit {
    var base: Envelope = Envelope(9);
    var custom: Envelope = Envelope(9, 17u);
    assert_eq_i64(base.data, 9);
    assert_eq_u64(base.label, 5u);
    assert_eq_i64(custom.data, 9);
    assert_eq_u64(custom.label, 17u);
}

fn test_private_constructor_via_factory() -> unit {
    var secret: Secret = Secret.make_double(21);
    assert_eq_i64(secret.reveal(), 42);
}

fn test_synthesized_private_compatibility_constructor_via_factory() -> unit {
    var hidden: PrivateCompat = PrivateCompat.make_tripled(14);
    assert_eq_i64(hidden.reveal(), 42);
}

fn test_inherited_compatibility_constructor_order_and_defaults() -> unit {
    var leaf: ChainLeaf = ChainLeaf(4, 7);
    assert_eq_i64(leaf.first, 4);
    assert_eq_i64(leaf.second, 7);
    assert_eq_u64(leaf.base_default, 10u);
    assert_eq_bool(leaf.middle_default, true);
    assert_eq_i64(leaf.third, 99);
}

fn test_explicit_super_selects_overloaded_base_constructor() -> unit {
    var derived: OverDerived = OverDerived(true, 8);
    assert_eq_i64(derived.tag, 2);
    assert_eq_i64(derived.value, 1);
    assert_eq_i64(derived.extra, 8);
}

fn test_constructor_overload_prefers_more_specific_match() -> unit {
    var sink: SpecificSink = SpecificSink(Key(9u));
    assert_eq_i64(sink.branch, 2);
}

fn test_explicit_cast_disambiguates_constructor_overload() -> unit {
    var key: Key = Key(9u);
    var from_hashable: CastSink = CastSink((Hashable)key);
    var from_equalable: CastSink = CastSink((Equalable)key);
    assert_eq_i64(from_hashable.branch, 3);
    assert_eq_i64(from_equalable.branch, 4);
}

fn main() -> i64 {
    var select: u64 = read_program_args()[1].to_u64();

    if select == 1u { test_explicit_zero_arg_constructor_sets_final_and_defaults(); return 0; }
    if select == 2u { test_constructor_locals_and_early_return_keep_default_fields(); return 0; }
    if select == 3u { test_overloaded_constructor_by_arity(); return 0; }
    if select == 4u { test_overloaded_constructor_by_exact_type(); return 0; }
    if select == 5u { test_explicit_constructor_defaults_and_override_paths(); return 0; }
    if select == 6u { test_private_constructor_via_factory(); return 0; }
    if select == 7u { test_synthesized_private_compatibility_constructor_via_factory(); return 0; }
    if select == 8u { test_inherited_compatibility_constructor_order_and_defaults(); return 0; }
    if select == 9u { test_explicit_super_selects_overloaded_base_constructor(); return 0; }
    if select == 10u { test_constructor_overload_prefers_more_specific_match(); return 0; }
    if select == 11u { test_explicit_cast_disambiguates_constructor_overload(); return 0; }

    fail("Invalid test selection.");
    return 1;
}
