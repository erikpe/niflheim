import std.test;
import std.io;
import tests.golden.lang.test_indexing_sugar.util as util;

class FlagMap {
    yes: i64;
    no: i64;

    fn index_get(key: bool) -> i64 {
        if key {
            return __self.yes;
        }
        return __self.no;
    }

    fn index_set(key: bool, value: i64) -> unit {
        if key {
            __self.yes = value;
            return;
        }
        __self.no = value;
    }
}

class WeirdStore {
    stored: bool;

    fn index_get(index: i64) -> bool {
        return __self.stored;
    }

    fn index_set(index: i64, value: i64) -> unit {
        __self.stored = value > 0;
    }
}

class SplitKey {
    value: i64;

    fn index_get(flag: bool) -> i64 {
        if flag {
            return __self.value;
        }
        return 0;
    }

    fn index_set(index: i64, value: i64) -> unit {
        if index == 0 {
            __self.value = value;
        }
    }
}

class ReadOnlyIndex {
    value: i64;

    fn index_get(index: i64) -> i64 {
        if index == 0 {
            return __self.value;
        }
        return -1;
    }
}

class WriteOnlyIndex {
    value: i64;

    fn index_set(index: i64, value: i64) -> unit {
        if index == 0 {
            __self.value = value;
        }
    }

    fn reveal() -> i64 {
        return __self.value;
    }
}

class SliceWindow {
    values: i64[];

    static fn from_three(a: i64, b: i64, c: i64) -> SliceWindow {
        var data: i64[] = i64[](3u);
        data[0] = a;
        data[1] = b;
        data[2] = c;
        return SliceWindow(data);
    }

    fn index_get(index: i64) -> i64 {
        return __self.values[index];
    }

    fn slice_get(begin: i64, end: i64) -> SliceWindow {
        return SliceWindow(__self.values[begin:end]);
    }

    fn slice_set(begin: i64, end: i64, value: SliceWindow) -> unit {
        var i: i64 = 0;
        while begin + i < end {
            __self.values[begin + i] = value.values[i];
            i = i + 1;
        }
        return;
    }
}

class SliceShape {
    flag: bool;
    total: i64;

    fn slice_get(begin: i64, end: i64) -> bool {
        return __self.flag && begin < end;
    }

    fn slice_set(begin: i64, end: i64, value: i64) -> unit {
        __self.total = value + (end - begin);
        return;
    }
}

class BaseBuffer {
    values: i64[];

    fn index_get(index: i64) -> i64 {
        return __self.values[index];
    }

    fn index_set(index: i64, value: i64) -> unit {
        __self.values[index] = value;
        return;
    }

    fn slice_get(begin: i64, end: i64) -> BaseBuffer {
        return BaseBuffer(__self.values[begin:end]);
    }

    fn slice_set(begin: i64, end: i64, value: BaseBuffer) -> unit {
        var i: i64 = 0;
        while begin + i < end {
            __self.values[begin + i] = value.values[i];
            i = i + 1;
        }
        return;
    }
}

class DerivedBuffer extends BaseBuffer {}

interface IndexedSliceBuffer {
    fn index_get(index: i64) -> i64;
    fn index_set(index: i64, value: i64) -> unit;
    fn slice_get(begin: i64, end: i64) -> IndexedSliceBuffer;
    fn slice_set(begin: i64, end: i64, value: IndexedSliceBuffer) -> unit;
}

class InterfaceWindow implements IndexedSliceBuffer {
    values: i64[];

    static fn from_three(a: i64, b: i64, c: i64) -> InterfaceWindow {
        var data: i64[] = i64[](3u);
        data[0] = a;
        data[1] = b;
        data[2] = c;
        return InterfaceWindow(data);
    }

    fn index_get(index: i64) -> i64 {
        return __self.values[index];
    }

    fn index_set(index: i64, value: i64) -> unit {
        __self.values[index] = value;
        return;
    }

    fn slice_get(begin: i64, end: i64) -> IndexedSliceBuffer {
        return InterfaceWindow(__self.values[begin:end]);
    }

    fn slice_set(begin: i64, end: i64, value: IndexedSliceBuffer) -> unit {
        var i: i64 = 0;
        while begin + i < end {
            __self.values[begin + i] = value[i];
            i = i + 1;
        }
        return;
    }
}

fn test_custom_index_key_types() -> unit {
    var m: FlagMap = FlagMap(10, 20);
    assert_eq_i64(m[true], 10);
    assert_eq_i64(m[false], 20);

    m[false] = 99;
    assert_eq_i64(m[false], 99);

    var s: SplitKey = SplitKey(5);
    assert_eq_i64(s[true], 5);
    s[0] = 42;
    assert_eq_i64(s[true], 42);
}

fn test_mismatched_index_read_write_value_types() -> unit {
    var w: WeirdStore = WeirdStore(false);
    assert_false(w[0]);
    w[0] = 7;
    assert_true(w[0]);
    w[0] = -1;
    assert_false(w[0]);
}

fn test_read_only_and_write_only_index_sugar() -> unit {
    var ro: ReadOnlyIndex = ReadOnlyIndex(77);
    assert_eq_i64(ro[0], 77);

    var wo: WriteOnlyIndex = WriteOnlyIndex(0);
    wo[0] = 123;
    assert_eq_i64(wo.reveal(), 123);
}

fn test_slice_get_and_set_for_user_class() -> unit {
    var sw: SliceWindow = SliceWindow.from_three(1, 2, 3);
    var cut: SliceWindow = sw[0:2];
    assert_eq_i64(cut[0], 1);
    assert_eq_i64(cut[1], 2);

    var repl: SliceWindow = SliceWindow.from_three(9, 8, 7);
    sw[1:3] = repl;
    assert_eq_i64(sw[0], 1);
    assert_eq_i64(sw[1], 9);
    assert_eq_i64(sw[2], 8);
}

fn test_slice_read_write_independence() -> unit {
    var shape: SliceShape = SliceShape(true, 0);
    assert_true(shape[0:1]);
    assert_false(shape[1:1]);

    shape[1:3] = 10;
    assert_eq_i64(shape.total, 12);
}

fn test_inherited_index_and_slice_members() -> unit {
    var values: i64[] = i64[](3u);
    values[0] = 3;
    values[1] = 4;
    values[2] = 5;

    var buf: DerivedBuffer = DerivedBuffer(values);
    assert_eq_i64(buf[1], 4);

    buf[1] = 11;
    assert_eq_i64(buf[1], 11);

    var cut: BaseBuffer = buf[1:3];
    assert_eq_i64(cut[0], 11);
    assert_eq_i64(cut[1], 5);

    var repl_values: i64[] = i64[](2u);
    repl_values[0] = 21;
    repl_values[1] = 22;
    buf[0:2] = BaseBuffer(repl_values);
    assert_eq_i64(buf[0], 21);
    assert_eq_i64(buf[1], 22);
    assert_eq_i64(buf[2], 5);
}

fn test_imported_index_and_slice_sugar() -> unit {
    var window: util.ImportedWindow = util.ImportedWindow.from_three(4, 5, 6);
    assert_eq_i64(window[0], 4);

    window[2] = 12;
    assert_eq_i64(window[2], 12);

    var cut: util.ImportedWindow = window[1:3];
    assert_eq_i64(cut[0], 5);
    assert_eq_i64(cut[1], 12);

    var repl: util.ImportedWindow = util.ImportedWindow.from_three(30, 31, 32);
    window[0:2] = repl;
    assert_eq_i64(window[0], 30);
    assert_eq_i64(window[1], 31);
    assert_eq_i64(window[2], 12);
}

fn test_interface_typed_index_and_slice_sugar() -> unit {
    var window: IndexedSliceBuffer = InterfaceWindow.from_three(4, 5, 6);
    assert_eq_i64(window[0], 4);

    window[2] = 12;
    assert_eq_i64(window[2], 12);

    var cut: IndexedSliceBuffer = window[1:3];
    assert_eq_i64(cut[0], 5);
    assert_eq_i64(cut[1], 12);

    var repl: IndexedSliceBuffer = InterfaceWindow.from_three(30, 31, 32);
    window[0:2] = repl;
    assert_eq_i64(window[0], 30);
    assert_eq_i64(window[1], 31);
    assert_eq_i64(window[2], 12);
}

fn main() -> i64 {
    var select: u64 = read_program_args()[1].to_u64();

    if select == 1u { test_custom_index_key_types(); return 0; }
    if select == 2u { test_mismatched_index_read_write_value_types(); return 0; }
    if select == 3u { test_read_only_and_write_only_index_sugar(); return 0; }
    if select == 4u { test_slice_get_and_set_for_user_class(); return 0; }
    if select == 5u { test_slice_read_write_independence(); return 0; }
    if select == 6u { test_inherited_index_and_slice_members(); return 0; }
    if select == 7u { test_imported_index_and_slice_sugar(); return 0; }
    if select == 8u { test_interface_typed_index_and_slice_sugar(); return 0; }

    fail("Invalid test selection.");
    return 1;
}
