export class ImportedWindow {
    values: i64[];

    static fn from_three(a: i64, b: i64, c: i64) -> ImportedWindow {
        var data: i64[] = i64[](3u);
        data[0] = a;
        data[1] = b;
        data[2] = c;
        return ImportedWindow(data);
    }

    fn index_get(index: i64) -> i64 {
        return __self.values[index];
    }

    fn index_set(index: i64, value: i64) -> unit {
        __self.values[index] = value;
        return;
    }

    fn slice_get(begin: i64, end: i64) -> ImportedWindow {
        return ImportedWindow(__self.values[begin:end]);
    }

    fn slice_set(begin: i64, end: i64, value: ImportedWindow) -> unit {
        var i: i64 = 0;
        while begin + i < end {
            __self.values[begin + i] = value.values[i];
            i = i + 1;
        }
        return;
    }
}