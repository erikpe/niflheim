import std.test;
import std.io;
import std.object;

interface Hashable {
    fn hash_code() -> u64;
}

class Key implements Hashable {
    value: u64;

    fn hash_code() -> u64 {
        return __self.value + 1u;
    }
}

class Box {
    value: u64;
}

fn test_obj_type_tests() -> unit {
    var obj: Obj = Key(7u);

    assert_eq_bool(obj is Key, true);
    assert_eq_bool(obj is Hashable, true);
    assert_eq_bool(obj is Box, false);
}

fn test_interface_type_tests() -> unit {
    var hashable: Hashable = Key(9u);

    assert_eq_bool(hashable is Key, true);
    assert_eq_bool(hashable is Hashable, true);
    assert_eq_bool(hashable is Box, false);
}

fn test_null_type_tests() -> unit {
    var obj: Obj = null;
    var hashable: Hashable = (Hashable)null;

    assert_eq_bool(obj is Key, false);
    assert_eq_bool(obj is Hashable, false);
    assert_eq_bool(hashable is Key, false);
    assert_eq_bool(hashable is Hashable, false);
}

fn test_exact_type_checks() -> unit {
    var key: Key = Key(11u);

    assert_eq_bool(key is Key, true);
    assert_eq_bool(key is Hashable, true);
}

fn main() -> i64 {
    var select: u64 = read_program_args()[1].to_u64();

    if select == 1u { test_obj_type_tests(); return 0; }
    if select == 2u { test_interface_type_tests(); return 0; }
    if select == 3u { test_null_type_tests(); return 0; }
    if select == 4u { test_exact_type_checks(); return 0; }

    fail("Invalid test selection.");
    return 1;
}