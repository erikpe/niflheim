import std.test;
import std.io;
import std.object;

interface Hashable {
    fn hash_code() -> u64;
}

class Key implements Hashable {
    value: u64;

    fn hash_code() -> u64 {
        return __self.value + 1u;
    }
}

class Box {
    value: u64;
}

fn test_obj_type_tests() -> unit {
    var obj: Obj = Key(7u);

    assert_true(obj is Key);
    assert_true(obj is Hashable);
    assert_false(obj is Box);
}

fn test_interface_type_tests() -> unit {
    var hashable: Hashable = Key(9u);

    assert_true(hashable is Key);
    assert_true(hashable is Hashable);
    assert_false(hashable is Box);
}

fn test_null_type_tests() -> unit {
    var obj: Obj = null;
    var hashable: Hashable = (Hashable)null;

    assert_false(obj is Key);
    assert_false(obj is Hashable);
    assert_false(hashable is Key);
    assert_false(hashable is Hashable);
}

fn test_exact_type_checks() -> unit {
    var key: Key = Key(11u);

    assert_true(key is Key);
    assert_true(key is Hashable);
}

fn main() -> i64 {
    var select: u64 = read_program_args()[1].to_u64();

    if select == 1u { test_obj_type_tests(); return 0; }
    if select == 2u { test_interface_type_tests(); return 0; }
    if select == 3u { test_null_type_tests(); return 0; }
    if select == 4u { test_exact_type_checks(); return 0; }

    fail("Invalid test selection.");
    return 1;
}