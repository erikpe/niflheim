import std.test;
import std.box;
import std.error;
import std.io;


class MapU64 {
    private _len: u64;
    private _capacity: u64;
    private _keys: u64[];
    private _values: Obj[];
    private _occupied: bool[];

    static fn new() -> MapU64 {
        return MapU64.with_capacity(8u);
    }

    static fn with_capacity(min_capacity: u64) -> MapU64 {
        var capacity: u64 = 8u;
        while capacity < min_capacity {
            capacity = capacity * 2u;
        }
        return MapU64(0u, capacity, u64[](capacity), Obj[](capacity), bool[](capacity));
    }

    fn len() -> u64 {
        return __self._len;
    }

    fn contains(key: u64) -> bool {
        return __self._find_existing_index(key) >= 0;
    }

    fn index_get(key: u64) -> Obj {
        var index: i64 = __self._find_existing_index(key);
        if index < 0 {
            panic("MapU64.index_get: key not found");
        }
        return __self._values[index];
    }

    fn put(key: u64, value: Obj) -> unit {
        __self._maybe_grow_for_insert();
        if __self._insert_or_assign(key, value) {
            __self._len = __self._len + 1u;
        }
    }

    fn index_set(key: u64, value: Obj) -> unit {
        __self.put(key, value);
    }

    private fn _maybe_grow_for_insert() -> unit {
        if ((__self._len + 1u) * 10u) < (__self._capacity * 7u) {
            return;
        }
        __self._rehash(__self._capacity * 2u);
    }

    private fn _rehash(new_capacity: u64) -> unit {
        var old_capacity: i64 = (i64)__self._capacity;
        var old_keys: u64[] = __self._keys;
        var old_values: Obj[] = __self._values;
        var old_occupied: bool[] = __self._occupied;

        __self._capacity = new_capacity;
        __self._keys = u64[](new_capacity);
        __self._values = Obj[](new_capacity);
        __self._occupied = bool[](new_capacity);
        __self._len = 0u;

        var i: i64 = 0;
        while i < old_capacity {
            if old_occupied[i] {
                if __self._insert_or_assign(old_keys[i], old_values[i]) {
                    __self._len = __self._len + 1u;
                }
            }
            i = i + 1;
        }
    }

    private fn _hash(key: u64) -> u64 {
        return key * 11400714819323198485u;
    }

    private fn _find_existing_index(key: u64) -> i64 {
        var capacity_i64: i64 = (i64)__self._capacity;
        var index: i64 = (i64)(__self._hash(key) % __self._capacity);
        var probes: i64 = 0;

        while probes < capacity_i64 {
            if !__self._occupied[index] {
                return -1;
            }

            if __self._keys[index] == key {
                return index;
            }

            index = index + 1;
            if index >= capacity_i64 {
                index = 0;
            }
            probes = probes + 1;
        }

        return -1;
    }

    private fn _insert_or_assign(key: u64, value: Obj) -> bool {
        var capacity_i64: i64 = (i64)__self._capacity;
        var index: i64 = (i64)(__self._hash(key) % __self._capacity);
        var probes: i64 = 0;

        while probes < capacity_i64 {
            if !__self._occupied[index] {
                __self._occupied[index] = true;
                __self._keys[index] = key;
                __self._values[index] = value;
                return true;
            }

            if __self._keys[index] == key {
                __self._values[index] = value;
                return false;
            }

            index = index + 1;
            if index >= capacity_i64 {
                index = 0;
            }
            probes = probes + 1;
        }

        panic("MapU64: table full");
        return false;
    }
}


fn test_put_get_contains() -> unit {
    var m: MapU64 = MapU64.new();
    assert_true(m.len() == 0u);

    m.put(10u, BoxI64(111));
    m.put(20u, BoxI64(222));

    assert_true(m.len() == 2u);
    assert_true(m.contains(10u));
    assert_true(m.contains(20u));
    assert_true(!m.contains(30u));

    assert_true(((BoxI64)m.index_get(10u)).val == 111);
    assert_true(((BoxI64)m.index_get(20u)).val == 222);
}


fn test_overwrite_same_key() -> unit {
    var m: MapU64 = MapU64.new();
    m.put(7u, BoxI64(1));
    m.put(7u, BoxI64(9));

    assert_true(m.len() == 1u);
    assert_true(m.contains(7u));
    assert_true(((BoxI64)m.index_get(7u)).val == 9);
}


fn test_growth_and_probe_chains() -> unit {
    var m: MapU64 = MapU64.with_capacity(2u);

    var i: u64 = 0u;
    while i < 80u {
        var key: u64 = i * 17u + 3u;
        m.put(key, BoxU64(i));
        i = i + 1u;
    }

    assert_true(m.len() == 80u);

    i = 0u;
    while i < 80u {
        var verify_key: u64 = i * 17u + 3u;
        assert_true(m.contains(verify_key));
        assert_true(((BoxU64)m.index_get(verify_key)).val == i);
        i = i + 1u;
    }
}


fn test_index_sugar_write_and_read() -> unit {
    var m: MapU64 = MapU64.new();

    m[1u] = BoxI64(42);
    m[2u] = BoxI64(99);

    assert_true(((BoxI64)m[1u]).val == 42);
    assert_true(((BoxI64)m[2u]).val == 99);
    assert_true(m.len() == 2u);
}


fn test_get_missing_panics() -> unit {
    var m: MapU64 = MapU64.new();
    var v: Obj = m.index_get(999u);
}


fn test_large_insert_then_overwrite_all() -> unit {
    var m: MapU64 = MapU64.with_capacity(1u);

    var i: u64 = 0u;
    while i < 512u {
        var key: u64 = i * 131u + 17u;
        m.put(key, BoxU64(i));
        i = i + 1u;
    }

    assert_true(m.len() == 512u);

    i = 0u;
    while i < 512u {
        var verify_key: u64 = i * 131u + 17u;
        assert_true(m.contains(verify_key));
        assert_true(((BoxU64)m.index_get(verify_key)).val == i);
        i = i + 1u;
    }

    i = 0u;
    while i < 512u {
        var rewrite_key: u64 = i * 131u + 17u;
        m.put(rewrite_key, BoxU64(i + 1000u));
        i = i + 1u;
    }

    assert_true(m.len() == 512u);

    i = 0u;
    while i < 512u {
        var check_key: u64 = i * 131u + 17u;
        assert_true(((BoxU64)m.index_get(check_key)).val == i + 1000u);
        i = i + 1u;
    }
}


fn test_collision_cluster_same_bucket() -> unit {
    var m: MapU64 = MapU64.with_capacity(8u);

    m.put(1u, BoxI64(10));
    m.put(9u, BoxI64(20));
    m.put(17u, BoxI64(30));
    m.put(25u, BoxI64(40));
    m.put(33u, BoxI64(50));

    assert_true(m.len() == 5u);
    assert_true(((BoxI64)m.index_get(1u)).val == 10);
    assert_true(((BoxI64)m.index_get(9u)).val == 20);
    assert_true(((BoxI64)m.index_get(17u)).val == 30);
    assert_true(((BoxI64)m.index_get(25u)).val == 40);
    assert_true(((BoxI64)m.index_get(33u)).val == 50);

    m.put(17u, BoxI64(300));
    assert_true(m.len() == 5u);
    assert_true(((BoxI64)m.index_get(17u)).val == 300);
    assert_true(!m.contains(41u));
}


fn main() -> i64 {
    var select: u64 = read_stdin().strip().to_u64();

    if select == 1u { test_put_get_contains(); }
    if select == 2u { test_overwrite_same_key(); }
    if select == 3u { test_growth_and_probe_chains(); }
    if select == 4u { test_index_sugar_write_and_read(); }
    if select == 5u { test_get_missing_panics(); }
    if select == 6u { test_large_insert_then_overwrite_all(); }
    if select == 7u { test_collision_cluster_same_bucket(); }

    return 0;
}