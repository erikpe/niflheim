import std.io;
import std.str;
import std.vec;

fn main() -> i64
{
    var dial: i64 = 50;
    var password: i64 = 0;

    for row in read_all().splitlines() {
        var line: Str = (Str)row;
        var direction: u8 = line[0];
        var clicks: i64 = line[1:].to_i64();
        if direction == 'L' {
            dial = (dial - clicks) % 100;
        }
        else if direction == 'R' {
            dial = (dial + clicks) % 100;
        }
        if dial == 0 {
            password = password + 1;
        }
    }

    print("RESULT:");
    println_i64(password);

    return 0;
}
