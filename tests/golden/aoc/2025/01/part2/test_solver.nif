import std.io;
import std.str;
import std.vec;

fn count_zero_hits(start: i64, clicks: i64) -> i64
{
    var first_hit: i64 = 0;
    if start == 0 {
        first_hit = 100;
    }
    else {
        first_hit = start;
    }

    if clicks < first_hit {
        return 0;
    }

    return 1 + ((clicks - first_hit) / 100);
}

fn main() -> i64
{
    var dial: i64 = 50;
    var password: i64 = 0;

    for row in read_stdin().splitlines() {
        var line: Str = (Str)row;
        var direction: u8 = line[0];
        var clicks: i64 = line[1:].to_i64();
        if direction == 'L' {
            password = password + count_zero_hits(dial, clicks);

            var reduced_clicks: i64 = clicks % 100;
            dial = dial - reduced_clicks;
            if dial < 0 {
                dial = dial + 100;
            }
        }
        else if direction == 'R' {
            var right_start: i64 = 100 - dial;
            if right_start == 100 {
                right_start = 0;
            }
            password = password + count_zero_hits(right_start, clicks);

            dial = (dial + (clicks % 100)) % 100;
        }
    }

    print("RESULT:");
    println_i64(password);

    return 0;
}
