import std.io;
import std.error;
import std.range;
import std.str;
import std.vec;

fn decode_end_state(end_state_str: Str) -> u64
{
    var end_state_bits: u64 = 0u;
    var i: u64 = 0u;
    for ch in end_state_str[1:-1] {
        if ch == '#' {
            end_state_bits = end_state_bits | (1u << i);
        }
        i = i + 1u;
    }
    return end_state_bits;
}

fn decode_press(press_str: Str) -> u64
{
    var press_bits: u64 = 0u;
    for press in press_str[1:-1].split(',') {
        press_bits = press_bits | (1u << ((Str)press).to_u64());
    }
    return press_bits;
}

fn find_endstate(end_state_bits: u64, presses_bits: u64[], num_presses: u64) -> bool
{
    var base_count: u64 = presses_bits.len();
    var total: u64 = 1u;

    if num_presses > base_count {
        total = 0u;
    } else if num_presses > 0u {
        // combinations without repetition: C(base_count, num_presses)
        for comb_i in Range(1, (i64)num_presses + 1) {
                total = (total * (base_count - num_presses + (u64)comb_i)) / (u64)comb_i;
        }
    }

    var indices: u64[] = u64[](num_presses);
        for init_i in Range(0, (i64)num_presses) {
            indices[init_i] = (u64)init_i;
    }

    for out_index in Range(0, (i64)total) {
        var running_state: u64 = 0u;
        for j in Range(0, (i64)num_presses) {
            running_state = running_state ^ presses_bits[(i64)indices[j]];
        }
        if running_state == end_state_bits {
            return true;
        }

        if (u64)(out_index + 1) < total {
            var p: i64 = (i64)num_presses - 1;
            while p >= 0 {
                var limit: u64 = base_count - (num_presses - (u64)p);
                if indices[p] < limit {
                    var next_value: u64 = indices[p] + 1u;
                    indices[p] = next_value;
                    for q in Range(p + 1, (i64)num_presses) {
                        indices[q] = indices[q - 1] + 1u;
                    }
                    break;
                }
                p = p - 1;
            }
        }
    }

    return false;
}

fn solve_machine(machine: Str) -> u64
{
    var parts: Vec = machine.split(' ');
    var end_state_bits: u64 = decode_end_state((Str)parts[0]);

    var presses_bits: u64[] = u64[](parts.len() - 2u);
    for part_index in Range(1, (i64)parts.len() - 1) {
        presses_bits[part_index - 1] = decode_press((Str)parts[part_index]);
    }

    var num_presses: u64 = 1u;
    while true {
        if find_endstate(end_state_bits, presses_bits, num_presses) {
            return num_presses;
        }
        num_presses = num_presses + 1u;
    }
    return 0u;
}

fn main() -> i64
{
    var min_presses: u64 = 0u;
    for line in read_stdin().splitlines() {
        min_presses = min_presses + solve_machine((Str)line);
    }
    print("RESULT:");
    println_u64(min_presses);
    return 0;
}
