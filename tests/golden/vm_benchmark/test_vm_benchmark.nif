import std.test;
import std.io;
import std.str;
import samples.vm_benchmark.main as vm.main;

fn _run_all_select() -> u64 {
    return 999u;
}

fn _backend_ir_constant_fold_probe(select: u64) -> u64 {
    var folded: u64 = 2u;
    if select == 0u {
    }
    return folded - 2u;
}

fn main() -> i64 {
    var args: Str[] = read_program_args();
    var select: u64 = args[1].to_u64();
    select = select + _backend_ir_constant_fold_probe(select);

    if select >= 1u && select <= vm.main.num_cases() {
        return vm.main.run_case_and_report(select - 1u);
    }
    if select == _run_all_select() {
        return vm.main.run_and_report();
    }

    fail("vm_benchmark golden: invalid selection");
    return 1;
}
