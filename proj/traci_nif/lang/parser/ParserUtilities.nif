import std.str;

export fn unquote_qstring(value: Str) -> Str {
    if value == null {
        return null;
    }

    var out: StrBuf = StrBuf.new(value.len());
    var i: i64 = 1;
    var stop: i64 = (i64)value.len() - 1;
    while i < stop {
        var ch: u8 = value[i];
        if ch == '\\' && i + 1 < stop {
            out.append_char(value[i + 1]);
            i = i + 2;
            continue;
        }

        out.append_char(ch);
        i = i + 1;
    }

    return out.to_str();
}