import std.str;

extern fn rt_panic_null_term_array(msg: u8[]) -> unit;

export fn panic(msg: Str) -> unit
{
    var length: i64 = (i64)msg.len();
    var msg_arr: u8[] = u8[]((u64)length + 1u);
    msg_arr[0:length] = msg.to_u8_array();
    msg_arr[length] = '\0';

    rt_panic_null_term_array(msg_arr);
}
