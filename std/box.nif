export class BoxBool implements Comparable, Equalable, Hashable
{
    final val: bool;

    fn compare_to(other: Obj) -> i64 {
        if !(other is BoxBool) {
            panic("BoxBool.compare_to: other is not a BoxBool");
        }
        var other_box: BoxBool = (BoxBool)other;
        if __self.val == other_box.val {
            return 0;
        }
        if __self.val {
            return 1;
        }
        return -1;
    }

    fn equals(other: Obj) -> bool {
        if !(other is BoxBool) {
            return false;
        }
        return __self.val == ((BoxBool)other).val;
    }

    fn hash_code() -> u64 {
        if __self.val {
            return 1u;
        }
        return 0u;
    }
}

export class BoxDouble implements Comparable, Equalable, Hashable
{
    final val: double;

    fn compare_to(other: Obj) -> i64 {
        if !(other is BoxDouble) {
            panic("BoxDouble.compare_to: other is not a BoxDouble");
        }
        var other_box: BoxDouble = (BoxDouble)other;
        if __self.val < other_box.val {
            return -1;
        }
        if __self.val > other_box.val {
            return 1;
        }
        return 0;
    }

    fn equals(other: Obj) -> bool {
        if !(other is BoxDouble) {
            return false;
        }
        return __self.val == ((BoxDouble)other).val;
    }

    fn hash_code() -> u64 {
        return Str.from_double(__self.val).hash_code();
    }
}
