export class BoxI64 implements Comparable, Equalable, Hashable
{
    final val: i64;

    fn compare_to(other: Obj) -> i64 {
        if !(other is BoxI64) {
            panic("BoxI64.compare_to: other is not a BoxI64");
        }
        var other_box: BoxI64 = (BoxI64)other;
        if __self.val < other_box.val {
            return -1;
        }
        if __self.val > other_box.val {
            return 1;
        }
        return 0;
    }

    fn equals(other: Obj) -> bool {
        if !(other is BoxI64) {
            return false;
        }
        return __self.val == ((BoxI64)other).val;
    }

    fn hash_code() -> u64 {
        return (u64)__self.val;
    }
}

export class BoxU64 implements Comparable, Equalable, Hashable
{
    final val: u64;

